<Project Sdk="Microsoft.NET.Sdk">

  <!-- The other half of the #69 spike: what does a flow editor cost if we write it ourselves?
       Forced on us rather than chosen — every node-editor library for Avalonia depends on
       Avalonia.Xaml.Behaviors, which has no Avalonia 12 release, and the cockpit is on Avalonia 12. The library
       spike next door compiles and then dies with a TypeLoadException the moment a behavior attaches.
       This is deliberately plain Avalonia: no library, nothing but what the cockpit already has. -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.5" />
  </ItemGroup>

</Project>
