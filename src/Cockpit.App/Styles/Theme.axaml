<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cockpit dark theme: flat, hairline-bordered, quiet. Tokens are consumed as
         DynamicResource so a future light/alt theme can swap this dictionary wholesale. -->
    <Styles.Resources>
        <ResourceDictionary>

            <!-- Surfaces -->
            <Color x:Key="CockpitWindowBgColor">#16181D</Color>
            <Color x:Key="CockpitPanelBgColor">#1E2128</Color>
            <Color x:Key="CockpitSecondaryBgColor">#131519</Color>
            <Color x:Key="CockpitHairlineColor">#2C2F37</Color>

            <SolidColorBrush x:Key="CockpitWindowBgBrush" Color="{StaticResource CockpitWindowBgColor}"/>
            <SolidColorBrush x:Key="CockpitPanelBgBrush" Color="{StaticResource CockpitPanelBgColor}"/>
            <SolidColorBrush x:Key="CockpitSecondaryBgBrush" Color="{StaticResource CockpitSecondaryBgColor}"/>
            <SolidColorBrush x:Key="CockpitHairlineBrush" Color="{StaticResource CockpitHairlineColor}"/>

            <!-- Text -->
            <Color x:Key="CockpitTextPrimaryColor">#E6E7EA</Color>
            <Color x:Key="CockpitTextSecondaryColor">#9498A3</Color>
            <Color x:Key="CockpitTextFaintColor">#6B6F79</Color>

            <SolidColorBrush x:Key="CockpitTextPrimaryBrush" Color="{StaticResource CockpitTextPrimaryColor}"/>
            <SolidColorBrush x:Key="CockpitTextSecondaryBrush" Color="{StaticResource CockpitTextSecondaryColor}"/>
            <SolidColorBrush x:Key="CockpitTextFaintBrush" Color="{StaticResource CockpitTextFaintColor}"/>

            <!-- User message bubble (T2): a calm cool-slate fill, distinct from the warm-neutral panel so
                 the operator's own lines read as "mine" on the right without shouting. -->
            <Color x:Key="CockpitUserBubbleColor">#28313B</Color>
            <SolidColorBrush x:Key="CockpitUserBubbleBrush" Color="{StaticResource CockpitUserBubbleColor}"/>

            <!-- Accent + status -->
            <Color x:Key="CockpitAccentColor">#D97757</Color>
            <Color x:Key="CockpitStatusBusyColor">#4A90E2</Color>
            <Color x:Key="CockpitStatusWaitingColor">#E0A33E</Color>
            <Color x:Key="CockpitStatusDoneColor">#5AA576</Color>
            <!-- Error toast severity (#61) — no session status used red before this, so a new token. -->
            <Color x:Key="CockpitStatusErrorColor">#D64545</Color>

            <SolidColorBrush x:Key="CockpitAccentBrush" Color="{StaticResource CockpitAccentColor}"/>
            <SolidColorBrush x:Key="CockpitAccentHoverBrush" Color="#E08867"/>
            <SolidColorBrush x:Key="CockpitAccentPressedBrush" Color="#C4694A"/>
            <SolidColorBrush x:Key="CockpitStatusBusyBrush" Color="{StaticResource CockpitStatusBusyColor}"/>
            <SolidColorBrush x:Key="CockpitStatusWaitingBrush" Color="{StaticResource CockpitStatusWaitingColor}"/>
            <SolidColorBrush x:Key="CockpitStatusDoneBrush" Color="{StaticResource CockpitStatusDoneColor}"/>
            <SolidColorBrush x:Key="CockpitStatusErrorBrush" Color="{StaticResource CockpitStatusErrorColor}"/>

            <!-- Geometry -->
            <CornerRadius x:Key="CockpitControlRadius">6</CornerRadius>
            <CornerRadius x:Key="CockpitPanelRadius">10</CornerRadius>
            <Thickness x:Key="CockpitHairlineThickness">1</Thickness>

            <!-- Typography: the transcript uses a terminal font so tool blocks and code read as a
                 Claude-TTY surface; the same family the TTY panel renders with. -->
            <FontFamily x:Key="CockpitMonoFont">Cascadia Mono, Consolas, monospace</FontFamily>

        </ResourceDictionary>
    </Styles.Resources>

    <!-- Window chrome -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource CockpitWindowBgBrush}"/>
    </Style>


    <!-- Base text. :is() so SelectableTextBlock (transcript rows, T3) inherits the same treatment as
         plain TextBlock — an exact-type selector would skip the derived SelectableTextBlock. -->
    <Style Selector=":is(TextBlock)">
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
    </Style>

    <!-- Transcript row surface (T2 + look&feel pass). Assistant/tool/thinking rows are flat — no card,
         so the transcript reads calm (the approved mockup); only a user row is a right-aligned, tinted
         bubble. State is set only through these classes — never inline on the Border — so the setters
         win (the Avalonia local-value gotcha). -->
    <Style Selector="Border.transcriptRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.transcriptRow.userRow">
        <Setter Property="Background" Value="{StaticResource CockpitUserBubbleBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="MaxWidth" Value="520"/>
    </Style>

    <!-- Buttons: flat, hairline border, rounded corners. Accent reserved for primary actions
         via the "Accent" style class (applied explicitly, not globally). -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource CockpitHairlineThickness}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
    </Style>

    <Style Selector="Button.Accent">
        <Setter Property="Background" Value="{StaticResource CockpitAccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
    </Style>
    <Style Selector="Button.Accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitAccentHoverBrush}"/>
    </Style>
    <Style Selector="Button.Accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitAccentPressedBrush}"/>
    </Style>

    <!-- Subtle buttons used as toggles (chevrons, "Thinking..." collapsers) — no chrome, just text. -->
    <Style Selector="Button.Subtle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2"/>
    </Style>
    <Style Selector="Button.Subtle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextBlock.Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
    </Style>
    <!-- Disabled Subtle button (e.g. Remove with nothing selected): stay chromeless — without this the
         default theme paints a grey disabled box, which reads as a broken/mis-styled button. -->
    <Style Selector="Button.Subtle:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextBlock.Foreground" Value="{StaticResource CockpitTextFaintBrush}"/>
    </Style>

    <!-- Compact button: denser secondary action (Stop) that must not compete with the accent. Shares
         the compact selectors' height/surface so the session top bar (Stop + mode/model/effort) reads
         as one aligned row of controls. -->
    <Style Selector="Button.Compact">
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextSecondaryBrush}"/>
    </Style>

    <!-- ToggleButton (e.g. the Zoom toggle): flat like a neutral button, cockpit accent when
         checked instead of the Fluent blue, so the active state matches the theme. -->
    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource CockpitHairlineThickness}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
    </Style>
    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
    </Style>
    <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitAccentHoverBrush}"/>
    </Style>

    <!-- ComboBox: flat, hairline, compact -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource CockpitHairlineThickness}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- ComboBox dropdown items: quiet cockpit selection (panel-bg highlight) instead of the default
         Fluent-blue, so an open mode/model/effort picker matches the dark theme. -->
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
    </Style>

    <!-- Compact selectors: the per-session mode/model/effort pickers are context controls, not the
         focus — shrink them (smaller font, tighter padding, faint text) so the transcript dominates. -->
    <Style Selector="ComboBox.Compact">
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextSecondaryBrush}"/>
    </Style>

    <!-- TextBox: dark input surface -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource CockpitHairlineThickness}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
        <Setter Property="Foreground" Value="{StaticResource CockpitTextFaintBrush}"/>
    </Style>
    <!-- Focused input: cockpit accent border instead of the default Fluent-blue focus ring (L10). -->
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
    </Style>

    <!-- NumericUpDown (e.g. the idle-minutes input): match the cockpit inputs — secondary background,
         hairline border, rounded — instead of the bare default that clashed with the theme. -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource CockpitHairlineThickness}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>
    <Style Selector="NumericUpDown /template/ ButtonSpinner">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Transcript body text: terminal font for the Claude-TTY reading surface. -->
    <Style Selector=":is(TextBlock).transcript">
        <Setter Property="FontFamily" Value="{StaticResource CockpitMonoFont}"/>
        <Setter Property="FontSize" Value="12.5"/>
    </Style>

    <!-- Tool rows (Bash(cmd…), Edit(…), tool results): mono, dimmed, one-line-feel toggles so they
         read as quiet, collapsible tool blocks rather than prose. -->
    <Style Selector="Button.toolRow">
        <Setter Property="FontFamily" Value="{StaticResource CockpitMonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector=":is(TextBlock).toolBody">
        <Setter Property="FontFamily" Value="{StaticResource CockpitMonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Structured/code result box (T6): a monospace panel a shade darker than the row, so JSON/code
         results read as a code block rather than prose. The copy button floats top-right. -->
    <Style Selector="Border.codeBox">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="Button.copyBtn">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,2,2,0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextFaintBrush}"/>
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
    </Style>
    <Style Selector="Button.copyBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="TextBlock.Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
    </Style>

    <!-- Cockpit sidebar session item. State is driven only by classes (never inline on the Border) so
         style setters actually win: the base row is flat and transparent, blending into the sidebar; the
         active row lifts to a filled card with a Claude-orange left edge so the selected session is
         unmistakable. The 2px left gutter is reserved as transparent on every row so text doesn't shift
         when selection moves. Order matters: .attention is declared after .active so its tinted fill wins
         for a row that is both selected and waiting, while .active still supplies the orange edge. -->
    <Style Selector="Border.sessionItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Border.sessionItem:pointerover">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
    </Style>
    <Style Selector="Border.sessionItem.active">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
    </Style>

    <!-- Active session panel (main grid): the selected panel carries the Claude-orange edge so the
         one you're driving jumps out of the grid; inactive panels keep the quiet hairline. -->
    <Style Selector="Border.panel">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitHairlineBrush}"/>
    </Style>
    <!-- Needs-attention grid panel: an amber edge so a session that needs you jumps out of the grid
         even while you're driving another one. The active panel's orange edge below still wins when a
         panel is both selected and waiting (that one already has your eye). -->
    <Style Selector="Border.panel.attention">
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitStatusWaitingBrush}"/>
    </Style>
    <Style Selector="Border.panel.active">
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
    </Style>

    <!-- Needs-attention sidebar item: a soft accent-tinted fill so it reads louder than a plain dot.
         Declared after .active so an active+waiting row keeps this tint (with .active's orange edge). -->
    <Style Selector="Border.sessionItem.attention">
        <Setter Property="Background" Value="#2E2A26"/>
    </Style>

    <!-- ListBox (profile manager): flat, transparent; the selected row gets a quiet panel-bg fill
         (matching the sidebar's active treatment) instead of the default Fluent-blue highlight. -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="6,5"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CockpitControlRadius}"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
    </Style>

    <!-- TabControl / TabItem: a compact segmented "pill" bar instead of Avalonia's default underlined
         text tabs (Options dialog). Each tab is a rounded chip on the dark tab strip; the selected one
         fills with the cockpit accent, an unselected one lifts to a quiet panel fill on hover. The
         TabItem template is replaced wholesale so the Fluent selected-underline is gone entirely — the
         accent fill is the state signal, so it stays obvious regardless of text-colour inheritance. -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="{StaticResource CockpitWindowBgBrush}"/>
        <Setter Property="Padding" Value="8,10,8,0"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="Foreground" Value="{StaticResource CockpitTextSecondaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource CockpitControlRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Header}"
                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="TabItem:pointerover">
        <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Background" Value="{StaticResource CockpitAccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TabItem:selected:pointerover">
        <Setter Property="Background" Value="{StaticResource CockpitAccentHoverBrush}"/>
    </Style>

</Styles>
