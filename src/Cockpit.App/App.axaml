<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Cockpit.App.App"
             xmlns:local="using:Cockpit.App"
             RequestedThemeVariant="Dark">
             <!-- Cockpit is dark-only by design (see Styles/Theme.axaml) — no light variant offered. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Cockpit.App/Styles/Theme.axaml"/>
    </Application.Styles>
</Application>