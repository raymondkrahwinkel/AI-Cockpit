<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Cockpit.App.App"
             xmlns:local="using:Cockpit.App"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Dark">
             <!-- Cockpit is dark-only by design (see Styles/Theme.axaml) — no light variant offered. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <!-- Material icon styles, app-wide, so the host and every plugin draw from the same bundled icon set (AC-33). -->
        <materialIcons:MaterialIconStyles />
        <!-- DataGrid theme, app-wide, so plugin dialogs (#14) can host a DataGrid without shipping/theming their own. -->
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://Cockpit.App/Styles/Theme.axaml"/>
    </Application.Styles>
</Application>