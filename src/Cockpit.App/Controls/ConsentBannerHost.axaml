<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:controls="using:Cockpit.App.Controls"
             x:Class="Cockpit.App.Controls.ConsentBannerHost"
             x:DataType="vm:SessionPanelViewModel">

    <!-- Hosts the consent banner for a session pane (#AC-47): bound to the pane's PendingConsent, hidden when there
         is none. Included once per pane view (SessionView, TtyView) so the wrapper is not duplicated across them. -->
    <ContentControl Content="{Binding PendingConsent}"
                    IsVisible="{Binding PendingConsent, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ContentControl.ContentTemplate>
            <DataTemplate x:DataType="vm:ConsentPromptViewModel">
                <controls:ConsentBanner/>
            </DataTemplate>
        </ContentControl.ContentTemplate>
    </ContentControl>
</UserControl>
