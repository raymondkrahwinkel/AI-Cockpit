<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:controls="using:Cockpit.App.Controls"
             xmlns:conv="using:Cockpit.App.Converters"
             xmlns:sessions="using:Cockpit.Core.Sessions"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Cockpit.App.Controls.SessionHeaderBar"
             x:DataType="vm:SessionPanelViewModel">

    <!-- AC-37 identity strip, shared by every session kind. AC-103: the right cluster (cwd · branch · token
         meter · usage pill) docks right so its full width is always reserved, and the activity in the left
         fill-Grid is the star that gives way with an ellipsis when the pane is narrow. The earlier single Grid
         put all of it in Auto columns that cannot shrink, so a narrow pane pushed the usage pill past the bar's
         right edge — over the pane's docked live-controls — instead of trimming the activity. -->
    <DockPanel>

        <!-- Right cluster: docked first, so DockPanel reserves its full width before the fill region gets the
             rest; the pill therefore stays fully visible and only the activity column below trims. -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

            <!-- cwd as an icon; profile + full path on hover, freeing the path's width. -->
            <materialIcons:MaterialIcon Kind="FolderOutline" Width="14" Height="14"
                                        VerticalAlignment="Center" Margin="8,0,0,0"
                                        Foreground="{StaticResource CockpitTextFaintBrush}"
                                        IsVisible="{Binding WorkingDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <ToolTip.Tip>
                    <MultiBinding StringFormat="{}{0} · {1}">
                        <Binding Path="ActiveProfileLabel"/>
                        <Binding Path="WorkingDirectory"/>
                    </MultiBinding>
                </ToolTip.Tip>
            </materialIcons:MaterialIcon>

            <!-- Worktree branch chip (AC-85), next to the cwd icon when the session runs in an isolated worktree.
                 Soft purple so it reads apart from the grey kind chip and the green/yellow status colours. -->
            <Border Background="#332B47" VerticalAlignment="Center"
                    CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                    IsVisible="{Binding WorktreeBranch, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    ToolTip.Tip="This session runs in an isolated git worktree on its own branch (AC-85)">
                <TextBlock Text="{Binding WorktreeBranch, StringFormat='⑂ {0}'}" FontSize="10"
                           Foreground="#BCA8E0"/>
            </Border>

            <!-- Branch (plugin-contributed, e.g. git-status): sizes to its own content so it never renders past a
                 fixed cap onto the pill beside it (the badge trims its own long branch names). Hidden on a plain
                 terminal pane (AC-25), where a plugin session indicator has nothing to say; takes no space when
                 none contributes. -->
            <controls:PluginSessionHeaderHost Margin="8,0,0,0"
                                              IsVisible="{Binding ShowPluginHeaderItems}"/>

            <!-- Token/cost meter (#8): the session's running token + cost total. Hidden until usage has accrued,
                 and hidden once the operator puts session usage on the pill itself (AC-105) so the same figure
                 never shows twice — see ShowTokenMeter. -->
            <Border Background="{StaticResource CockpitSecondaryBgBrush}" VerticalAlignment="Center"
                    CornerRadius="{StaticResource CockpitControlRadius}" Padding="5,1" Margin="8,0,0,0"
                    IsVisible="{Binding ShowTokenMeter}" ToolTip.Tip="{Binding UsageTooltip}">
                <TextBlock Text="{Binding UsageSummary}" FontSize="10" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </Border>

            <!-- Usage pill (AC-105): one segmented pill that reads as a whole — a segment per selected metric the
                 session has data for (each coloured by its own severity, amber/red on its threshold), the segments
                 butting together with a thin divider between them, and the chevron glued on as the final segment.
                 Which metrics show is a global Options preference; empty (no space taken) when none applies. -->
            <Border VerticalAlignment="Center" Margin="8,0,0,0" ClipToBounds="True"
                    Background="{StaticResource CockpitSecondaryBgBrush}"
                    BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1" CornerRadius="20"
                    IsVisible="{Binding HasUsagePillRegion}">
                <StackPanel Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding UsagePillItems}" VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:UsagePillItem">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Divider between adjacent segments; the first segment carries none. -->
                                    <Border Width="1" Background="{StaticResource CockpitHairlineBrush}"
                                            IsVisible="{Binding ShowLeadingDivider}"/>
                                    <TextBlock Text="{Binding DisplayText}" FontSize="10" Padding="8,2"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding SeverityBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                                               ToolTip.Tip="{Binding Tooltip}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Chevron as the final segment: opens the detail flyout (ctx plus each rate window with its
                         reset time) — the thing the compact segments cannot say. Its divider shows only when a
                         metric segment precedes it. -->
                    <Border Width="1" Background="{StaticResource CockpitHairlineBrush}"
                            IsVisible="{Binding ShowChevronDivider}"/>
                    <Button VerticalAlignment="Stretch" Padding="6,2"
                            MinWidth="0" MinHeight="0"
                            Background="Transparent" BorderThickness="0"
                            IsVisible="{Binding HasUsagePill}"
                            ToolTip.Tip="{Binding LimitsTooltip}">
                        <materialIcons:MaterialIcon Kind="ChevronDown" Width="12" Height="12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel Spacing="8" MinWidth="210" Margin="4">
                                    <TextBlock Text="Usage" FontWeight="SemiBold" FontSize="11.5"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                    <controls:LimitBar Label="ctx" Percent="{Binding ContextUsedPercent}" FontSize="10" Height="14"
                                                       StretchTrack="True" HorizontalAlignment="Stretch"/>
                                    <ItemsControl ItemsSource="{Binding RateLimits}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="sessions:SessionRateWindow">
                                                <StackPanel Spacing="1" Margin="0,4,0,0">
                                                    <controls:LimitBar Label="{Binding Label}" Percent="{Binding UsedPercent}" FontSize="10" Height="14"
                                                                       StretchTrack="True" HorizontalAlignment="Stretch"/>
                                                    <TextBlock Text="{Binding ResetsAt, Converter={x:Static conv:RateWindowResetConverter.Instance}}"
                                                               FontSize="10" Foreground="{StaticResource CockpitTextFaintBrush}"
                                                               IsVisible="{Binding ResetsAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Left fill region: status dot · name · kind chip · activity. Activity (Col 3, star) is the one that
             trims with an ellipsis when space runs out; the dot, name and kind chip keep their place. -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,*">

            <!-- Status as a colour, not a word: the dot carries running/waiting/done/background at a glance. -->
            <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                     Fill="{Binding SessionStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>

            <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center" Margin="7,0,0,0"
                       TextTrimming="CharacterEllipsis" MaxWidth="220"
                       Foreground="{StaticResource CockpitTextPrimaryBrush}"/>

            <!-- Kind chip (TTY / SDK / provider tag); hidden when the session reports none. Its hover content is a slot
                 (KindChipTooltip) each view fills — the SDK header its connected-tools card, the TTY header its
                 render diagnostics. -->
            <Border Grid.Column="2" Background="{StaticResource CockpitSecondaryBgBrush}" VerticalAlignment="Center"
                    CornerRadius="4" Padding="5,1" Margin="7,0,0,0"
                    IsVisible="{Binding KindLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    ToolTip.Tip="{Binding KindChipTooltip, RelativeSource={RelativeSource AncestorType=controls:SessionHeaderBar}}">
                <TextBlock Text="{Binding KindLabel}" FontSize="10" Foreground="{StaticResource CockpitTextFaintBrush}"/>
            </Border>

            <!-- Activity (flex, truncates): the AC-13 statusline, falling back to the plain session status. -->
            <Panel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock Text="{Binding Statusline}" FontSize="11" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"
                           IsVisible="{Binding Statusline, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding Status}" FontSize="11" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"
                           IsVisible="{Binding Statusline, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
            </Panel>
        </Grid>
    </DockPanel>
</UserControl>
