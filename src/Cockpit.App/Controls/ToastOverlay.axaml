<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:conv="using:Cockpit.App.Converters"
             x:Class="Cockpit.App.Controls.ToastOverlay"
             x:DataType="vm:CockpitViewModel"
             IsHitTestVisible="True"
             Background="Transparent">

    <!-- The toasts (#61), stacked bottom-right. Pulled out of CockpitView so a plugin's modal dialog can show the
         same ones: a toast raised from a dialog used to appear on the window behind it, which is to say nowhere.
         The overlay itself is transparent and only its toasts take the pointer, so it never blocks what is under it. -->
    <ItemsControl ItemsSource="{Binding Toasts}"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Spacing="8" HorizontalAlignment="Right"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ToastViewModel">
                <Border Width="320" Padding="12,10" CornerRadius="{StaticResource CockpitControlRadius}"
                        Background="{StaticResource CockpitPanelBgBrush}" BorderThickness="1"
                        BorderBrush="{Binding BrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Glyph}" FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding BrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                                   Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12.5"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="✕" Classes="Subtle" Padding="4,0" FontSize="11"
                                Foreground="{StaticResource CockpitTextFaintBrush}"
                                Command="{Binding CloseCommand}" ToolTip.Tip="Dismiss"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="{Binding ActionLabel}" Classes="Compact"
                                HorizontalAlignment="Left" Margin="0,6,0,0" IsVisible="{Binding HasAction}"
                                Command="{Binding InvokeActionCommand}"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
