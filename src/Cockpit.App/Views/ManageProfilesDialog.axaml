<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:conv="using:Cockpit.App.Converters"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.ManageProfilesDialog"
        x:DataType="vm:ManageProfilesDialogViewModel"
        Title="Manage profiles"
        Width="860" Height="680" MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:ManageProfilesDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: Remove (with confirmation) on the left, Cancel/Save on the right. Save persists the
             whole edited list; a confirmed Remove persists immediately on its own. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Panel>
                <!-- Normal footer. -->
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsConfirmingRemove}">
                    <Button Grid.Column="0" Content="Remove" Classes="Subtle" HorizontalAlignment="Left"
                            Foreground="{StaticResource CockpitTextSecondaryBrush}"
                            Command="{Binding RemoveProfileCommand}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                        <Button Content="Save" Command="{Binding SaveCommand}" Classes="Accent"/>
                    </StackPanel>
                </Grid>

                <!-- Remove confirmation: replaces the footer until answered; Yes removes and persists now. -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center"
                            IsVisible="{Binding IsConfirmingRemove}">
                    <TextBlock Text="{Binding PendingRemovalLabel, StringFormat='Remove profile ‘{0}’?'}"
                               VerticalAlignment="Center" Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
                    <Button Content="No" Command="{Binding CancelRemoveCommand}"/>
                    <Button Content="Yes, remove" Command="{Binding ConfirmRemoveCommand}" Classes="Accent"/>
                </StackPanel>
            </Panel>
        </Border>

        <Grid ColumnDefinitions="180,*">

            <!-- Profile list + Add. -->
            <DockPanel Grid.Column="0" Background="{StaticResource CockpitSecondaryBgBrush}">
                <Button DockPanel.Dock="Bottom" Content="+ Add profile" Classes="Subtle" Margin="8"
                        HorizontalAlignment="Left" Foreground="{StaticResource CockpitAccentBrush}"
                        Command="{Binding AddProfileCommand}"/>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent" Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditableProfileViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding LoginStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                <TextBlock Text="{Binding DisplayLabel}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Detail: the selected profile's fields + session defaults. -->
            <ScrollViewer Grid.Column="1"
                          IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Margin="16" Spacing="11"
                            DataContext="{Binding SelectedProfile}"
                            x:DataType="vm:EditableProfileViewModel">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Label" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding Label}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Provider (fixed after creation)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}"
                                  DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"
                                  IsEnabled="{Binding CanChooseProvider}"/>
                    </StackPanel>

                    <!-- Claude-CLI provider fields. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="Config directory (CLAUDE_CONFIG_DIR)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Browse" Classes="Compact" Margin="6,0,0,0"
                                    Click="OnBrowseConfigDir"/>
                            <TextBox Text="{Binding ConfigDir}" FontFamily="{StaticResource CockpitMonoFont}"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="Executable (empty = bundled default)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Browse" Classes="Compact" Margin="6,0,0,0"
                                    Click="OnBrowseExecutable"/>
                            <TextBox Text="{Binding ExecutablePath}" FontFamily="{StaticResource CockpitMonoFont}"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Local (Ollama / LM Studio) provider fields. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Server base URL" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding BaseUrl}" FontFamily="{StaticResource CockpitMonoFont}"
                                 PlaceholderText="{Binding BaseUrlPlaceholder}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Model" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Fetch" Classes="Compact" Margin="6,0,0,0"
                                    Command="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).RefreshModelsCommand}"
                                    ToolTip.Tip="List the models installed on this server (/v1/models)"/>
                            <!-- MinimumPrefixLength=0 opens the suggestion list on focus (click) without
                                 typing, so the fetched models are pickable, not just type-to-filter. -->
                            <AutoCompleteBox Text="{Binding Model}" ItemsSource="{Binding AvailableModels}"
                                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                                             FontFamily="{StaticResource CockpitMonoFont}"
                                             PlaceholderText="Click to pick a fetched model, or type an id"/>
                        </DockPanel>
                        <TextBlock Text="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).ModelFetchStatus}"
                                   FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"
                                   IsVisible="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).ModelFetchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLmStudioProvider}">
                        <TextBlock Text="API key (optional, only behind a proxy)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding ApiKey}" PasswordChar="•"/>
                    </StackPanel>

                    <!-- Plugin-registered provider fields (#45): the plugin's own config view (API key,
                         model, base URL, ...) is embedded here instead of a fixed set of controls, since a
                         plugin's config shape is opaque to the host. When the provider plugin is not
                         resolvable (removed/disabled/failed to load), the row goes read-only instead of
                         showing an empty settings region — the profile's stored config is preserved either way. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsPluginProviderMissing}">
                        <TextBlock Text="Provider plugin not installed" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CockpitStatusWaitingBrush}"/>
                        <TextBlock Text="This profile's provider plugin is missing, disabled, or failed to load. Its settings are kept as-is and cannot be edited here until the plugin is available again."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsPluginProvider}" IsEnabled="{Binding !IsPluginProviderMissing}">
                        <TextBlock Text="Provider settings" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                   IsVisible="{Binding !IsPluginProviderMissing}"/>
                        <ContentControl Content="{Binding PluginConfigView.View}" IsVisible="{Binding !IsPluginProviderMissing}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Base system prompt (optional)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding SystemPrompt}" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="64" MaxHeight="140"
                                 PlaceholderText="Sent as the first system message of every conversation"/>
                    </StackPanel>

                    <!-- Only a local provider (Ollama/LM Studio) gates tool calls through the per-call
                         approval prompt (#26) — Claude uses its own permission modes instead, so this
                         toggle is meaningless for it. -->
                    <CheckBox Content="Auto-approve tool calls" IsChecked="{Binding AutoApproveTools}"
                              IsVisible="{Binding IsLocalProvider}"
                              ToolTip.Tip="New sessions under this profile start with 'Allow all tools' already on"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Purpose" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding Purpose}"/>
                    </StackPanel>

                    <!-- Default working directory (AC-130): a per-project profile lands a New session in its project
                         folder without picking one each time. Empty = no default; still editable at session start. -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Default working directory" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Browse" Classes="Compact" Margin="6,0,0,0"
                                    Click="OnBrowseWorkingDirectory"/>
                            <TextBox Text="{Binding DefaultWorkingDirectory}" FontFamily="{StaticResource CockpitMonoFont}"
                                     PlaceholderText="Optional — pre-fills a new session's folder for this profile"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- A memory ceiling for the session CLI. Off unless someone types a number, and the warning is
                         not decoration: a capped session that needs more memory than the cap dies mid-turn. -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Memory ceiling (MB, 0 = none)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <NumericUpDown Value="{Binding MemoryLimitMb}" Minimum="0" Maximum="16384" Increment="256"
                                       FormatString="0" Width="160" HorizontalAlignment="Left"
                                       HorizontalContentAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"
                                   Text="Claude runs on Node, and a long conversation grows past half a gigabyte. A ceiling makes it collect harder rather than grow — but a session that genuinely needs more than the ceiling does not slow down, it dies mid-turn and that turn's work is gone. Leave it at 0 unless you are short of memory. Below 256 MB is ignored: the CLI cannot start a conversation in less."/>
                    </StackPanel>

                    <!-- Delegation (#67): whether another session may hand work to this profile, and what it may
                         be handed. Off by default — delegating spawns a process under this profile's login. -->
                    <StackPanel Spacing="11">
                        <TextBlock Text="DELEGATION" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>

                        <CheckBox Content="Other sessions may delegate work to this profile"
                                  IsChecked="{Binding AllowedAsTarget}"
                                  ToolTip.Tip="Lets a session hand a task to this profile, which then runs it as its own background session"/>

                        <StackPanel Spacing="11" IsVisible="{Binding AllowedAsTarget}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Good for" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <TextBox Text="{Binding DelegationPurpose}"
                                         PlaceholderText="e.g. cheap bulk refactors and summarising — no web access"/>
                                <TextBlock Text="Told to the delegating agent so it picks the right profile for the job."
                                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Only these kinds of work" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <TextBox Text="{Binding AllowedTaskTypes}" PlaceholderText="summarize, refactor  (leave empty to accept anything)"/>
                            </StackPanel>

                            <!-- Without this the policy could only ever say "nowhere": a delegated task may run in a
                                 directory the profile allows, and nothing here could name one — so every delegation
                                 that carried a working directory was refused, whichever directory it was. -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="May work in these directories" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <TextBox Text="{Binding AllowedWorkingDirs}"
                                         AcceptsReturn="True"
                                         MinHeight="60"
                                         TextWrapping="NoWrap"
                                         PlaceholderText="/home/raymond/RiderProjects/Eveworkbench&#x0a;one directory per line"/>
                                <TextBlock Text="A delegated task may only run in these directories, and in what lies under them. Empty means a task may not choose a directory at all — so delegation can never reach an arbitrary part of the disk."
                                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- AC-79: for a local-model delegated session (no human to answer a tool-permission
                                 prompt) the ceiling grades which tool calls run unattended, and the allow-list is the
                                 explicit trust anchor for tools an MCP server does not annotate. Ignored when the
                                 profile's "Auto-Approve tool calls" is on, which already allows everything. -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Tool permission ceiling (delegated, local models)" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding PermissionCeilingChoices}"
                                          SelectedItem="{Binding PermissionCeiling}"
                                          HorizontalAlignment="Left" MinWidth="200"
                                          ToolTip.Tip="How far a delegated local-model session may go without a human: plan/default = read-only tools only, acceptEdits = also non-destructive writes, bypassPermissions = everything. Ignored when 'Auto-Approve tool calls' is on."/>
                                <TextBlock Text="plan / default = read-only only · acceptEdits = also writes · bypassPermissions = everything"
                                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Auto-runnable tools (allow-list)" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <TextBox Text="{Binding AllowedTools}"
                                         AcceptsReturn="True"
                                         MinHeight="60"
                                         TextWrapping="NoWrap"
                                         PlaceholderText="get_current_user&#x0a;one tool name per line"/>
                                <TextBlock Text="Tools a delegated session may run unattended regardless of the ceiling — the explicit trust anchor for tools whose MCP server gives no read-only/destructive hint (those are otherwise blocked). One tool name per line."
                                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Tasks at once" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <NumericUpDown Value="{Binding MaxConcurrentTasks}" Minimum="1" Maximum="8"
                                               Increment="1" FormatString="0" Width="110"
                                               HorizontalContentAlignment="Center"
                                               ToolTip.Tip="How many delegated tasks may run on this profile at the same time — keeps a burst of sub-tasks from eating this provider's usage (or the GPU, for a local model)"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Stop a task after" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <NumericUpDown Value="{Binding DelegationTimeoutMinutes}" Minimum="0" Maximum="240"
                                               Increment="1" FormatString="0" Width="110"
                                               HorizontalContentAlignment="Center"
                                               ToolTip.Tip="Minutes a delegated task may run here before AI-Cockpit stops it. Nobody is watching a delegated session, so a model that loops or waits on something that never comes would otherwise hold this profile's slot indefinitely. 0 = no limit."/>
                                <TextBlock Text="minutes (0 = no limit)" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextFaintBrush}"/>
                            </StackPanel>

                            <CheckBox Content="Tasks on this profile may delegate further"
                                      IsChecked="{Binding MayDelegateFurther}"
                                      ToolTip.Tip="Off by default: without this, a delegated task cannot hand work on again, so a chain of agents cannot start"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Session defaults + login are Claude-CLI concepts; a local provider has no permission
                         mode / thinking budget / login, so this whole block is hidden for those. -->
                    <StackPanel Spacing="11" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="SESSION DEFAULTS" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>
                        <TextBlock Text="Used to launch every new session. Live-switching these mid-session (the per-session dropdowns) is SDK-only — a TTY session only ever uses them as start defaults."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Mode" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).PermissionModes}"
                                          SelectedItem="{Binding SelectedPermissionMode}"
                                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Model" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <AutoCompleteBox ItemsSource="{Binding ClaudeModelSuggestions}" Text="{Binding ClaudeModel}"
                                                 FilterMode="ContainsOrdinal" MinimumPrefixLength="0" IsTextCompletionEnabled="False"
                                                 HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Effort" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).Efforts}"
                                          SelectedItem="{Binding SelectedEffort}"
                                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Login" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center" Height="30">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding LoginStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                    <TextBlock Text="{Binding LoginStatusLabel}" VerticalAlignment="Center"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Session defaults for a plugin provider (Claude and Codex are both plugins now): the provider's
                         own declared start options, rendered generically from its declaration and pre-filled from the
                         profile's saved defaults. The provider-neutral successor to the Claude-CLI block above. -->
                    <StackPanel Spacing="11" IsVisible="{Binding HasPluginOptionDefaults}">
                        <TextBlock Text="SESSION DEFAULTS" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>
                        <TextBlock Text="Pre-selected for every new session under this profile; each can still be changed when a session is started."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <ItemsControl ItemsSource="{Binding PluginOptionDefaults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginTtyOptionSelectionViewModel">
                                    <Grid ColumnDefinitions="120,*" Margin="0,0,0,6">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding ChoiceItems}"
                                                  SelectedValueBinding="{Binding Value}" SelectedValue="{Binding Value, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding Label}"
                                                  IsVisible="{Binding !IsFreeText}" HorizontalAlignment="Stretch"
                                                  PlaceholderText="(default)"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value}" IsVisible="{Binding IsFreeText}"
                                                 PlaceholderText="(default)"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- MCP server pre-selection (AC-130): a project profile can remember exactly which MCP servers
                         a New session ticks, instead of re-toggling them each time. Off = no restriction (every
                         enabled server ticked, future ones included). Hidden entirely when there are no servers. -->
                    <StackPanel Spacing="11" IsVisible="{Binding HasMcpServers}">
                        <TextBlock Text="MCP SERVERS" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>
                        <CheckBox Content="Pre-select MCP servers for this profile"
                                  IsChecked="{Binding RestrictMcpServers}"
                                  ToolTip.Tip="Off: a new session ticks every enabled server (and future ones). On: only the servers ticked below."/>
                        <StackPanel Spacing="4" IsVisible="{Binding RestrictMcpServers}">
                            <TextBlock Text="Ticked servers are pre-selected for every new session under this profile; each can still be changed when a session is started."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{StaticResource CockpitTextFaintBrush}"/>
                            <ItemsControl ItemsSource="{Binding McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:McpServerSelectionItemViewModel">
                                        <!-- name checkbox, plus the server's pre-flight tool-token figure (AC-134) -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <CheckBox Grid.Column="0" Content="{Binding Name}" IsChecked="{Binding IsEnabledForSession}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TokenLabel}" VerticalAlignment="Center"
                                                       Margin="8,0,0,0" FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Pre-flight token estimate for the ticked servers (AC-134), so a profile's pre-selection
                                 shows roughly what it adds; Refresh re-enumerates. -->
                            <DockPanel IsVisible="{Binding HasMcpTokenSummary}" Margin="0,2,0,0">
                                <Button DockPanel.Dock="Right" Content="Refresh" Classes="Subtle" Padding="6,2" FontSize="11"
                                        Command="{Binding RefreshMcpTokensCommand}"
                                        ToolTip.Tip="Re-enumerate the selected servers' tools and recount"/>
                                <TextBlock Text="{Binding McpToolTokenSummary}" VerticalAlignment="Center" FontSize="11"
                                           TextWrapping="Wrap" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Per-profile environment variables (AC-22), injected into every session spawned under this
                         profile. Gated on the provider's SupportsEnvVars capability, so a provider with nothing to
                         inject into (an HTTP model) never shows a dead editor. -->
                    <StackPanel Spacing="11" IsVisible="{Binding SupportsEnvVars}">
                        <TextBlock Text="ENVIRONMENT VARIABLES" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>
                        <TextBlock Text="Injected into every session spawned under this profile, terminal and headless alike. Mark a value as secret to store it encrypted and masked."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <ItemsControl ItemsSource="{Binding EnvironmentVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProfileEnvironmentVariableViewModel">
                                    <Grid ColumnDefinitions="4*,5*,Auto,Auto" RowDefinitions="Auto,Auto"
                                          ColumnSpacing="6" Margin="0,0,0,6">
                                        <TextBox Grid.Column="0" Text="{Binding Key}" PlaceholderText="NAME"
                                                 FontFamily="{StaticResource CockpitMonoFont}"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value}" PlaceholderText="value"
                                                 FontFamily="{StaticResource CockpitMonoFont}"
                                                 IsVisible="{Binding !IsSecret}"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value}" PlaceholderText="value"
                                                 PasswordChar="•" IsVisible="{Binding IsSecret}"/>
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsSecret}" Content="Secret"
                                                  FontSize="11" VerticalAlignment="Center"/>
                                        <Button Grid.Column="3" Classes="Subtle" VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].((vm:EditableProfileViewModel)DataContext).RemoveEnvironmentVariableCommand}"
                                                CommandParameter="{Binding}">
                                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                                        </Button>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2,0,0"
                                                   Text="Not a valid variable name — letters, digits and underscores, not starting with a digit."
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{StaticResource CockpitStatusWaitingBrush}"
                                                   IsVisible="{Binding !IsKeyValid}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add variable" Classes="Subtle" HorizontalAlignment="Left"
                                Foreground="{StaticResource CockpitAccentBrush}"
                                Command="{Binding AddEnvironmentVariableCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
