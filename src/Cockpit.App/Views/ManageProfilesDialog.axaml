<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:conv="using:Cockpit.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.ManageProfilesDialog"
        x:DataType="vm:ManageProfilesDialogViewModel"
        Title="Manage profiles"
        Width="620" Height="420" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:ManageProfilesDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: Remove (with confirmation) on the left, Cancel/Save on the right. Save persists the
             whole edited list; a confirmed Remove persists immediately on its own. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Panel>
                <!-- Normal footer. -->
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsConfirmingRemove}">
                    <Button Grid.Column="0" Content="Remove" Classes="Subtle" HorizontalAlignment="Left"
                            Foreground="{StaticResource CockpitTextSecondaryBrush}"
                            Command="{Binding RemoveProfileCommand}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                        <Button Content="Save" Command="{Binding SaveCommand}" Classes="Accent"/>
                    </StackPanel>
                </Grid>

                <!-- Remove confirmation: replaces the footer until answered; Yes removes and persists now. -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center"
                            IsVisible="{Binding IsConfirmingRemove}">
                    <TextBlock Text="{Binding PendingRemovalLabel, StringFormat='Remove profile ‘{0}’?'}"
                               VerticalAlignment="Center" Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
                    <Button Content="No" Command="{Binding CancelRemoveCommand}"/>
                    <Button Content="Yes, remove" Command="{Binding ConfirmRemoveCommand}" Classes="Accent"/>
                </StackPanel>
            </Panel>
        </Border>

        <Grid ColumnDefinitions="180,*">

            <!-- Profile list + Add. -->
            <DockPanel Grid.Column="0" Background="{StaticResource CockpitSecondaryBgBrush}">
                <Button DockPanel.Dock="Bottom" Content="+ Add profile" Classes="Subtle" Margin="8"
                        HorizontalAlignment="Left" Foreground="{StaticResource CockpitAccentBrush}"
                        Command="{Binding AddProfileCommand}"/>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent" Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditableProfileViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding LoginStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                <TextBlock Text="{Binding DisplayLabel}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Detail: the selected profile's fields + session defaults. -->
            <ScrollViewer Grid.Column="1"
                          IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Margin="16" Spacing="11"
                            DataContext="{Binding SelectedProfile}"
                            x:DataType="vm:EditableProfileViewModel">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Label" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding Label}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Provider (fixed after creation)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}"
                                  DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"
                                  IsEnabled="{Binding CanChooseProvider}"/>
                    </StackPanel>

                    <!-- Claude-CLI provider fields. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="Config directory (CLAUDE_CONFIG_DIR)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Browse" Classes="Compact" Margin="6,0,0,0"
                                    Click="OnBrowseConfigDir"/>
                            <TextBox Text="{Binding ConfigDir}" FontFamily="{StaticResource CockpitMonoFont}"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="Executable (empty = bundled default)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Browse" Classes="Compact" Margin="6,0,0,0"
                                    Click="OnBrowseExecutable"/>
                            <TextBox Text="{Binding ExecutablePath}" FontFamily="{StaticResource CockpitMonoFont}"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Local (Ollama / LM Studio) provider fields. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Server base URL" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding BaseUrl}" FontFamily="{StaticResource CockpitMonoFont}"
                                 PlaceholderText="{Binding BaseUrlPlaceholder}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Model" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Fetch" Classes="Compact" Margin="6,0,0,0"
                                    Command="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).RefreshModelsCommand}"
                                    ToolTip.Tip="List the models installed on this server (/v1/models)"/>
                            <!-- MinimumPrefixLength=0 opens the suggestion list on focus (click) without
                                 typing, so the fetched models are pickable, not just type-to-filter. -->
                            <AutoCompleteBox Text="{Binding Model}" ItemsSource="{Binding AvailableModels}"
                                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                                             FontFamily="{StaticResource CockpitMonoFont}"
                                             PlaceholderText="Click to pick a fetched model, or type an id"/>
                        </DockPanel>
                        <TextBlock Text="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).ModelFetchStatus}"
                                   FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"
                                   IsVisible="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).ModelFetchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLmStudioProvider}">
                        <TextBlock Text="API key (optional, only behind a proxy)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding ApiKey}" PasswordChar="•"/>
                    </StackPanel>

                    <!-- Plugin-registered provider fields (#45): the plugin's own config view (API key,
                         model, base URL, ...) is embedded here instead of a fixed set of controls, since a
                         plugin's config shape is opaque to the host. When the provider plugin is not
                         resolvable (removed/disabled/failed to load), the row goes read-only instead of
                         showing an empty settings region — the profile's stored config is preserved either way. -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsPluginProviderMissing}">
                        <TextBlock Text="Provider plugin not installed" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CockpitStatusWaitingBrush}"/>
                        <TextBlock Text="This profile's provider plugin is missing, disabled, or failed to load. Its settings are kept as-is and cannot be edited here until the plugin is available again."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsPluginProvider}" IsEnabled="{Binding !IsPluginProviderMissing}">
                        <TextBlock Text="Provider settings" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                   IsVisible="{Binding !IsPluginProviderMissing}"/>
                        <ContentControl Content="{Binding PluginConfigView.View}" IsVisible="{Binding !IsPluginProviderMissing}"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding IsLocalProvider}">
                        <TextBlock Text="Base system prompt (optional)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding SystemPrompt}" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="64" MaxHeight="140"
                                 PlaceholderText="Sent as the first system message of every conversation"/>
                    </StackPanel>

                    <!-- Only a local provider (Ollama/LM Studio) gates tool calls through the per-call
                         approval prompt (#26) — Claude uses its own permission modes instead, so this
                         toggle is meaningless for it. -->
                    <CheckBox Content="Auto-approve tool calls" IsChecked="{Binding AutoApproveTools}"
                              IsVisible="{Binding IsLocalProvider}"
                              ToolTip.Tip="New sessions under this profile start with 'Allow all tools' already on"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Purpose" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                        <TextBox Text="{Binding Purpose}"/>
                    </StackPanel>

                    <!-- Session defaults + login are Claude-CLI concepts; a local provider has no permission
                         mode / thinking budget / login, so this whole block is hidden for those. -->
                    <StackPanel Spacing="11" IsVisible="{Binding IsClaudeProvider}">
                        <TextBlock Text="SESSION DEFAULTS" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>
                        <TextBlock Text="Used to launch every new session. Live-switching these mid-session (the per-session dropdowns) is SDK-only — a TTY session only ever uses them as start defaults."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Mode" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).PermissionModes}"
                                          SelectedItem="{Binding SelectedPermissionMode}"
                                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Model" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).Models}"
                                          SelectedItem="{Binding SelectedModel}"
                                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Effort" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:ManageProfilesDialogViewModel)DataContext).Efforts}"
                                          SelectedItem="{Binding SelectedEffort}"
                                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Login" FontSize="11" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center" Height="30">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding LoginStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                    <TextBlock Text="{Binding LoginStatusLabel}" VerticalAlignment="Center"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
