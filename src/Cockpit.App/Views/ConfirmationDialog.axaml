<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.ConfirmationDialog"
        x:DataType="vm:ConfirmationDialogViewModel"
        Title="Confirm"
        Width="440" SizeToContent="Height" CanResize="False"
        MaxHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:ConfirmationDialogViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="OnCancel"/>
                <Button Content="{Binding ConfirmLabel}" Classes="Accent" Click="OnConfirm"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20,18" Spacing="8">
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
            <!-- The message can be a long git error (a failed worktree checkout dumps every file it could not
                 create). Bounded and scrolled so it never grows the window past its owner and pushes the action
                 buttons off-screen; short messages still size to their content. -->
            <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </ScrollViewer>
        </StackPanel>
    </DockPanel>
</Window>
