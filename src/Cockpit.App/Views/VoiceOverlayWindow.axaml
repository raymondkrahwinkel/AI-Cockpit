<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        x:Class="Cockpit.App.Views.VoiceOverlayWindow"
        x:DataType="vm:VoiceOverlayViewModel"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Title="AI-Cockpit voice overlay">
    <!-- Transcription of pill-mockup.html/.png: dark translucent pill, hairline border, Claude-coral
         accent — see the plan (#34) for the mockup source. Listening/Transcribing are mutually
         exclusive rows overlaid in one cell so the window (SizeToContent) always sizes to whichever
         one is showing. -->
    <Border Background="#F01E2128" BorderBrush="#1AFFFFFF" BorderThickness="1"
            CornerRadius="24" Padding="18,12,22,12">
        <Grid>
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsListening}">
                <Border Width="9" Height="9" VerticalAlignment="Center" CornerRadius="4.5"
                        Background="{StaticResource CockpitAccentBrush}"
                        BoxShadow="0 0 0 4 #2ED97757"/>
                <!-- Live microphone waveform (#34b): each bar's height tracks a captured level, newest on
                     the right, so the pill shows sound actually coming in rather than a static graphic.
                     Fixed 20px cell so the pill height never jumps as the bars move. -->
                <ItemsControl ItemsSource="{Binding Bars}" Height="20" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:VoiceOverlayBarViewModel">
                            <Rectangle Width="3" Height="{Binding Height}" RadiusX="2" RadiusY="2"
                                       VerticalAlignment="Bottom" Fill="{StaticResource CockpitAccentBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Listening" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
            </StackPanel>
            <!-- The key is held but nothing is being recorded. Deliberately unlike the other three rows: no
                 waveform and no spinner, because nothing is moving — a flat waveform under "Listening" is
                 exactly what this replaces. The dot is hollow and grey rather than the coral of a live mic. -->
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsUnavailable}">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" StrokeThickness="1.5"
                         Stroke="{StaticResource CockpitTextSecondaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsTranscribing}">
                <Ellipse Width="16" Height="16" VerticalAlignment="Center" StrokeThickness="2"
                         Stroke="{StaticResource CockpitTextSecondaryBrush}" Opacity="0.5"/>
                <TextBlock Text="Transcribing…" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </StackPanel>
            <!-- Read-aloud is playing (#34, Raymond 2026-07-15). No waveform: the playback queue reports that it
                 is speaking, not how loudly, and bars driven by nothing are a meter that measures nothing. A
                 filled coral dot like Listening's — sound is moving — but no glow, because this row yields to
                 any dictation and should not read as the louder of the two. -->
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsSpeaking}">
                <Border Width="9" Height="9" VerticalAlignment="Center" CornerRadius="4.5"
                        Background="{StaticResource CockpitAccentBrush}"/>
                <TextBlock Text="Reading aloud" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
            </StackPanel>
            <!-- First use only: the model (~1.6 GB) and the GPU runtime come down inside the first dictation.
                 Its own row rather than a re-worded Transcribing one — the pill must not claim to transcribe
                 what it has not started, and this row needs a bar the other does not. The bar binds to
                 HasProgress, so a step with no known total (the model stream carries no length) shows its
                 counting text alone instead of a bar parked at a position we made up. -->
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsPreparing}">
                <Ellipse Width="16" Height="16" VerticalAlignment="Center" StrokeThickness="2"
                         Stroke="{StaticResource CockpitAccentBrush}" Opacity="0.6"/>
                <StackPanel Spacing="6" VerticalAlignment="Center" MinWidth="220">
                    <TextBlock Text="{Binding StatusText}" FontSize="15" FontWeight="Medium"
                               Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
                    <ProgressBar IsVisible="{Binding HasProgress}" Value="{Binding ProgressValue}"
                                 Minimum="0" Maximum="1" Height="3" CornerRadius="2"
                                 Foreground="{StaticResource CockpitAccentBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
