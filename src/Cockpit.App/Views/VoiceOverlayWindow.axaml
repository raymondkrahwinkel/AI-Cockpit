<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        x:Class="Cockpit.App.Views.VoiceOverlayWindow"
        x:DataType="vm:VoiceOverlayViewModel"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Title="AI-Cockpit voice overlay">
    <!-- Transcription of pill-mockup.html/.png: dark translucent pill, hairline border, Claude-coral
         accent — see the plan (#34) for the mockup source. Listening/Transcribing are mutually
         exclusive rows overlaid in one cell so the window (SizeToContent) always sizes to whichever
         one is showing. -->
    <Border Background="#F01E2128" BorderBrush="#1AFFFFFF" BorderThickness="1"
            CornerRadius="24" Padding="18,12,22,12">
        <Grid>
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsListening}">
                <Border Width="9" Height="9" VerticalAlignment="Center" CornerRadius="4.5"
                        Background="{StaticResource CockpitAccentBrush}"
                        BoxShadow="0 0 0 4 #2ED97757"/>
                <!-- Live microphone waveform (#34b): each bar's height tracks a captured level, newest on
                     the right, so the pill shows sound actually coming in rather than a static graphic.
                     Fixed 20px cell so the pill height never jumps as the bars move. -->
                <ItemsControl ItemsSource="{Binding Bars}" Height="20" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:VoiceOverlayBarViewModel">
                            <Rectangle Width="3" Height="{Binding Height}" RadiusX="2" RadiusY="2"
                                       VerticalAlignment="Bottom" Fill="{StaticResource CockpitAccentBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Listening" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="13" IsVisible="{Binding IsTranscribing}">
                <Ellipse Width="16" Height="16" VerticalAlignment="Center" StrokeThickness="2"
                         Stroke="{StaticResource CockpitTextSecondaryBrush}" Opacity="0.5"/>
                <TextBlock Text="Transcribing…" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
