<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:conv="using:Cockpit.App.Converters"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.WorktreesDialog"
        x:DataType="vm:WorktreesViewModel"
        Title="Managed worktrees"
        Width="760" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:WorktreesViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="Managed worktrees" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Git worktrees the cockpit created to isolate sessions. A gone one — its session closed or crashed — can be reattached to a fresh session or removed. Removing a tree with unsaved changes always asks first."
                       Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0" Classes="Subtle Compact" HorizontalAlignment="Left" Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <materialIcons:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Classes="Subtle Compact" HorizontalAlignment="Left" Margin="8,0,0,0"
                    Command="{Binding CleanUpFinishedCommand}"
                    IsVisible="{Binding HasWorktrees}"
                    ToolTip.Tip="Removes every worktree that is clean (nothing to lose). Never touches one with unsaved changes.">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <materialIcons:MaterialIcon Kind="Broom" Width="12" Height="12"/>
                    <TextBlock Text="Clean up finished"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Content="Close" Click="OnClose"/>
        </Grid>

        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitPanelRadius}" Padding="4">

            <Panel>
                <TextBlock Text="No worktrees. A session started with &quot;Isolate in a git worktree&quot; will show up here."
                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"
                           TextAlignment="Center" IsVisible="{Binding !HasWorktrees}"/>

                <ScrollViewer IsVisible="{Binding HasWorktrees}">
                    <ItemsControl ItemsSource="{Binding Worktrees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ManagedWorktreeRowViewModel">
                                <Border Padding="10,8" Margin="3,2" CornerRadius="{StaticResource CockpitControlRadius}"
                                        Background="{StaticResource CockpitSecondaryBgBrush}">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <!-- Status dot + branch chip: at a glance clean vs. work-to-lose. -->
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                         Fill="{Binding StatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                                <TextBlock Text="{Binding Branch, StringFormat='⑂ {0}'}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource CockpitTextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Border CornerRadius="4" Padding="5,1" VerticalAlignment="Center"
                                                        Background="{StaticResource CockpitSecondaryBgBrush}">
                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                                               Foreground="{Binding StatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                                </Border>
                                                <TextBlock Text="{Binding OwnerLabel}" FontSize="10" VerticalAlignment="Center"
                                                           Foreground="{Binding OwnerBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="16,0,0,0">
                                                <TextBlock Text="{Binding RepositoryName}" FontSize="11"
                                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding WorktreePath}" FontSize="11"
                                                           Foreground="{StaticResource CockpitTextFaintBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <!-- Look at the files yourself in the OS file manager (read-only, always available). -->
                                            <Button Classes="Subtle Compact" Content="Open folder"
                                                    ToolTip.Tip="Open the worktree folder in your file manager"
                                                    Click="OnOpenFolder"/>
                                            <!-- Reattach only when the owning session is gone (Raymond: GONE only); a live tree
                                                 disables it so two sessions never land on one working tree. -->
                                            <Button Classes="Subtle Compact" Content="Reattach"
                                                    IsEnabled="{Binding CanReattach}"
                                                    ToolTip.ShowOnDisabled="True"
                                                    ToolTip.Tip="Start a new session in this worktree. Only for a worktree whose session is gone."
                                                    Command="{Binding ((vm:WorktreesViewModel)DataContext).ReattachCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="Subtle Compact" Content="Remove"
                                                    IsEnabled="{Binding CanRemove}"
                                                    ToolTip.ShowOnDisabled="True"
                                                    ToolTip.Tip="Remove this worktree (asks to confirm; a tree with unsaved changes warns first). Disabled while a session is still using it — close the session first."
                                                    Command="{Binding ((vm:WorktreesViewModel)DataContext).RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </Border>
    </DockPanel>
</Window>
