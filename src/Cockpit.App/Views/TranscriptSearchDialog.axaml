<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:tr="using:Cockpit.Core.Transcripts"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.TranscriptSearchDialog"
        x:DataType="vm:TranscriptSearchDialogViewModel"
        Title="Search transcripts"
        Width="820" Height="600" MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:TranscriptSearchDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: status on the left, Close on the right. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <Button Grid.Column="1" Content="Close" Command="{Binding CloseCommand}"/>
            </Grid>
        </Border>

        <!-- Search bar: type a query and press Enter or Search. -->
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,12">
                <TextBox x:Name="QueryBox" Text="{Binding Query}" Width="480"
                         PlaceholderText="Search across all your past sessions…" KeyDown="OnQueryKeyDown"/>
                <Button Content="Search" Classes="Accent" Command="{Binding SearchCommand}"/>
            </StackPanel>
        </Border>

        <!-- Results: one row per matching line, newest sessions first. -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Results}" Margin="12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="tr:TranscriptSearchHit">
                        <Border Background="{StaticResource CockpitSecondaryBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource CockpitControlRadius}" Margin="0,0,0,8" Padding="12">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{StaticResource CockpitPanelBgBrush}" CornerRadius="3" Padding="5,1">
                                        <TextBlock Text="{Binding Role}" FontSize="10"
                                                   Foreground="{StaticResource CockpitAccentBrush}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Project}" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                               MaxWidth="360" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ModifiedUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm} UTC'}"
                                               FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Snippet}" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CockpitTextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SessionId}" FontFamily="{StaticResource CockpitMonoFont}"
                                               FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                    <Button Content="Copy id" Classes="Compact" Tag="{Binding SessionId}" Click="OnCopySessionId"
                                            ToolTip.Tip="Copy the session id — resume it with 'claude --resume &lt;id&gt;'"/>
                                    <Button Content="Reveal" Classes="Compact" Tag="{Binding FilePath}" Click="OnRevealFile"
                                            ToolTip.Tip="Open the transcript's folder"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
