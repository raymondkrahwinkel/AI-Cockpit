<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:Cockpit.App.Controls"
             xmlns:conv="using:Cockpit.App.Converters"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:term="using:Exclr8.Terminal"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.TtyView"
             x:DataType="vm:TtyViewModel">

    <Design.DataContext>
        <vm:TtyViewModel/>
    </Design.DataContext>

    <!-- The pane is a Grid so the consent overlay (last child) can dim and cover the whole session. -->
    <Grid>
    <DockPanel Margin="6,6,6,8">

        <!-- Compact one-row session header: the session data (TTY tag with render diagnostics on hover,
             status, profile, working directory, read-aloud/redraw) is left-aligned; the session title is
             docked right. Always top-docked, including the stacked-vertical grid layout (#54). -->
        <Border x:Name="HeaderPanel" DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="8,4" Margin="0,0,0,6">
            <DockPanel>
                <!-- Controls dock right and stay on the bar (AC-37): read-aloud + the debug redraw. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0,0,0">
                    <!-- Read-aloud (#35b): tails the live JSONL transcript for assistant text; a speaker, struck through when off (#73). -->
                    <ToggleButton IsChecked="{Binding ReadResponsesAloud}" Classes="Compact" VerticalAlignment="Center"
                                  IsVisible="{Binding !IsTerminal}"
                                  ToolTip.Tip="{Binding ReadResponsesAloud, Converter={x:Static conv:ReadAloudIconConverter.Tip}}">
                        <materialIcons:MaterialIcon Kind="{Binding ReadResponsesAloud, Converter={x:Static conv:ReadAloudIconConverter.Icon}}" Width="14" Height="14"/>
                    </ToggleButton>
                    <!-- Redraw is a diagnostic, not part of the work: shown only with the debug controls on (#73). -->
                    <Button Content="Redraw" Click="OnRedrawClick" Classes="Compact" VerticalAlignment="Center"
                            IsVisible="{Binding ShowDebugControls}"
                            ToolTip.Tip="Force the terminal to repaint from scratch — recovers the TUI if a resize/focus change left it misaligned or stacked at the top"/>
                </StackPanel>

                <!-- The one shared header strip (AC-37): dot · name · kind chip · activity · cwd · branch · token
                     meter · usage pill — SessionHeaderBar, the same control the SDK header uses. The controls above
                     dock right. The kind chip's hover is this view's own render diagnostics. -->
                <controls:SessionHeaderBar VerticalAlignment="Center">
                    <controls:SessionHeaderBar.KindChipTooltip>
                        <TextBlock Text="{Binding Diagnostics}" MaxWidth="440" TextWrapping="Wrap" FontSize="11"/>
                    </controls:SessionHeaderBar.KindChipTooltip>
                </controls:SessionHeaderBar>
            </DockPanel>
        </Border>

        <!-- AC-230: the usage warning — raised once when a signal passes the point its provider called worth
             mentioning (a context window filling, an allowance nearly spent), and dismissible. Same shape as the
             agent bar below it, in the amber the pill uses at the same threshold, so one language says "watch
             this" wherever it appears. -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6" Padding="8,4"
                IsVisible="{Binding HasUsageWarning}"
                Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitStatusWaitingBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Dismiss" Classes="Compact"
                        Command="{Binding DismissUsageWarningCommand}" VerticalAlignment="Center"
                        ToolTip.Tip="Hide this warning. It comes back if the figure drops and climbs past the threshold again."/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="GaugeFull" Width="15" Height="15"
                                                Foreground="{StaticResource CockpitStatusWaitingBrush}"/>
                    <TextBlock Text="{Binding UsageWarning}" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource CockpitStatusWaitingBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- AC-34: the "agent connected" bar — always visible while an agent is coupled to this pane through the
             terminal-access MCP, the counterpart to both the operator and the agent being able to type. Its
             Disconnect is the reactive kill-switch: it interrupts a running command and breaks the coupling at once. -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6" Padding="8,4"
                IsVisible="{Binding AgentConnected}"
                Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitAccentBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Disconnect" Classes="Compact" Click="OnAgentDisconnect"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Stop the agent driving this terminal: interrupt whatever it is running (Ctrl-C) and break the connection immediately."/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="RobotOutline" Width="15" Height="15"
                                                Foreground="{StaticResource CockpitAccentBrush}"/>
                    <TextBlock Text="{Binding AgentConnectedLabel}" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource CockpitAccentBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- The terminal surface: Exclr8.Terminal, a pure Avalonia terminal-emulator renderer with no
             PTY plumbing of its own. The code-behind hosts the ConPTY/Porta.Pty process, feeds pty
             output in via Write(...), forwards the control's Input/Output byte events to the pty, and
             relays Resized to the pty. -->
        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="4"
                Background="Black">
            <!-- TerminalControl.FontFamily/FontSize are plain CLR properties (not registered
                 AvaloniaProperties), so Avalonia's compiled-binding XAML compiler can't target them
                 directly (AVLN3000) — the code-behind applies the VM's font settings imperatively
                 instead (#40), the same "code-behind owns the terminal plumbing" pattern already used
                 for Input/Output/Resized below. Default mirrors the old hardcoded fallback list:
                 "Cascadia Mono" is Windows-only, so without the monospace fallback the terminal dropped
                 to the proportional UI font on Linux/macOS, which put a phantom gap between the text and
                 the block cursor. -->
            <term:TerminalControl x:Name="Terminal" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13"/>
        </Border>
    </DockPanel>

    <!-- Consent overlay (#AC-47): dims the whole pane and centres the Approve/Deny card when a request
         is waiting on this session, so it plainly takes over rather than a banner that shifted the TUI
         and was easy to miss. Collapsed and hit-transparent while idle. -->
    <controls:ConsentBannerHost/>
    </Grid>
</UserControl>
