<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.ClaudeSessionView"
             x:DataType="vm:ClaudeSessionViewModel">

    <Design.DataContext>
        <vm:ClaudeSessionViewModel/>
    </Design.DataContext>

    <DockPanel Margin="8">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Start session" Command="{Binding StartCommand}"/>
            <Button Content="Stop" Command="{Binding StopCommand}"
                    ToolTip.Tip="Onderbreekt de lopende turn (control_request/interrupt)"/>
            <ComboBox ItemsSource="{Binding PermissionModes}" SelectedItem="{Binding SelectedPermissionMode}"
                      DisplayMemberBinding="{Binding Label}" MinWidth="150"
                      ToolTip.Tip="Permission-mode voor deze sessie (live wisselbaar)"/>
            <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                      DisplayMemberBinding="{Binding Label}" MinWidth="120"
                      ToolTip.Tip="Model voor deze sessie (--model bij start, live wisselbaar)"/>
            <ComboBox ItemsSource="{Binding Efforts}" SelectedItem="{Binding SelectedEffort}"
                      DisplayMemberBinding="{Binding Label}" MinWidth="100"
                      ToolTip.Tip="Thinking-effort (ongeverifieerde mapping naar thinking-budget)"/>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ActiveProfileLabel, StringFormat='· {0}'}" VerticalAlignment="Center"
                       IsVisible="{Binding ActiveProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8"
                    IsVisible="{Binding IsChoosingProfile}">
            <TextBlock Text="Profile:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding ProfileChoices}" SelectedItem="{Binding SelectedProfile}"
                      DisplayMemberBinding="{Binding Label}" Width="200"/>
            <Button Content="Use profile" Command="{Binding ConfirmProfileChoiceCommand}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="InputBox" Text="{Binding InputText}"
                     PlaceholderText="Message Claude...  (Enter = versturen, Shift+Enter = nieuwe regel)" Width="600"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120" VerticalContentAlignment="Top"/>
            <Button Content="Send" Command="{Binding SendCommand}" IsEnabled="{Binding !IsBusy}"/>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Transcript}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TranscriptEntryViewModel">
                        <Border Padding="6" Margin="0,2" CornerRadius="4"
                                Background="#22FFFFFF">
                            <StackPanel Spacing="4">

                                <!-- Thinking rows: dimmed, collapsed to a toggle by default so they read as
                                     reasoning-in-the-background rather than part of the visible transcript flow. -->
                                <StackPanel IsVisible="{Binding IsThinking}" Spacing="4">
                                    <Button Content="Thinking..." Command="{Binding ToggleExpandedCommand}"
                                            Opacity="0.6" FontStyle="Italic" Padding="2" Background="Transparent"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                               Opacity="0.6" FontStyle="Italic"
                                               IsVisible="{Binding IsExpanded}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           IsVisible="{Binding IsPlainText}"/>

                                <!-- Tool results: collapsed by default; expand on demand. -->
                                <StackPanel IsVisible="{Binding IsToolResult}" Spacing="4">
                                    <Button Content="▸ Tool result (klik om te tonen)" Command="{Binding ToggleExpandedCommand}"
                                            Opacity="0.7" Padding="2" Background="Transparent" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Opacity="0.85"
                                               IsVisible="{Binding IsExpanded}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding IsPendingPermission}">
                                    <Button Content="Allow" Command="{Binding AllowCommand}"/>
                                    <Button Content="Always (exact)" Command="{Binding AllowAlwaysExactCommand}"/>
                                    <Button Content="Always (wildcard)" Command="{Binding AllowAlwaysWildcardCommand}"/>
                                    <Button Content="Deny" Command="{Binding DenyCommand}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding PermissionDecision}"
                                           FontStyle="Italic"
                                           IsVisible="{Binding PermissionDecision, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
