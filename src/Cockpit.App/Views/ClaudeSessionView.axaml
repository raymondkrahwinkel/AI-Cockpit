<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.ClaudeSessionView"
             x:DataType="vm:ClaudeSessionViewModel">

    <Design.DataContext>
        <vm:ClaudeSessionViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Session name above the panel (L5): the dialog's optional name, else "Claude N". -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                   Margin="2,0,0,6"/>

        <!-- Top bar: the session was started from the New-session dialog (#31), so there is no Start
             button — only Stop plus the live mode/model/effort selectors. They share one compact height
             and surface so they read as one aligned row. Status sits inline to save a row. -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitPanelRadius}" Padding="10,7" Margin="0,0,0,8">
            <StackPanel Spacing="6">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Stop" Command="{Binding StopCommand}" Classes="Compact"
                            VerticalAlignment="Center" Margin="0,0,6,4"
                            ToolTip.Tip="Interrupts the running turn (control_request/interrupt)"/>
                    <ComboBox ItemsSource="{Binding PermissionModes}" SelectedItem="{Binding SelectedPermissionMode}"
                              DisplayMemberBinding="{Binding Label}" Classes="Compact" MinWidth="104"
                              VerticalAlignment="Center" Margin="0,0,6,4"
                              IsEnabled="{Binding !IsPermissionModeLocked}" ToolTip.ShowOnDisabled="True"
                              ToolTip.Tip="Permission mode for this session (live-switchable; bypass is locked once the session is launched in it)"/>
                    <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                              DisplayMemberBinding="{Binding Label}" Classes="Compact" MinWidth="90"
                              VerticalAlignment="Center" Margin="0,0,6,4"
                              ToolTip.Tip="Model for this session (--model at launch, live-switchable)"/>
                    <ComboBox ItemsSource="{Binding Efforts}" SelectedItem="{Binding SelectedEffort}"
                              DisplayMemberBinding="{Binding Label}" Classes="Compact" MinWidth="90"
                              VerticalAlignment="Center" Margin="0,0,0,4"
                              ToolTip.Tip="Thinking effort — the live thinking-token budget (set_max_thinking_tokens)"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ActiveProfileLabel, StringFormat='· {0}'}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource CockpitTextFaintBrush}"
                               IsVisible="{Binding ActiveProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Input bar: pending-attachment chips on top, then dark multiline textbox + accent Send. -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="True">

            <!-- Pasted-image chips: removable thumbnail + x. Hidden when there are no attachments. -->
            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding PendingAttachments}" Margin="0,0,0,8"
                          IsVisible="{Binding HasPendingAttachments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ImageAttachmentViewModel">
                        <Border Background="{StaticResource CockpitPanelBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource CockpitControlRadius}"
                                Padding="4" Margin="0,0,6,6">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Source="{Binding Thumbnail}" Height="44" MaxWidth="72" Stretch="Uniform"/>
                                <Button Content="✕" Command="{Binding RemoveCommand}" Classes="Subtle"
                                        VerticalAlignment="Top" Padding="4,0"
                                        ToolTip.Tip="Remove image"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button DockPanel.Dock="Right" Content="Send" Command="{Binding SendCommand}" IsEnabled="{Binding !IsBusy}"
                    Classes="Accent" VerticalAlignment="Bottom" Margin="8,0,0,0"/>
            <TextBox x:Name="InputBox" Text="{Binding InputText}"
                     PlaceholderText="Message Claude...  (Enter = send, Shift+Enter = new line, Ctrl+V = paste text or image)"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120" VerticalContentAlignment="Top"/>
        </DockPanel>

        <Grid>
        <!-- Empty-state hint fills the transcript area until the first row arrives, so a fresh session
             is a calm prompt rather than a black void (L6). -->
        <TextBlock Text="Ready — type a message below to start." IsVisible="{Binding !HasTranscript}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
        <ScrollViewer x:Name="TranscriptScroll" IsVisible="{Binding HasTranscript}">
            <ItemsControl ItemsSource="{Binding Transcript}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TranscriptEntryViewModel">
                        <Border Padding="8,5" Margin="0,2" CornerRadius="{StaticResource CockpitControlRadius}"
                                Background="{StaticResource CockpitPanelBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                            <StackPanel Spacing="4">

                                <!-- Thinking rows: dimmed, collapsed to a toggle by default so they read as
                                     reasoning-in-the-background rather than part of the visible transcript flow. -->
                                <StackPanel IsVisible="{Binding IsThinking}" Spacing="4">
                                    <Button Content="Thinking..." Command="{Binding ToggleExpandedCommand}"
                                            Classes="Subtle toolRow" FontStyle="Italic"
                                            Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                               Classes="transcript"
                                               FontStyle="Italic"
                                               Foreground="{StaticResource CockpitTextFaintBrush}"
                                               IsVisible="{Binding IsExpanded}"/>
                                </StackPanel>

                                <!-- User rows ("> ...") are muted so they read as the user's own line, not assistant output.
                                     No local Foreground here — the "userRow" style class (Theme.axaml) needs to be able
                                     to override the default TextBlock foreground, and a local value always wins over styles. -->
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           Classes="transcript"
                                           IsVisible="{Binding IsPlainText}"
                                           Classes.userRow="{Binding IsUserRow}"/>

                                <!-- Tool-use rows: the call line, plus its coupled result as an expandable
                                     section beneath it (L14 — matched on tool_use_id), so a result stays
                                     attached to the call it belongs to instead of drifting to a loose row. -->
                                <StackPanel IsVisible="{Binding IsToolUse}" Spacing="4">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                               Classes="toolBody"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                    <StackPanel IsVisible="{Binding HasResult}" Spacing="4">
                                        <Button Content="{Binding ResultToggleGlyph}"
                                                Command="{Binding ToggleExpandedCommand}"
                                                Classes="Subtle toolRow" HorizontalAlignment="Left"
                                                Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                        <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap"
                                                   Classes="toolBody"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                                   IsVisible="{Binding IsExpanded}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Standalone (orphan) tool results: collapsed by default; expand via chevron. -->
                                <StackPanel IsVisible="{Binding IsToolResult}" Spacing="4">
                                    <Button Content="{Binding ToggleGlyph}"
                                            Command="{Binding ToggleExpandedCommand}"
                                            Classes="Subtle toolRow" HorizontalAlignment="Left"
                                            Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                               Classes="toolBody"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                               IsVisible="{Binding IsExpanded}"/>
                                </StackPanel>

                                <!-- Bind to the parent session view model's commands (not the row's), passing
                                     the row as the parameter, so allow/deny/always actually resolve the
                                     session's pending decision and persist the always-allow rule. Compact
                                     row: Allow gets the accent, the rest stay quiet and wrap if narrow. -->
                                <WrapPanel Orientation="Horizontal"
                                           IsVisible="{Binding IsPendingPermission}">
                                    <Button Content="Allow" Classes="Accent Compact" Margin="0,4,6,0"
                                            Command="{Binding $parent[ItemsControl].((vm:ClaudeSessionViewModel)DataContext).AllowToolCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Deny" Classes="Compact" Margin="0,4,6,0"
                                            Command="{Binding $parent[ItemsControl].((vm:ClaudeSessionViewModel)DataContext).DenyToolCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Always (exact)" Classes="Compact" Margin="0,4,6,0"
                                            Command="{Binding $parent[ItemsControl].((vm:ClaudeSessionViewModel)DataContext).AllowAlwaysExactToolCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Always (wildcard)" Classes="Compact" Margin="0,4,0,0"
                                            Command="{Binding $parent[ItemsControl].((vm:ClaudeSessionViewModel)DataContext).AllowAlwaysWildcardToolCommand}"
                                            CommandParameter="{Binding}"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding PermissionDecision}"
                                           FontStyle="Italic" FontSize="11"
                                           Foreground="{StaticResource CockpitTextFaintBrush}"
                                           IsVisible="{Binding PermissionDecision, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Scroll-to-bottom affordance: shown only when scrolled up (#21), jumps back to the newest
             row and resumes following. On top of the transcript (last Grid child), bottom-right. -->
        <Button x:Name="ScrollToBottomButton" Content="↓" IsVisible="False"
                Classes="Accent" Click="_OnScrollToBottomClick"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Width="32" Height="32" Padding="0" Margin="0,0,10,10"
                FontSize="15" CornerRadius="16"
                ToolTip.Tip="Jump to the newest message"/>
        </Grid>

    </DockPanel>
</UserControl>
