<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:term="using:SvcSystems.UI.Terminal"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.ClaudeTtyView"
             x:DataType="vm:ClaudeTtyViewModel"
             Background="{StaticResource CockpitWindowBgBrush}">

    <Design.DataContext>
        <vm:ClaudeTtyViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">

        <!-- Top bar: Start (launches the real TUI) + status. TTY mode has no per-session model/mode
             dropdowns — those are SDK-mode controls; the real TUI carries its own in-terminal UI. -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitPanelRadius}" Padding="12,10" Margin="0,0,0,10">
            <StackPanel Spacing="8">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Start TUI" Command="{Binding StartCommand}" Classes="Accent" Margin="0,0,6,4"
                            IsEnabled="{Binding !IsLaunched}"
                            ToolTip.Tip="Start de echte interactieve claude-TUI in dit paneel (experiment)"/>
                    <Border Background="{StaticResource CockpitSecondaryBgBrush}"
                            CornerRadius="{StaticResource CockpitControlRadius}" Padding="6,2" Margin="0,0,6,4"
                            VerticalAlignment="Center">
                        <TextBlock Text="TTY (experiment)" FontSize="11"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                    </Border>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ActiveProfileLabel, StringFormat='· {0}'}" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextFaintBrush}"
                               IsVisible="{Binding ActiveProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Profile picker (shown only when >1 logged-in profile requires a choice). -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitPanelRadius}" Padding="12,10" Margin="0,0,0,10"
                IsVisible="{Binding IsChoosingProfile}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center" Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <ComboBox ItemsSource="{Binding ProfileChoices}" SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberBinding="{Binding Label}" Width="200"/>
                <Button Content="Use profile" Command="{Binding ConfirmProfileChoiceCommand}" Classes="Accent"/>
            </StackPanel>
        </Border>

        <!-- The terminal surface: a pure XTerm.NET renderer. The code-behind hosts the ConPTY and
             pumps output into its Model, forwards keystrokes, and relays resizes. -->
        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="4"
                Background="Black">
            <term:TerminalControl x:Name="Terminal" FontFamily="Cascadia Mono" FontSize="13"/>
        </Border>
    </DockPanel>
</UserControl>
