<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:term="using:Exclr8.Terminal"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.ClaudeTtyView"
             x:DataType="vm:ClaudeTtyViewModel">

    <Design.DataContext>
        <vm:ClaudeTtyViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">

        <!-- Compact session header (#54 look&feel): a title line, then ONE tight row with the TTY tag
             (hover = render diagnostics), status, profile, the working directory (ellipsised, full path on
             hover) and the read-aloud/redraw controls — down from the old three-row badge+status stack.
             HeaderPanel + StatusRow keep their names: the code-behind's _ApplyHeaderLayout flips their
             Dock/Orientation between the normal (top, horizontal) and stacked-vertical (left, vertical)
             layouts. -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                   Margin="2,0,0,4"/>

        <Border x:Name="HeaderPanel" DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="8,4" Margin="0,0,0,6">
            <StackPanel x:Name="StatusRow" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Background="{StaticResource CockpitSecondaryBgBrush}" VerticalAlignment="Center"
                        CornerRadius="{StaticResource CockpitControlRadius}" Padding="5,1"
                        ToolTip.Tip="{Binding Diagnostics}">
                    <TextBlock Text="TTY" FontSize="10" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                </Border>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <TextBlock Text="{Binding ActiveProfileLabel, StringFormat='· {0}'}" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource CockpitTextFaintBrush}"
                           IsVisible="{Binding ActiveProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <!-- Working directory the TUI runs in (#: header working-path). Ellipsised so a deep path
                     never stretches the header; the full path is on hover. -->
                <TextBlock Text="{Binding WorkingPath}" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource CockpitTextFaintBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="300"
                           ToolTip.Tip="{Binding WorkingPath}"/>
                <!-- Read-aloud (#35b): tails the live JSONL session transcript for assistant text. -->
                <ToggleButton Content="Read aloud" IsChecked="{Binding ReadResponsesAloud}" Classes="Compact"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Read each assistant reply aloud by tailing the session transcript (voice model downloads on first use)"/>
                <Button Content="Redraw" Click="OnRedrawClick" Classes="Compact" VerticalAlignment="Center"
                        ToolTip.Tip="Force the terminal to repaint from scratch — recovers the TUI if a resize/focus change left it misaligned or stacked at the top"/>
            </StackPanel>
        </Border>

        <!-- The terminal surface: Exclr8.Terminal, a pure Avalonia terminal-emulator renderer with no
             PTY plumbing of its own. The code-behind hosts the ConPTY/Porta.Pty process, feeds pty
             output in via Write(...), forwards the control's Input/Output byte events to the pty, and
             relays Resized to the pty. -->
        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="4"
                Background="Black">
            <!-- TerminalControl.FontFamily/FontSize are plain CLR properties (not registered
                 AvaloniaProperties), so Avalonia's compiled-binding XAML compiler can't target them
                 directly (AVLN3000) — the code-behind applies the VM's font settings imperatively
                 instead (#40), the same "code-behind owns the terminal plumbing" pattern already used
                 for Input/Output/Resized below. Default mirrors the old hardcoded fallback list:
                 "Cascadia Mono" is Windows-only, so without the monospace fallback the terminal dropped
                 to the proportional UI font on Linux/macOS, which put a phantom gap between the text and
                 the block cursor. -->
            <term:TerminalControl x:Name="Terminal" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13"/>
        </Border>
    </DockPanel>
</UserControl>
