<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:term="using:Exclr8.Terminal"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Cockpit.App.Views.ClaudeTtyView"
             x:DataType="vm:ClaudeTtyViewModel">

    <Design.DataContext>
        <vm:ClaudeTtyViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">

        <!-- Session name above the panel (L5): the dialog's optional name, else "Claude N". -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                   Margin="2,0,0,8"/>

        <!-- Top bar: an experiment badge + status. The session was launched from the New-session dialog
             (#31), so there is no Start button here; TTY mode has no per-session model/mode dropdowns
             either — those are SDK-mode controls, and the real TUI carries its own in-terminal UI. -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitPanelRadius}" Padding="12,10" Margin="0,0,0,10">
            <StackPanel Spacing="8">
                <Border Background="{StaticResource CockpitSecondaryBgBrush}" HorizontalAlignment="Left"
                        CornerRadius="{StaticResource CockpitControlRadius}" Padding="6,2">
                    <TextBlock Text="TTY (experiment)" FontSize="11"
                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ActiveProfileLabel, StringFormat='· {0}'}" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextFaintBrush}"
                               IsVisible="{Binding ActiveProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- The terminal surface: Exclr8.Terminal, a pure Avalonia terminal-emulator renderer with no
             PTY plumbing of its own. The code-behind hosts the ConPTY/Porta.Pty process, feeds pty
             output in via Write(...), forwards the control's Input/Output byte events to the pty, and
             relays Resized to the pty. -->
        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CockpitControlRadius}" Padding="4"
                Background="Black">
            <!-- TerminalControl.FontFamily is a plain string (resolved via Avalonia's FontManager, so
                 comma-fallback applies) — not an Avalonia FontFamily, so it can't bind the CockpitMonoFont
                 resource. Keep the same fallback list: "Cascadia Mono" is Windows-only, so without the
                 monospace fallback the terminal dropped to the proportional UI font on Linux/macOS, which
                 put a phantom gap between the text and the block cursor. -->
            <term:TerminalControl x:Name="Terminal" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13"/>
        </Border>
    </DockPanel>
</UserControl>
