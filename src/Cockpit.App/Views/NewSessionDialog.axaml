<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:conv="using:Cockpit.App.Converters"
        xmlns:profiles="using:Cockpit.Core.Profiles"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.NewSessionDialog"
        x:DataType="vm:NewSessionDialogViewModel"
        Title="{Binding HeaderText}"
        Width="480" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:NewSessionDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: login status of the chosen profile on the left, Cancel/Start on the right. Start
             is disabled unless the profile is logged in (CanStart), so it never launches into a failure. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <!-- Login status is Claude-only — a local provider has no login. -->
                    <Ellipse Width="8" Height="8" IsVisible="{Binding IsClaudeProfile}"
                             Fill="{Binding LoginStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                    <TextBlock Text="{Binding LoginStatusLabel}" FontSize="12" VerticalAlignment="Center"
                               IsVisible="{Binding IsClaudeProfile}"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    <Button Content="Manage profiles" Classes="Subtle" FontSize="12" VerticalAlignment="Center"
                            Command="{Binding ManageProfilesCommand}"
                            Foreground="{StaticResource CockpitAccentBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                    <!-- IsDefault: Enter starts the session (fires ConfirmCommand), but only when it's
                         enabled — CanStart gates it, so Enter never launches into a failure. -->
                    <Button Content="Start" Command="{Binding ConfirmCommand}" Classes="Accent" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: session kind first (SDK vs TTY — #32, replaces the old two-sidebar-button choice),
             then the profile picker (with its config directory shown), then the start mode/model/effort —
             initialised from the profile's saved defaults, still overridable. Mode/model/effort are shown
             for both kinds: TTY passes these as launch-only CLI flags, the real TUI owns any live
             switching. SelectedKind/IsSdk/IsTty is the seam for showing/hiding kind-specific fields later. -->
        <StackPanel Margin="16" Spacing="12">

            <!-- Profile first: its provider decides which of the options below apply (#26). The picker shows
                 the provider (and local model) after the label, e.g. "default (Claude CLI)". -->
            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Profile" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <StackPanel Grid.Column="1" Spacing="3">
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="profiles:SessionProfile">
                                <TextBlock Text="{Binding ., Converter={x:Static conv:ProfileDisplayConverter.Instance}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding SelectedProfileConfigDir}" FontFamily="{StaticResource CockpitMonoFont}"
                               FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"
                               IsVisible="{Binding SelectedProfileConfigDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="Not logged in — run 'claude /login' in a terminal for this profile first."
                               FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                               Foreground="{StaticResource CockpitStatusWaitingBrush}"
                               IsVisible="{Binding ShowLoginHint}"/>
                </StackPanel>
            </Grid>

            <!-- Session name is provider-independent, so it is always shown. -->
            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding SessionName}"
                         PlaceholderText="Optional — defaults to the profile name"/>
            </Grid>

            <!-- Optional per-session working directory: launch this session in a project folder instead of the
                 app directory. Browse picks one; the ★ pins the current one; the picker offers previously-used
                 folders (favorites first). Blank keeps the global default. -->
            <Grid ColumnDefinitions="72,*" VerticalAlignment="Top">
                <TextBlock Grid.Column="0" Text="Folder" VerticalAlignment="Center" Margin="0,4,0,0" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0" Text="{Binding WorkingDirectory}"
                                 PlaceholderText="Optional — defaults to the app directory"/>
                        <Button Grid.Column="1" Content="{Binding FavoriteToggleGlyph}" Margin="4,0,0,0"
                                Command="{Binding ToggleWorkingDirectoryFavoriteCommand}"
                                IsEnabled="{Binding CanFavoriteWorkingDirectory}"
                                Foreground="{StaticResource CockpitAccentBrush}"
                                ToolTip.Tip="Pin this folder as a favorite"/>
                        <Button Grid.Column="2" Content="Browse…" Margin="4,0,0,0" Click="OnBrowseWorkingDirectory"/>
                    </Grid>
                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding RememberedPaths}"
                              SelectedItem="{Binding SelectedRememberedPath}"
                              PlaceholderText="Recent / favorite folders…"
                              IsVisible="{Binding HasRememberedPaths}"
                              DisplayMemberBinding="{Binding Display}"/>
                </StackPanel>
            </Grid>

            <!-- Kind is Claude-only: a local provider runs solely as an SDK session (TTY spawns the claude CLI). -->
            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center" IsVisible="{Binding IsClaudeProfile}">
                <TextBlock Grid.Column="0" Text="Kind" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="SDK" Classes.Accent="{Binding IsSdk}" Command="{Binding SelectSdkCommand}"
                            ToolTip.Tip="Headless stream-json rendered as the chat UI, with live mode/model/effort switching"/>
                    <Button Content="TTY" Classes.Accent="{Binding IsTty}" Command="{Binding SelectTtyCommand}"
                            ToolTip.Tip="The real interactive claude TUI in a terminal panel"/>
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center" IsVisible="{Binding ShowSessionOptions}">
                <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PermissionModes}" SelectedItem="{Binding SelectedPermissionMode}"
                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center" IsVisible="{Binding ShowSessionOptions}">
                <TextBlock Grid.Column="0" Text="Model" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid ColumnDefinitions="72,*" VerticalAlignment="Center" IsVisible="{Binding ShowSessionOptions}">
                <TextBlock Grid.Column="0" Text="Effort" VerticalAlignment="Center" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Efforts}" SelectedItem="{Binding SelectedEffort}"
                          DisplayMemberBinding="{Binding Label}" HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Per-session MCP-server selection (#44): a checkbox per enabled registry server, defaulting to
                 all checked (matching the pre-#44 behaviour). Hidden entirely when the registry has none. -->
            <Grid ColumnDefinitions="72,*" IsVisible="{Binding HasMcpServers}">
                <TextBlock Grid.Column="0" Text="MCP" VerticalAlignment="Top" Margin="0,4,0,0" FontSize="12.5"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding McpServers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:McpServerSelectionItemViewModel">
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabledForSession}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- TTY hint: the mode/model/effort above are launch-only start defaults here — the real TUI
                 owns live switching itself, unlike the SDK per-session dropdowns. -->
            <TextBlock Text="Start defaults only — once running, switch live inside the TUI itself (/model, /effort, Shift+Tab). The per-session dropdowns are SDK-only."
                       FontSize="11" TextWrapping="Wrap" Margin="72,0,0,0"
                       Foreground="{StaticResource CockpitTextFaintBrush}"
                       IsVisible="{Binding ShowTtyStartHint}"/>

            <!-- SDK hint: short reassurance that these stay live-switchable, mirroring the TTY note above. -->
            <TextBlock Text="These stay live-switchable during the session via the per-session dropdowns."
                       FontSize="11" TextWrapping="Wrap" Margin="72,0,0,0"
                       Foreground="{StaticResource CockpitTextFaintBrush}"
                       IsVisible="{Binding ShowSdkStartHint}"/>

        </StackPanel>
    </DockPanel>
</Window>
