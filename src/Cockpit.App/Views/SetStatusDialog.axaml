<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.SetStatusDialog"
        x:DataType="vm:SetStatusDialogViewModel"
        Title="Set status"
        Width="460" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:SetStatusDialogViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Button Grid.Column="0" Content="Clear" Click="OnClear"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="Cancel" Click="OnCancel"/>
                    <Button Content="Set" Classes="Accent" Click="OnSet"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Margin="20,18" Spacing="10">
            <TextBlock Text="What is this session working on? Shown under the session in the sidebar and header."
                       TextWrapping="Wrap" FontSize="12.5"
                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            <TextBox Name="StatusBox" Text="{Binding StatusText}"
                     PlaceholderText="e.g. AC-32 — manual status" KeyDown="OnStatusBoxKeyDown"/>
        </StackPanel>
    </DockPanel>
</Window>
