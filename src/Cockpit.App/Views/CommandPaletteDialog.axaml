<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.CommandPaletteDialog"
        x:DataType="vm:CommandPaletteDialogViewModel"
        Title="Command palette"
        Width="640" Height="460" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:CommandPaletteDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="12">
        <!-- Spotlight-style search bar: a rounded pill with an accent spark icon and a borderless input. -->
        <Border Grid.Row="0" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="14,11">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="›" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                           Margin="2,0,12,0" Foreground="{StaticResource CockpitAccentBrush}"/>
                <TextBox x:Name="QueryBox" Text="{Binding Query}"
                         Background="Transparent" BorderThickness="0" Padding="0" FontSize="15"
                         VerticalContentAlignment="Center"
                         PlaceholderText="Type a command…  ↑/↓ to move, Enter to run, Esc to close"/>
            </DockPanel>
        </Border>

        <ListBox x:Name="CommandList" Grid.Row="1" Margin="0,10,0,0"
                 ItemsSource="{Binding Visible}" SelectedItem="{Binding Selected}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.Styles>
                <!-- Recolour the Fluent selection directly on the item's content presenter (the theme
                     resource-key override was too faint). Use the subtle hover background — the accent was
                     too loud — so the selected command reads clearly without shouting. -->
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{StaticResource CockpitSecondaryBgBrush}"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PaletteCommand">
                    <Grid ColumnDefinitions="*,Auto" Margin="2,3">
                        <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding GestureDisplay}" VerticalAlignment="Center"
                                   FontFamily="{StaticResource CockpitMonoFont}" FontSize="11"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
