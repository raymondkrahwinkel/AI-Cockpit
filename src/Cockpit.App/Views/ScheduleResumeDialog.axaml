<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.ScheduleResumeDialog"
        x:DataType="vm:ScheduleResumeDialogViewModel"
        Title="Resume later"
        Width="460" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:ScheduleResumeDialogViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="OnCancel"/>
                <Button Content="Schedule" Classes="Accent" Click="OnSchedule"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20,18" Spacing="12">
            <TextBlock Text="Send a prompt to this session at a time you choose. One prompt, once — nothing runs on its own afterwards."
                       TextWrapping="Wrap" FontSize="12.5"
                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <CalendarDatePicker SelectedDate="{Binding Day}" Width="180"/>
                <TimePicker SelectedTime="{Binding TimeOfDay}" ClockIdentifier="24HourClock"/>
            </StackPanel>
            <!-- One line: a terminal reads a line break as "send now", so a two-line prompt would arrive cut in
                 half with something acting on the first half. -->
            <TextBox Text="{Binding Prompt}" AcceptsReturn="False"
                     PlaceholderText="What should it pick up with?"/>
        </StackPanel>
    </DockPanel>
</Window>
