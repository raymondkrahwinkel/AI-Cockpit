<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.AboutDialog"
        x:DataType="vm:AboutInfo"
        Title="About"
        Width="380" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:AboutInfo AppName="AI-Cockpit" VersionText="0.3.0"
                      BuildText="Plugin API 1 (SDK 1.4.0) · .NET 10.0.10"
                      Description="Run several AI coding sessions side by side — each in its own profile, with its own provider, permissions and transcript."
                      Providers="Ollama · LM Studio · plus any provider a plugin adds (Claude, Codex, Gemini, OpenAI, GitHub Models)."
                      LicenseText="Apache 2.0 with the Commons Clause · © 2026 Raymond Krahwinkel / Krahwinkel-IT"
                      GitHubUrl="https://github.com/raymondkrahwinkel/AI-Cockpit"
                      IssuesUrl="https://github.com/raymondkrahwinkel/AI-Cockpit/issues"
                      PluginStoreUrl="https://github.com/raymondkrahwinkel/AI-Cockpit-Plugins"/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="12">

        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="36" Height="36" CornerRadius="10"
                    BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                <TextBlock Text="AI" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource CockpitAccentBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppName}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VersionText, StringFormat='Version {0}'}"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="12"/>
                <TextBlock Text="{Binding BuildText}" TextWrapping="Wrap"
                           Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12"
                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>

        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>

        <StackPanel Spacing="3">
            <TextBlock Text="Providers" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource CockpitTextFaintBrush}"/>
            <TextBlock Text="{Binding Providers}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
        </StackPanel>

        <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>

        <StackPanel Spacing="6">
            <Button Content="GitHub repository" Classes="Subtle" HorizontalAlignment="Left" Padding="0"
                    Foreground="{StaticResource CockpitAccentBrush}"
                    Click="OnOpenGitHub" ToolTip.Tip="{Binding GitHubUrl}"/>
            <Button Content="Report an issue" Classes="Subtle" HorizontalAlignment="Left" Padding="0"
                    Foreground="{StaticResource CockpitAccentBrush}"
                    Click="OnOpenIssues" ToolTip.Tip="{Binding IssuesUrl}"/>
            <Button Content="Plugin store" Classes="Subtle" HorizontalAlignment="Left" Padding="0"
                    Foreground="{StaticResource CockpitAccentBrush}"
                    Click="OnOpenPluginStore" ToolTip.Tip="{Binding PluginStoreUrl}"/>
        </StackPanel>

        <TextBlock Text="{Binding LicenseText}" TextWrapping="Wrap" FontSize="11"
                   Foreground="{StaticResource CockpitTextFaintBrush}"/>

        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <Button Grid.Column="1" Content="Close" Click="OnClose"/>
        </Grid>
    </StackPanel>
</Window>
