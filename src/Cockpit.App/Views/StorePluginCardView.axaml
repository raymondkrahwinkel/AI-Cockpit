<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:conv="using:Cockpit.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Cockpit.App.Views.StorePluginCardView"
             x:DataType="vm:StorePluginRowViewModel"
             HorizontalAlignment="Stretch">

    <!-- No Design.DataContext here: StorePluginRowViewModel has no parameterless constructor (it always
         wraps a real PluginStoreEntry/index URL), so the previewer just shows this control unbound. -->

    <!-- One catalogue row in the store's middle column (categories | plugins | details). A click anywhere
         on the row outside its own buttons opens the detail panel (OnCardPressed, code-behind) — mirrors
         CockpitWindowChrome's "bail if the click landed on a Button" pattern. Surface + hover + the featured
         accent edge come from the Border.storeRow styles (Theme.axaml). -->
    <Border Classes="storeRow" Classes.featured="{Binding IsFeatured}"
            CornerRadius="{StaticResource CockpitPanelRadius}" Padding="12,10" Cursor="Hand"
            PointerPressed="OnCardPressed">
        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Icon: the entry's glyph, or its monogram letter when it set none. -->
            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9"
                    Background="{StaticResource CockpitPanelBgBrush}" VerticalAlignment="Center">
                <Panel>
                    <TextBlock Text="{Binding IconGlyphOrNull}" FontSize="19"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding IconGlyphOrNull, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding MonogramLetter}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding IconGlyphOrNull, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                </Panel>
            </Border>

            <!-- Name + install-state pill, one-line description, and the category/version/Free meta row. -->
            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <!-- A quiet outlined pill — green "Installed", amber "Update" — so install state reads at a
                         glance without hunting for the button's label. -->
                    <Border CornerRadius="20" Padding="7,1" IsVisible="{Binding HasStateBadge}"
                            BorderThickness="1" VerticalAlignment="Center"
                            BorderBrush="{Binding StateBadgeBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}">
                        <TextBlock Text="{Binding StateBadgeText}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding StateBadgeBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,0">
                    <Border Background="{StaticResource CockpitPanelBgBrush}" CornerRadius="4" Padding="6,1"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding LatestVersion}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                    <TextBlock Text="Free" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                    <TextBlock Text="{Binding Author}" FontSize="11" VerticalAlignment="Center"
                               IsVisible="{Binding HasAuthor}"
                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Actions: settings gear + enable/disable power for an installed plugin, then the primary
                 Install/Update call-to-action (accent-filled while it does something; a quiet "Installed ✓"
                 once up to date). -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Content="⚙" Classes="Subtle Compact" Padding="6,2" FontSize="13"
                        IsVisible="{Binding HasSettings}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.OpenStorePluginSettingsCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="Plugin settings"/>
                <Button Content="{Binding ToggleGlyph}" Classes="Subtle Compact" Padding="6,2" FontSize="14"
                        Foreground="{Binding ToggleBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                        IsVisible="{Binding IsInstalled}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.ToggleStorePluginCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{Binding ToggleTooltip}"/>
                <Button Content="{Binding PrimaryActionLabel}" Classes="Compact"
                        Classes.accentCta="{Binding CanTakePrimaryAction}"
                        IsEnabled="{Binding CanTakePrimaryAction}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.InstallFromStoreCommand}"
                        CommandParameter="{Binding}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
