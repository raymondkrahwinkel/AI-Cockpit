<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Cockpit.App.Views.StorePluginCardView"
             x:DataType="vm:StorePluginRowViewModel"
             Width="260">

    <!-- No Design.DataContext here: StorePluginRowViewModel has no parameterless constructor (it always
         wraps a real PluginStoreEntry/index URL), so the previewer just shows this control unbound. -->

    <!-- A click anywhere on the card outside its own buttons opens the detail panel (OnCardPressed,
         code-behind) — mirrors CockpitWindowChrome's "bail if the click landed on a Button" pattern. -->
    <Border Background="{StaticResource CockpitSecondaryBgBrush}"
            BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
            CornerRadius="{StaticResource CockpitControlRadius}" Padding="14" Cursor="Hand"
            PointerPressed="OnCardPressed">
        <StackPanel Spacing="6">

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource CockpitPanelBgBrush}">
                    <Panel>
                        <TextBlock Text="{Binding IconGlyphOrNull}" FontSize="17"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding IconGlyphOrNull, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="{Binding MonogramLetter}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding IconGlyphOrNull, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                    </Panel>
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Author}" FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"
                               IsVisible="{Binding HasAuthor}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis" MaxLines="2"
                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Background="{StaticResource CockpitPanelBgBrush}" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                </Border>
                <TextBlock Text="{Binding LatestVersion}" FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"/>
                <TextBlock Text="Free" FontSize="11" Foreground="{StaticResource CockpitTextFaintBrush}"/>
            </StackPanel>

            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,2,0,0">
                <!-- For an installed plugin: a gear to its settings and a power toggle to enable/disable it,
                     right on the card (in addition to the Installed management view). -->
                <Button Grid.Column="0" Content="⚙" Classes="Subtle Compact" Padding="6,2"
                        IsVisible="{Binding HasSettings}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.OpenStorePluginSettingsCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="Plugin settings"/>
                <Button Grid.Column="1" Content="{Binding ToggleGlyph}" Classes="Subtle Compact" Padding="6,2" Margin="4,0,0,0"
                        IsVisible="{Binding IsInstalled}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.ToggleStorePluginCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{Binding ToggleTooltip}"/>
                <Button Grid.Column="2" Content="Details" Classes="Subtle Compact" HorizontalAlignment="Left" Margin="4,0,0,0"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).ShowDetailsCommand}"
                        CommandParameter="{Binding}"/>
                <Button Grid.Column="3" Content="{Binding PrimaryActionLabel}" Classes="Compact"
                        IsEnabled="{Binding CanTakePrimaryAction}"
                        Command="{Binding $parent[Window].((vm:PluginStoreDialogViewModel)DataContext).Manager.InstallFromStoreCommand}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
