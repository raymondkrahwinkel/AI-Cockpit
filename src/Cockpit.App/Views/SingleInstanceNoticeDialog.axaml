<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.SingleInstanceNoticeDialog"
        Title="Cockpit is already running"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CockpitPanelBgBrush}">

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="OK" Classes="Accent" IsDefault="True" Click="OnDismiss"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20,18" Spacing="8">
            <TextBlock Text="Cockpit is already running" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock TextWrapping="Wrap" FontSize="12.5"
                       Foreground="{StaticResource CockpitTextSecondaryBrush}"
                       Text="Another cockpit is open on this machine, so this one will not start. Two of them share one set of settings, plugins and sessions, and would write over each other's. Use the cockpit you already have open."/>
        </StackPanel>
    </DockPanel>
</Window>
