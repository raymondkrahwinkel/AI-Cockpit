<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:conv="using:Cockpit.App.Converters"
             xmlns:controls="using:Cockpit.App.Controls"
             xmlns:layout="using:Cockpit.Core.Layout"
             xmlns:projects="using:Cockpit.Core.Projects"
             xmlns:ws="using:Cockpit.Core.Workspaces"
             xmlns:widgets="using:Cockpit.Plugins.Abstractions.Widgets"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:avconv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
             x:Class="Cockpit.App.Views.CockpitView"
             x:DataType="vm:CockpitViewModel"
             Background="{StaticResource CockpitWindowBgBrush}">

    <Design.DataContext>
        <vm:CockpitViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- The per-session close ✕ stays invisible until its sidebar row is hovered, so the overview
             reads calm; hovering reveals the affordance. Opacity (not IsVisible) keeps the row layout
             stable, and the target is only practically clickable while hovered (thus visible). -->
        <Style Selector="Border.sessionItem Button.closeSession">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Border.sessionItem:pointerover Button.closeSession">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- The project rows' ▶ hides the same way, for the same reason (AC-164): a column of play buttons
             reads as a list of things to launch, where the sidebar's job is to show what is already running. -->
        <Style Selector="Border.sessionItem Button.startProject">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Border.sessionItem:pointerover Button.startProject">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- A workspace tab reads as a tab only once one of them is clearly the current one, so the active tab
             takes the panel background and full-strength text while the rest stay flat and faint. Same
             hover-to-reveal ✕ as the session rows, for the same reason: a row of close buttons makes the strip
             read as a list of things to get rid of. -->
        <Style Selector="Border.workspaceTab">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.workspaceTab TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CockpitTextFaintBrush}"/>
        </Style>
        <Style Selector="Border.workspaceTab:pointerover">
            <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        </Style>
        <Style Selector="Border.workspaceTab.active">
            <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        </Style>
        <Style Selector="Border.workspaceTab.active TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        </Style>
        <!-- A widget is being dragged over this tab and would land there: the same coral outline the drop ghost
             draws on the grid, because it answers the same question in the same gesture — only here the answer
             is "on that desk" rather than "on this cell".
             The class goes on the generated container (the strip's children) and the selector reaches through to
             the Border. Outline only, deliberately: the tab sets Background="Transparent" inline — it has to, or
             it would not be hit-testable — and a local value beats a style setter, so a Background here would
             silently do nothing. BorderBrush/BorderThickness carry no local value, so they land. -->
        <Style Selector="ContentPresenter.dropTarget > Border.workspaceTab">
            <Setter Property="BorderBrush" Value="{StaticResource CockpitAccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="ContentPresenter.dropTarget > Border.workspaceTab TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CockpitTextPrimaryBrush}"/>
        </Style>
        <Style Selector="Border.workspaceTab Button.closeWorkspace">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Border.workspaceTab:pointerover Button.closeWorkspace">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- The figures in the status bar are a button, and have to look like one before they are hovered: a strip of
             grey text that happens to be clickable is a feature nobody finds. So it carries a chevron pointing at the
             panel it opens, lifts on hover and takes the hand cursor — enough to say "press me" without putting a
             button-shaped box in a bar that is meant to be quiet. -->
        <Style Selector="Button.statusMeter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.statusMeter:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CockpitPanelBgBrush}"/>
        </Style>

        <!-- The resource panel (#78) rises out of the status bar rather than appearing: closed it is not merely
             hidden but out of the way — no opacity, no pointer — so it never eats a click at the bottom-right of a
             window it is not in. Animated on opacity and position rather than toggled on IsVisible, because a panel
             that snaps into existence reads as a glitch, and one that slides up reads as the bar opening. -->
        <Style Selector="Border.resourcePanel">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="RenderTransform" Value="translateY(10px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.resourcePanel.open">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="RenderTransform" Value="translateY(0)"/>
        </Style>
    </UserControl.Styles>

    <DockPanel LastChildFill="True">

        <!-- Persistent update banner (AC-73). A newer build was too easy to miss as a startup toast: it
             auto-dismisses, and it fires before the freshly-opened window has focus. This bar stays until the
             operator opens the release or dismisses it, and returns when a build newer than the dismissed one is
             found. Docked above the whole window — over sidebar and content both — so it reads as "the application
             has an update", not "this panel does". The tint is the accent at low alpha, so it tracks the accent
             colour rather than pinning a second brown. Collapsed (not just transparent) when there is nothing to
             say, so it costs no height until a build is waiting. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding UpdateBannerVisible}"
                Background="#26D97757"
                BorderBrush="{StaticResource CockpitAccentBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,9">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="Accent" Padding="12,5"
                            Content="Open release"
                            Command="{Binding OpenUpdateCommand}"
                            ToolTip.Tip="{Binding UpdateUrl}"/>
                    <Button Classes="Subtle" Padding="6,4"
                            Command="{Binding DismissUpdateCommand}"
                            ToolTip.Tip="Dismiss — reappears when a newer build is available">
                        <materialIcons:MaterialIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="ArrowUpBoldCircleOutline" Width="18" Height="18"
                                                Foreground="{StaticResource CockpitAccentBrush}"
                                                VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextPrimaryBrush}"
                               Text="A new build is available —"/>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{StaticResource CockpitTextPrimaryBrush}"
                               Text="{Binding UpdateName}"/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"
                               Text="{Binding CurrentBuild, StringFormat='· you’re on {0}'}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Awareness banner (AC-41): the API keys and tokens in cockpit.json are readable at rest. Amber, not
             red, and never modal — it states a fact and offers the one-click fix, it does not steal focus or block
             the cockpit. Docked above the whole window like the update banner, so it reads as "the application",
             not "this panel". Collapsed (not just transparent) when there is nothing to say, so it costs no height
             once encryption is on or the operator dismisses it. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding Security.ShowUnprotectedBanner}"
                Background="#26E0A33E"
                BorderBrush="{StaticResource CockpitStatusWaitingBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,9">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <!-- While the migration runs, the action is replaced by its own inline "Encrypting…" so the
                         banner shows its work rather than going quiet mid-rewrite. -->
                    <TextBlock Text="Encrypting…" VerticalAlignment="Center"
                               IsVisible="{Binding Security.IsMigrating}"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    <Button Classes="Accent" Padding="12,5" Content="Enable now"
                            IsVisible="{Binding !Security.IsMigrating}"
                            Click="OnEnableEncryption"
                            ToolTip.Tip="Encrypt your API keys and tokens with a password"/>
                    <Button Classes="Subtle" Padding="6,4"
                            Command="{Binding Security.DismissBannerCommand}"
                            ToolTip.Tip="Dismiss — returns when you add a new credential">
                        <materialIcons:MaterialIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="ShieldAlertOutline" Width="18" Height="18"
                                                Foreground="{StaticResource CockpitStatusWaitingBrush}"
                                                VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextPrimaryBrush}"
                               Text="Your API keys and tokens are stored unencrypted."/>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"
                               Text="Turn on encryption to protect them at rest — it only takes a moment."/>
                </StackPanel>
            </DockPanel>
        </Border>

    <Grid x:Name="RootGrid">
        <!-- One row for AI-Cockpit, one for the status bar (#78). Everything that was here before stays in
             row 0 by default, so adding the bar did not have to touch a single existing panel. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Width set from CockpitViewModel.SidebarWidth in code-behind (#49) — a GridLength column
                 can't compiled-bind straight to the VM's double, so CockpitView.axaml.cs applies it on
                 load/change and reads it back once the GridSplitter drag below ends (via RootGrid, since
                 x:Name on a ColumnDefinition itself doesn't generate a code-behind field). Min/Max keep
                 both the drag and a hand-edited persisted value inside a sane range. -->
            <ColumnDefinition Width="180"
                               MinWidth="{x:Static layout:LayoutSettings.MinSidebarWidth}"
                               MaxWidth="{x:Static layout:LayoutSettings.MaxSidebarWidth}"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: always visible in both grid and zoom mode — the constant overview/status anchor. -->
        <Border Grid.Column="0" Background="{StaticResource CockpitSecondaryBgBrush}"
                IsVisible="{Binding !SidebarCollapsed}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="8">

                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                    <!-- Collapse the sidebar out of the way; a matching » button appears over the content to bring it back. -->
                    <Button Content="«" HorizontalAlignment="Right" Padding="8,2" Classes="Subtle"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip.Tip="Collapse the sidebar"/>
                    <!-- SDK vs TTY is chosen inside the New-session dialog (#32) — the primary action covers both.
                         The caret adds a plain terminal (#AC-25) without pushing it into the common one-click path:
                         "new session" stays a single click, "new terminal" is one flyout down. One accent pill with
                         a hairline divider, so it reads as a single split-button rather than two loose buttons. -->
                    <Border CornerRadius="{StaticResource CockpitControlRadius}" ClipToBounds="True"
                            Background="{StaticResource CockpitAccentBrush}"
                            BorderBrush="{StaticResource CockpitAccentBrush}" BorderThickness="1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Classes="Subtle" Padding="11,6"
                                    VerticalAlignment="Stretch" ToolTip.Tip="New session or terminal">
                                <materialIcons:MaterialIcon Kind="ChevronDown" Width="12" Height="12"/>
                                <Button.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                                        <MenuItem Header="New session" Command="{Binding NewSessionCommand}"
                                                  ToolTip.Tip="An AI session — SDK or TTY, chosen in the dialog">
                                            <MenuItem.Icon>
                                                <materialIcons:MaterialIcon Kind="ChatOutline" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="New terminal" Command="{Binding NewTerminalCommand}"
                                                  ToolTip.Tip="A plain shell (your default, else the OS default) in a terminal pane">
                                            <MenuItem.Icon>
                                                <materialIcons:MaterialIcon Kind="Console" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Border DockPanel.Dock="Right" Width="1" Margin="0,4"
                                    Background="{StaticResource CockpitAccentPressedBrush}"/>
                            <Button Classes="Subtle" Content="+ New session" Command="{Binding NewSessionCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="12,6"/>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Footer: secondary "Tools" section — Audio (F0) lives here, out of the way of the
                     primary session overview per AI-Cockpit's design goal (sidebar = sessions, not tools). -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="4">
                    <Border Height="1" Background="{StaticResource CockpitHairlineBrush}" Margin="0,4"/>
                    <!-- Runtime open-mic toggle: listens continuously and types into the selected session.
                         Disabled until Voice is enabled in Options (open-mic needs the mic pipeline). -->
                    <ToggleButton Content="Open mic" HorizontalAlignment="Stretch"
                                  IsChecked="{Binding OpenMic.IsListening, Mode=OneWay}"
                                  Command="{Binding OpenMic.ToggleOpenMicCommand}"
                                  IsEnabled="{Binding OpenMic.IsAvailable}"
                                  ToolTip.ShowOnDisabled="True"
                                  ToolTip.Tip="Toggle open-mic dictation on/off — listens continuously and types into the selected session (enable Voice in Options first)"/>
                    <!-- The plugin store sits in the menu column rather than inside the menu: it is where the plugins
                         and the workflow templates come from, and it is the one thing in that menu people go looking
                         for. A door you have to open a drawer to find is a door most people never open. -->
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            Command="{Binding OpenPluginStoreCommand}"
                            ToolTip.Tip="Browse, install and update plugins — and the workflow templates they ship with">
                        <DockPanel>
                            <!-- AC-76: a persistent coral count-pill on the right when plugin updates are waiting, so
                                 an update shows in the main window rather than only a transient toast. The button
                                 opens the store on the Updates filter while the badge is showing. -->
                            <Border DockPanel.Dock="Right" IsVisible="{Binding Plugins.HasUpdateBadge}"
                                    Background="{StaticResource CockpitAccentBrush}" CornerRadius="20" Padding="7,1"
                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                    ToolTip.Tip="Plugin updates available — click to review them">
                                <TextBlock Text="{Binding Plugins.UpdateBadgeCount}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <!-- AC-208: a persistent badge while any installed plugin is sitting at awaiting-approval
                                 (new, or its bytes changed) — mirrors the AC-76 update pill so the two read as the
                                 same kind of indicator; it clears once every such plugin is approved or disabled. -->
                            <Border DockPanel.Dock="Right" IsVisible="{Binding Plugins.HasPendingApproval}"
                                    Background="{StaticResource CockpitStatusWaitingBrush}" CornerRadius="20" Padding="7,1"
                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                    ToolTip.Tip="Plugins awaiting your approval — click to review them">
                                <TextBlock Text="{Binding Plugins.PendingApprovalCount}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <TextBlock Text="Plugin store" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Button>

                    <!-- Everything you configure or look up once, behind one menu: the sidebar is for sessions,
                         and six permanent text rows of setup drowned that out. Styled like the plugin rows above
                         it rather than as a faint chromeless link: it sits in the same column and does the same
                         kind of thing, and a row that is styled differently reads as a different kind of control. -->
                    <Button Content="Menu" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            ToolTip.Tip="Profiles, MCP servers, plugins, options and about">
                        <Button.Flyout>
                            <MenuFlyout Placement="TopEdgeAlignedLeft">
                                <MenuItem Header="Profiles" Command="{Binding ManageProfilesCommand}"
                                          ToolTip.Tip="Add, edit or remove session profiles"/>
                                <MenuItem Header="MCP servers" Command="{Binding OpenMcpServersCommand}"
                                          ToolTip.Tip="Add, edit or remove shared MCP servers"/>
                                <MenuItem Header="Verify runners" Command="{Binding OpenVerifyRunnersCommand}"
                                          ToolTip.Tip="Register the per-project command the visual verify loop may run"/>
                                <MenuItem Header="Command palette" Command="{Binding ShowCommandPaletteCommand}"
                                          InputGesture="Ctrl+K"
                                          ToolTip.Tip="Run any app or plugin command by name"/>
                                <Separator/>
                                <MenuItem Header="Options" Command="{Binding OptionsCommand}"
                                          InputGesture="Ctrl+O"
                                          ToolTip.Tip="Configure notifications, sessions, and voice"/>
                                <MenuItem Header="About" Command="{Binding AboutCommand}"
                                          ToolTip.Tip="App version and links"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!-- Plugin-contributed left-menu sections (#14), docked above the footer and below the
                     session list. Built in code-behind from CockpitViewModel.PluginSideSections; hidden
                     entirely when no plugin contributes a section (no visual noise at zero plugins). -->
                <StackPanel DockPanel.Dock="Bottom" x:Name="PluginSectionsHost" Spacing="4" IsVisible="False"/>

                <!-- Projects (AC-164): the few most recently worked on, one click from starting one. Hidden
                     entirely when there are none, so a cockpit that does not use projects looks exactly as it did.
                     ▶ starts on the project's own defaults and skips the dialog; the context menu holds the slower
                     routes for when the operator wants to change something the project would otherwise decide.
                     Deliberately the recent few and not all of them: this strip is for reaching what you are busy
                     with, and the overview is where the whole list lives. -->
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,10"
                            IsVisible="{Binding Projects.HasProjects}">
                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="2,0,0,2">
                        <TextBlock Grid.Column="0" Text="Projects" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                        <!-- The way to the overview: without it, reaching it means knowing a workspace type exists
                             and finding it in the "+" menu — which is exactly the knowledge it is built to spare. -->
                        <Button Grid.Column="1" Classes="Subtle" Padding="4,0"
                                Foreground="{StaticResource CockpitTextFaintBrush}"
                                Command="{Binding OpenProjectsWorkspaceCommand}"
                                ToolTip.Tip="Open the projects overview">
                            <materialIcons:MaterialIcon Kind="ViewGridOutline" Width="12" Height="12"/>
                        </Button>
                        <Button Grid.Column="2" Classes="Subtle" Padding="4,0"
                                Foreground="{StaticResource CockpitTextFaintBrush}"
                                Command="{Binding Projects.AddProjectCommand}"
                                ToolTip.Tip="New project">
                            <materialIcons:MaterialIcon Kind="Plus" Width="12" Height="12"/>
                        </Button>
                    </Grid>

                    <ItemsControl x:Name="ProjectListStrip" ItemsSource="{Binding Projects.SidebarProjects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="projects:Project">
                                <!-- Same row treatment as a session (Border.sessionItem): both are things in the
                                     sidebar you point at, and a second look for the same gesture would only say
                                     they behave differently. Background/border stay out of the markup for the
                                     reason the session rows document — a local value beats the style. -->
                                <Border Classes="sessionItem" Margin="0,0,0,2" Padding="8,5"
                                        CornerRadius="{StaticResource CockpitControlRadius}"
                                        ToolTip.Tip="{Binding Description}">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Start session" Click="OnStartProjectSession"/>
                                            <MenuItem Header="New session…" Click="OnNewSessionForProject"/>
                                            <Separator/>
                                            <MenuItem Header="Open folder" Click="OnOpenProjectFolder"
                                                      IsEnabled="{Binding SourceDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <MenuItem Header="Edit project" Click="OnEditProject"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7">
                                        <controls:ProjectLogoBadge Grid.Column="0" Size="17" ShowsInitial="False"
                                                                   VerticalAlignment="Center"
                                                                   LogoPath="{Binding LogoPath}"
                                                                   ProjectName="{Binding Name}"
                                                                   IsVisible="{Binding LogoPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Hover-revealed quick start, mirroring the session rows' hover ✕. -->
                                        <Button Grid.Column="2" Classes="Subtle startProject"
                                                Padding="4,0" VerticalAlignment="Center"
                                                Foreground="{StaticResource CockpitAccentBrush}"
                                                Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).StartProjectSessionCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Start a session on this project">
                                            <materialIcons:MaterialIcon Kind="Play" Width="13" Height="13"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Classes="Subtle" Padding="8,2" FontSize="11" HorizontalAlignment="Left"
                            Foreground="{StaticResource CockpitTextFaintBrush}"
                            IsVisible="{Binding Projects.HasMoreThanSidebarShows}"
                            Command="{Binding OpenProjectsWorkspaceCommand}"
                            Content="All projects →"
                            ToolTip.Tip="Open the projects overview"/>
                </StackPanel>

                <ScrollViewer>
                    <!-- The sidebar lists only the workspace now showing, so it never offers a session the grid
                         is hiding. Safe to filter here, unlike the grid below: these rows carry no pty.
                         Drag-reorder (AC-115): the move/release handlers sit on the ItemsControl, not the row —
                         a move rebuilds the row containers, so a per-row handler would stop firing mid-drag. Each
                         row only arms the drag on PointerPressed. Mirrors the workspace tab strip. -->
                    <ItemsControl x:Name="SessionListStrip" ItemsSource="{Binding VisibleSessions}"
                                  PointerMoved="OnSessionItemPointerMoved"
                                  PointerReleased="OnSessionItemPointerReleased">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SessionPanelViewModel">
                                <!-- Selection + attention are driven entirely by the style classes below
                                     (see Theme.axaml Border.sessionItem*): the active session lifts to a
                                     filled card with an accent left-edge, inactive ones stay flat against
                                     the sidebar. Background/border are NOT set inline here — a local value
                                     would beat the style setters and both rows would look identical. -->
                                <Border Classes="sessionItem" Margin="0,0,0,4" Padding="8,6" CornerRadius="{StaticResource CockpitControlRadius}"
                                        Classes.active="{Binding IsSelected}"
                                        Classes.attention="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                        Cursor="Hand"
                                        PointerPressed="OnSessionItemPointerPressed">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename" Click="OnRenameSession"/>
                                            <MenuItem Header="Duplicate" Click="OnDuplicateSession"/>
                                            <Separator/>
                                            <MenuItem Header="Set status…" Click="OnSetSessionStatus"/>
                                            <MenuItem Header="Resume later…" Click="OnScheduleSessionResume"/>
                                            <MenuItem Header="Clear status" Click="OnClearSessionStatus"
                                                      IsEnabled="{Binding Statusline, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <Separator/>
                                            <MenuItem Header="Move up" Click="OnMoveSessionUp"/>
                                            <MenuItem Header="Move down" Click="OnMoveSessionDown"/>
                                            <Separator/>
                                            <MenuItem Header="Close" Click="OnCloseSessionMenu"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding SessionStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                               IsVisible="{Binding !IsRenaming}"/>
                                                    <TextBox Text="{Binding EditTitle}" IsVisible="{Binding IsRenaming}"
                                                             Classes="Compact" MinWidth="110" FontWeight="SemiBold"
                                                             KeyDown="OnRenameBoxKeyDown" LostFocus="OnRenameBoxLostFocus"
                                                             AttachedToVisualTree="OnRenameBoxAttached"/>
                                                    <materialIcons:MaterialIcon Kind="AlertOutline" Width="13" Height="13"
                                                               Foreground="{StaticResource CockpitStatusWaitingBrush}"
                                                               IsVisible="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                                               ToolTip.Tip="Needs attention"/>
                                                    <!-- A consent request is waiting on this session (#AC-47): the same
                                                         "Ask me first" hand the cockpit.approve step uses, in the accent
                                                         colour, so the sidebar shows it even when the pane is off screen. -->
                                                    <materialIcons:MaterialIcon Kind="HandBackLeftOutline" Width="13" Height="13"
                                                               Foreground="{StaticResource CockpitAccentBrush}"
                                                               IsVisible="{Binding PendingConsent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                               ToolTip.Tip="Waiting for your consent"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <!-- Mirrors the session-header provider pill (SessionView.axaml) so a local
                                                         (Ollama/LM Studio) session is identifiable from the sidebar too, not just once
                                                         opened; hidden for Claude-CLI sessions, which leave ProviderBadge empty (#26). -->
                                                    <Border Background="{StaticResource CockpitSecondaryBgBrush}"
                                                            BorderBrush="{StaticResource CockpitAccentBrush}" BorderThickness="1"
                                                            CornerRadius="3" Padding="4,0" VerticalAlignment="Center"
                                                            IsVisible="{Binding ProviderBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Text="{Binding ProviderBadge}" FontSize="9"
                                                                   Foreground="{StaticResource CockpitAccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding ActiveProfileLabel}"
                                                               Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding SessionStatusLabel}"
                                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>
                                                </StackPanel>
                                                <!-- AC-13: what this session is working on, set by the agent (via MCP) or a workflow;
                                                     accented so it stands out, hidden when blank. -->
                                                <TextBlock Text="{Binding Statusline}" FontSize="11"
                                                           Foreground="{StaticResource CockpitAccentBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding Statusline, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>

                                            <!-- Hover-revealed close, hidden while the confirm prompt is up. -->
                                            <Button Grid.Column="1" Classes="Subtle closeSession"
                                                    VerticalAlignment="Top" Padding="4,0"
                                                    Foreground="{StaticResource CockpitTextFaintBrush}"
                                                    IsVisible="{Binding !IsConfirmingClose}"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).RequestCloseSessionCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Close session">
                                                <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                                            </Button>
                                        </Grid>

                                        <!-- Inline close confirm for a busy session (L11 pattern): Close / Keep. -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsConfirmingClose}">
                                            <TextBlock Text="Close?" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                            <Button Content="Close" Classes="Compact"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).ConfirmCloseSessionCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Keep" Classes="Compact"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).CancelCloseSessionCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Collapsed rail: a slim strip in the sidebar's own column (so it never overlaps the session
             content) with the expand chevron and a compact New session. Shown only while collapsed. -->
        <Border Grid.Column="0" Background="{StaticResource CockpitSecondaryBgBrush}"
                IsVisible="{Binding SidebarCollapsed}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="4,8" Spacing="6" HorizontalAlignment="Center">
                <Button Content="»" Classes="Subtle" Padding="6,2"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip.Tip="Expand the sidebar"/>
                <Button Content="+" Classes="Accent" Padding="7,2"
                        Command="{Binding NewSessionCommand}"
                        ToolTip.Tip="New session"/>
            </StackPanel>
        </Border>

        <!-- Sidebar-width splitter (#49): drags SidebarColumn between its min/max, then
             OnSidebarSplitterDragCompleted reads the settled width back and persists it. -->
        <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"
                      IsVisible="{Binding !SidebarCollapsed}"
                      DragCompleted="OnSidebarSplitterDragCompleted"/>

        <!-- Main area: empty-state welcome until a session exists (#31), then the grid/zoom. -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*">

            <!-- The workspace strip sits ABOVE both the empty state and the grid, deliberately outside the
                 HasSessions gate below: a Dashboard workspace holds widgets and no sessions at all, so a strip
                 that only appeared once a session existed would be a strip you could never reach a dashboard
                 from. Hidden while there is only one workspace (ShowTabStrip) — that is the cockpit as it has
                 always looked, and a lone tab is chrome that earns nothing — but the + stays, since it is what
                 makes the second workspace that reveals the strip. -->
            <Border Grid.Row="0" Margin="12,12,12,0" Padding="0,0,0,6"
                    BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Dock the + first so the tab list never pushes it off the edge when the strip fills up. -->
                    <Button DockPanel.Dock="Right" Classes="Subtle" Padding="8,3" Content="+"
                            ToolTip.Tip="New workspace">
                        <Button.Flyout>
                            <!-- A plain Flyout over an ItemsControl of buttons rather than a MenuFlyout with an
                                 ItemsSource: the latter's containers never materialise (the same shape and reason
                                 the widget gallery uses), which a plugin-contributed type needs. Host types and
                                 plugin types share one list and one command; the type is asked up front and is an
                                 invariant afterwards, since it decides what the workspace can hold. -->
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <ItemsControl ItemsSource="{Binding Workspaces.WorkspaceMenuOptions}" MinWidth="200">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:WorkspaceMenuOption">
                                            <Button Classes="Subtle" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,6"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).Workspaces.AddWorkspaceOptionCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{Binding Description}">
                                                <DockPanel>
                                                    <materialIcons:MaterialIcon Kind="{Binding Icon}" Width="16" Height="16"
                                                                                Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- The drag lives on the strip, not on the tabs: a move rebuilds the tabs, so a handler on
                         the dragged Border would stop firing the moment it did its job once. -->
                    <ItemsControl x:Name="WorkspaceTabStrip" ItemsSource="{Binding Workspaces.Tabs}"
                                  IsVisible="{Binding Workspaces.ShowTabStrip}"
                                  PointerMoved="OnWorkspaceTabPointerMoved"
                                  PointerReleased="OnWorkspaceTabPointerReleased">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceTabViewModel">
                                <!-- Double-click renames in place — the same inline edit a session row uses,
                                     rather than a dialog for one short string. -->
                                <Border Classes="workspaceTab" Classes.active="{Binding IsActive}"
                                        CornerRadius="6" Padding="10,4" Background="Transparent"
                                        PointerPressed="OnWorkspaceTabPressed"
                                        DoubleTapped="OnWorkspaceTabDoubleTapped">
                                    <!-- Right-click is where people look for "rename"; the double-click stays as
                                         the shortcut for those who know it, but it is not discoverable on its
                                         own (Raymond). Same menu shape as the session rows' own. -->
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename…" Click="OnRenameWorkspaceRequested"/>
                                            <MenuItem Header="Close" Click="OnCloseWorkspaceRequested"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <DockPanel>
                                        <!-- Routed through the same handler as the menu's Close, so the close button asks
                                             before discarding a workspace too — it is the easier of the two to
                                             hit by accident. -->
                                        <Button DockPanel.Dock="Right" Classes="Subtle closeWorkspace"
                                                Padding="4,0" Margin="6,0,0,0"
                                                IsVisible="{Binding !IsRenaming}"
                                                Click="OnCloseWorkspaceRequested"
                                                ToolTip.Tip="Close workspace">
                                            <materialIcons:MaterialIcon Kind="Close" Width="10" Height="10"/>
                                        </Button>
                                        <materialIcons:MaterialIcon Kind="{Binding Icon}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   IsVisible="{Binding !IsRenaming}"/>
                                        <!-- Sized and aligned to sit in the tab rather than on top of it: a
                                             default TextBox brings its own padding and min-height, which made
                                             the tab jump and the box hang out of it. Attached, it takes focus
                                             and selects everything, so the first keystroke replaces the name —
                                             which is what you came to do. -->
                                        <TextBox Text="{Binding EditName}" IsVisible="{Binding IsRenaming}"
                                                 MinWidth="90" MinHeight="0" Height="19" Padding="4,0"
                                                 FontSize="12" VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 AttachedToVisualTree="OnWorkspaceRenameAttached"
                                                 KeyDown="OnWorkspaceRenameKeyDown" LostFocus="OnWorkspaceRenameLostFocus"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Dashboard: the widget grid, shown instead of the session content when a Dashboard workspace is
                 active. Its own empty state says "add a widget", never "no sessions yet" — the workspace type
                 drives the affordance, so a dashboard never asks for something it cannot hold. -->
            <DockPanel Grid.Row="1" IsVisible="{Binding Workspaces.IsDashboardActive}">

                <!-- The dashboard's own toolbar. "Add widget" used to live only in the centred empty state,
                     which put it underneath the widgets the moment there were any — it needs a home that does
                     not move, and the dashboard's other controls belong beside it rather than scattered. -->
                <DockPanel DockPanel.Dock="Top" Margin="12,12,12,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                        <!-- Disabled, not hidden, while no plugin contributes a widget: the button is the answer
                             to "how do I fill this dashboard", so it has to stay visible and say why it cannot. -->
                        <Button Content="+ Add widget" Classes="Accent" Padding="10,4"
                                IsEnabled="{Binding Workspaces.HasAvailableWidgets}"
                                ToolTip.Tip="Widgets come from plugins — install one that contributes widgets first">
                        <!-- A plain Flyout over an ItemsControl of buttons rather than a MenuFlyout with an
                             ItemsSource: the latter's containers never materialised here, leaving an enabled
                             button that opened an empty popup. This shape is the gallery — icon, title and the
                             one-liner the widget describes itself with. -->
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <ItemsControl ItemsSource="{Binding Workspaces.AvailableWidgets}" MinWidth="220">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="widgets:WidgetRegistration">
                                            <Button Classes="Subtle" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,6"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).Workspaces.PlaceWidgetCommand}"
                                                    CommandParameter="{Binding}">
                                                <DockPanel>
                                                    <Panel Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <materialIcons:MaterialIcon Kind="{Binding IconKind}" Width="16" Height="16"
                                                                                    IsVisible="{Binding IconKind, Converter={x:Static avconv:ObjectConverters.IsNotNull}}"/>
                                                        <TextBlock Text="{Binding Icon}"
                                                                   IsVisible="{Binding IconKind, Converter={x:Static avconv:ObjectConverters.IsNull}}"/>
                                                    </Panel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7"
                                                                   TextWrapping="Wrap" MaxWidth="180"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Flyout>
                        </Button.Flyout>
                        </Button>

                        <!-- The dashboard's grid shape. Its own settings, not the app's — each dashboard is laid
                             out on its own, and this is where §4g's Columns/Rows live. -->
                        <Button Classes="Subtle" Padding="7,4" ToolTip.Tip="Dashboard settings">
                            <materialIcons:MaterialIcon Kind="Cog" Width="14" Height="14"/>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <StackPanel Spacing="10" MinWidth="200" Margin="4">
                                        <TextBlock Text="Dashboard grid" FontWeight="SemiBold"/>
                                        <DockPanel>
                                            <NumericUpDown DockPanel.Dock="Right" Width="104" Increment="1" FormatString="0"
                                                           Minimum="1" Maximum="256"
                                                           Value="{Binding Workspaces.DashboardColumnsSetting}"/>
                                            <TextBlock Text="Columns" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <DockPanel>
                                            <!-- The bounds match DashboardLayout's Min/Max constants; the record
                                                 clamps anyway, so a drifted literal here cannot reach the grid. -->
                                            <NumericUpDown DockPanel.Dock="Right" Width="104" Increment="1" FormatString="0"
                                                           Minimum="1" Maximum="256"
                                                           Value="{Binding Workspaces.DashboardRowsSetting}"/>
                                            <TextBlock Text="Rows" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="Rows are a starting height — the dashboard grows past it as you add widgets."
                                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap" MaxWidth="190"/>
                                        <CheckBox Content="Show grid lines" IsChecked="{Binding Workspaces.DashboardShowGridLines}"
                                                  ToolTip.Tip="Draw the cells widgets snap to — handy while arranging"/>

                                        <!-- Export/import live with the dashboard's other controls rather than in
                                             the toolbar: they are things you do once, not affordances the
                                             arranging needs in front of it. -->
                                        <Border BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Margin="0,4,0,0"/>
                                        <Button Classes="Subtle" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Padding="6,4" Content="Export this dashboard…" Click="OnExportDashboardPressed"
                                                ToolTip.Tip="Save it to a file — to keep, or to hand to someone. Credentials are left out."/>
                                        <Button Classes="Subtle" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Padding="6,4" Content="Import a dashboard…" Click="OnImportDashboardPressed"
                                                ToolTip.Tip="Add a dashboard from a file, alongside the ones you have"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding Workspaces.Active.Name}" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <!-- The grid, its drag ghost and the empty state share one cell. A Panel rather than more
                     DockPanel children: only a DockPanel's last child fills, so the grid would be docked to the
                     left the moment anything followed it. -->
                <Panel>

                <!-- The cells, under everything and never in the way of a pointer. Same margin as the grid it
                     traces, so the lines land on the boundaries the widgets actually snap to. -->
                <controls:DashboardGridLines Margin="12" IsHitTestVisible="False"
                                             IsVisible="{Binding Workspaces.DashboardShowGridLines}"
                                             Columns="{Binding Workspaces.DashboardColumns}"
                                             Rows="{Binding Workspaces.DashboardRows}"
                                             LineBrush="{StaticResource CockpitHairlineBrush}"/>

                <!-- Column/row counts come from the view model, not the XAML: the row count grows past the
                     configured height as widgets are added (rows are a starting height, not a cap). The panel
                     builds its definitions from them itself — the view cannot, because it has to find the panel
                     to do it and the panel does not exist until a layout pass creates it. -->
                <!-- The drop lives on the grid, not the panes: an arrangement rebuilds nothing, but the pointer
                     has to be tracked across cells the dragged pane does not occupy. -->
                <ItemsControl x:Name="DashboardGrid" Margin="12"
                              ItemsSource="{Binding Workspaces.WidgetPanes}"
                              IsVisible="{Binding !Workspaces.ShowDashboardEmptyState}"
                              PointerMoved="OnDashboardPointerMoved"
                              PointerReleased="OnDashboardPointerReleased">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:DashboardCellsPanel Columns="{Binding Workspaces.DashboardColumns}"
                                                          Rows="{Binding Workspaces.DashboardRows}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter" x:DataType="vm:WidgetPaneViewModel">
                            <Setter Property="Grid.Column" Value="{Binding Column}"/>
                            <Setter Property="Grid.Row" Value="{Binding Row}"/>
                            <Setter Property="Grid.ColumnSpan" Value="{Binding ColumnSpan}"/>
                            <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}"/>
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:WidgetPaneViewModel">
                            <Border Margin="4" CornerRadius="8" Background="{StaticResource CockpitPanelBgBrush}"
                                    BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                                <DockPanel>
                                    <!-- Pane chrome. The gear is bound to HasConfig: a widget that declared no
                                         settings form shows no gear at all, rather than one that opens nothing. -->
                                    <!-- The header is the drag handle: dragging the widget's own body would fight
                                         whatever the plugin's control does with a pointer, and a header is where
                                         a pane is grabbed everywhere else in the cockpit. -->
                                    <DockPanel DockPanel.Dock="Top" Margin="8,6,6,6" Background="Transparent"
                                               Cursor="Hand" PointerPressed="OnWidgetHeaderPressed">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                                            <Button Classes="Subtle" Padding="5,0" Click="OnWidgetRefreshPressed"
                                                    ToolTip.Tip="Refresh">
                                                <materialIcons:MaterialIcon Kind="Refresh" Width="12" Height="12"/>
                                            </Button>
                                            <Button Classes="Subtle" Padding="5,0" Click="OnWidgetConfigPressed"
                                                    IsVisible="{Binding HasConfig}" ToolTip.Tip="Widget settings">
                                                <materialIcons:MaterialIcon Kind="Cog" Width="12" Height="12"/>
                                            </Button>
                                            <Button Classes="Subtle" Padding="5,0" Click="OnWidgetRemovePressed"
                                                    ToolTip.Tip="Remove widget">
                                                <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                                            </Button>
                                        </StackPanel>
                                        <Panel Margin="0,0,6,0" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="{Binding IconKind}" Width="14" Height="14"
                                                                        IsVisible="{Binding IconKind, Converter={x:Static avconv:ObjectConverters.IsNotNull}}"/>
                                            <TextBlock Text="{Binding Icon}"
                                                       IsVisible="{Binding IconKind, Converter={x:Static avconv:ObjectConverters.IsNull}}"/>
                                        </Panel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <!-- The plugin's own control, built once per instance and hosted as-is. The
                                         resize grip sits over its bottom-right corner: a widget is sized by
                                         dragging the corner, and the grip has to be reachable whatever the
                                         plugin drew underneath it. -->
                                    <Panel>
                                        <ContentControl Margin="8,0,8,8" Content="{Binding View}"/>
                                        <Border Width="14" Height="14" Margin="0,0,2,2" Background="Transparent"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Cursor="BottomRightCorner" PointerPressed="OnWidgetResizePressed"
                                                ToolTip.Tip="Drag to resize">
                                            <Path Data="M 10,0 L 10,10 L 0,10" Stroke="{StaticResource CockpitTextFaintBrush}"
                                                  StrokeThickness="1.5" Margin="2"/>
                                        </Border>
                                    </Panel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Where the dragged or resized widget will land. Shown during the gesture and applied on
                     release: without it you are dragging blind, and applying on every pointer move rewrote
                     cockpit.json on every pixel. Its rectangle is set in code — it is measured in the grid's
                     cells, which nothing here can bind to. -->
                <Border x:Name="WidgetDropGhost" IsVisible="False" IsHitTestVisible="False" ZIndex="100"
                        Margin="12" HorizontalAlignment="Left" VerticalAlignment="Top"
                        CornerRadius="8" BorderThickness="2"
                        BorderBrush="{StaticResource CockpitAccentBrush}"
                        Background="{StaticResource CockpitPanelBgBrush}" Opacity="0.55"/>

                <!-- The dashboard's empty state carries no button of its own: the toolbar's "Add widget" is
                     always there, and two buttons doing one thing is how the old one ended up buried under the
                     widgets it created. -->
                <StackPanel IsVisible="{Binding Workspaces.ShowDashboardEmptyState}" MaxWidth="320"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="14"
                            BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <materialIcons:MaterialIcon Kind="ViewDashboardOutline" Width="24" Height="24"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No widgets yet" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Use “+ Add widget” above to fill this dashboard. Widgets come from plugins — install more from the store."
                               TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                </StackPanel>
                </Panel>
            </DockPanel>

            <!-- The projects overview (AC-162): what there is to work on, and everything you do with it — start,
                 open the folder, edit, add a new one. A workspace surface like the session grid and the dashboard
                 rather than a window of its own, so it lives inside the shell the operator already has open and
                 needs no second window lifetime. Written for someone who does not want to know what a profile or
                 an MCP server is: a card says what the project is, when it was last worked on, and has one
                 obvious button. -->
            <ScrollViewer Grid.Row="1" IsVisible="{Binding Workspaces.IsProjectsActive}">
                <StackPanel MaxWidth="920" Margin="24,28" HorizontalAlignment="Center">
                    <TextBlock Text="What do you want to work on?" FontSize="21" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick a project to begin. Everything it needs is already set up."
                               FontSize="13" Margin="0,6,0,18" HorizontalAlignment="Center"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>

                    <!-- The summary line: how much there is, how much of it is actually in use, and what was last
                         worked on — the three things worth knowing before choosing. Hidden with no projects, where
                         a row of zeroes would say nothing the empty state does not say better. -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center"
                                Margin="0,0,0,20" IsVisible="{Binding Projects.HasProjects}">
                        <Border Padding="14,10" CornerRadius="{StaticResource CockpitPanelRadius}"
                                Background="{StaticResource CockpitPanelBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Projects.ProjectCount}" FontSize="19" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="projects" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="14,10" CornerRadius="{StaticResource CockpitPanelRadius}"
                                Background="{StaticResource CockpitPanelBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Projects.OpenedProjectCount}" FontSize="19" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="worked on" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="14,10" CornerRadius="{StaticResource CockpitPanelRadius}"
                                Background="{StaticResource CockpitPanelBgBrush}"
                                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Sessions.Count}" FontSize="19" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="sessions open" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Projects.RecentProjects}" IsVisible="{Binding Projects.HasProjects}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="projects:Project">
                                <Border Width="278" Margin="8" Padding="16"
                                        CornerRadius="{StaticResource CockpitPanelRadius}"
                                        Background="{StaticResource CockpitPanelBgBrush}"
                                        BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <!-- The logo carries the recognition: a colleague finds their project by its
                                             picture before they have read a word. Without one the well shows the
                                             project's initial, so every card is the same shape either way. -->
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <controls:ProjectLogoBadge Grid.Column="0" Size="34"
                                                                       LogoPath="{Binding LogoPath}"
                                                                       ProjectName="{Binding Name}"
                                                                       WellBackground="{StaticResource CockpitSecondaryBgBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <!-- The description carries the card: it is what a colleague reads to know
                                             which one is theirs. A card without one closes up instead of holding
                                             the space open — an empty gap reads as something that failed to load. -->
                                        <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                   VerticalAlignment="Top"
                                                   IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding LastOpenedAt, Converter={x:Static conv:LastOpenedConverter.Instance}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                        <!-- Start only promises a start when the project can actually deliver one.
                                             Without a profile it has nothing to run on and would fall through to
                                             the dialog — the same thing the button below it does, which is exactly
                                             how the two came to look identical. Then the card asks for the missing
                                             piece instead. -->
                                        <Button Classes="Accent" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Padding="12,7"
                                                IsVisible="{Binding DefaultProfileLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).StartProjectSessionCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <materialIcons:MaterialIcon Kind="Play" Width="13" Height="13"
                                                                            VerticalAlignment="Center"/>
                                                <TextBlock Text="Start" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="Accent" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center" Padding="12,7"
                                                IsVisible="{Binding DefaultProfileLabel, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                                ToolTip.Tip="This project has no profile yet, so there is nothing to start it on. Pick one and Start appears."
                                                Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).EditProjectCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <materialIcons:MaterialIcon Kind="Cog" Width="13" Height="13"
                                                                            VerticalAlignment="Center"/>
                                                <TextBlock Text="Finish setting up" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- The quieter half: everything that is not "carry on with this", kept
                                             below the one button that is. -->
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <Button Classes="Subtle" Padding="6,2" FontSize="11" Content="Open folder"
                                                    ToolTip.ShowOnDisabled="True"
                                                    ToolTip.Tip="{Binding SourceDirectory}"
                                                    IsEnabled="{Binding SourceDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).OpenProjectFolderCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="Subtle" Padding="6,2" FontSize="11" Content="Edit"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).EditProjectCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="Subtle" Padding="6,2" FontSize="11" Content="Start with options…"
                                                    ToolTip.Tip="Open the New-session dialog on this project, to change something before it starts"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).NewSessionForProjectCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel IsVisible="{Binding !Projects.HasProjects}" MaxWidth="440" Spacing="10"
                                HorizontalAlignment="Center">
                        <TextBlock Text="No projects yet" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="A project remembers the folder you work in, who works on it and what it may reach — so starting work on it is one click, every time."
                                   TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,24,0,0"
                                HorizontalAlignment="Center">
                        <Button Classes="Accent" Content="+ New project" Padding="14,7"
                                Command="{Binding Projects.AddProjectCommand}"/>
                        <Button Content="Manage projects" Classes="Subtle"
                                Command="{Binding ManageProjectsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state: no session opens on startup; one only exists once the operator creates it. Gated on
                 a Sessions workspace being active, so a dashboard never shows it. -->
            <StackPanel Grid.Row="1" MaxWidth="320" IsVisible="{Binding ShowSessionEmptyState}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14"
                        BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="AI" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource CockpitAccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No sessions yet" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Start a session to begin. You pick the profile — and with it the provider — and its defaults up front."
                           TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}" Margin="0,0,0,16"/>
                <Button Content="+ New session" Command="{Binding NewSessionCommand}"
                        Classes="Accent" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Plugin workspace: the plugin owns the whole body (AC-122). Shown instead of the session/widget
                 grids when a plugin-registered type is active. An unknown type — its plugin is not installed —
                 shows a placeholder rather than an empty surface, and the body appears the moment the plugin
                 registers. -->
            <ContentControl Grid.Row="1"
                            Content="{Binding Workspaces.ActivePluginBody}"
                            IsVisible="{Binding Workspaces.ActivePluginBody, Converter={x:Static avconv:ObjectConverters.IsNotNull}}"/>
            <Border Grid.Row="1" IsVisible="{Binding Workspaces.ShowUnknownPluginWorkspace}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="8" MaxWidth="360">
                    <materialIcons:MaterialIcon Kind="PuzzleOutline" Width="28" Height="28"
                                                HorizontalAlignment="Center" Opacity="0.6"/>
                    <TextBlock Text="This workspace's plugin is not installed."
                               HorizontalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="Install or enable the plugin that provides it, and this workspace comes back."
                               HorizontalAlignment="Center" TextAlignment="Center" FontSize="12"
                               Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Session grid + zoom, shown once at least one session exists and a Sessions workspace is active. -->
            <DockPanel Grid.Row="1" Margin="12" IsVisible="{Binding ShowSessionGrid}">
                <!-- This workspace's toolbar. The ⚙ lives here rather than inside the Zoom row because that row
                     hides itself in single-session layout (#24) — and that is exactly the layout you would open
                     the ⚙ to get back out of. -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <!-- The transient Zoom toggle is hidden in the persistent single-session layout (#24),
                         where it would be a no-op (the single pane is always shown) — no dead control. -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowZoomButton}">
                        <ToggleButton Content="Zoom" IsChecked="{Binding IsZoomed}"
                                      IsEnabled="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}"
                                      ToolTip.Tip="Zoom in on the selected session / back to the grid"/>
                    </StackPanel>

                    <!-- Mirrors the dashboard's gear (its columns/rows/grid lines): each workspace type sets what it
                         actually has, in the same place. -->
                    <!-- Plugin quick-actions (AC-91) sit just left of the gear; both hug the right. -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                        <controls:PluginToolbarHost VerticalAlignment="Center"/>
                        <Button Padding="8,4"
                                ToolTip.Tip="How this workspace arranges its sessions">
                        <materialIcons:MaterialIcon Kind="Cog" Width="14" Height="14"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Spacing="8" MinWidth="300" Margin="4">
                                    <TextBlock Text="Layout" FontWeight="SemiBold"/>
                                    <CheckBox Content="Use the default layout (Options)"
                                              IsChecked="{Binding WorkspaceFollowsGlobalLayout}"/>
                                    <TextBlock Text="Off: this workspace arranges itself, and Options no longer moves it."
                                               Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                                    <!-- Disabled rather than hidden while following: they show what this desk is
                                         doing, which is the thing you came here to read before changing it. -->
                                    <CheckBox Content="Show one session at a time (no grid)"
                                              IsChecked="{Binding WorkspaceSingleSessionLayout}"
                                              IsEnabled="{Binding !WorkspaceFollowsGlobalLayout}"/>
                                    <CheckBox Content="Stack sessions vertically (one column)"
                                              IsChecked="{Binding WorkspaceStackSessionsVertically}"
                                              IsEnabled="{Binding !WorkspaceFollowsGlobalLayout}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- One live session grid serves both layouts: grid mode shows every panel; single-pane
                     mode (#24 / Zoom) collapses all but the selected one to a single column so it fills
                     the width. Keeping one set of views means a session's view (and its TTY pty) is built
                     once and merely hidden when deselected — not rebuilt by a separate single-pane control
                     on every switch, which stranded a relaunched TTY on "Launching TUI...". -->
                <!-- The session grid plus, on top, a hit-transparent accent outline that marks the cell a
                     dragged pane will drop into (#54 follow-up). Both share the same Grid cell so the
                     code-behind can place the outline in the grid's coordinate space. -->
                <Grid>
                <ItemsControl x:Name="SessionGrid" ItemsSource="{Binding Sessions}">
                    <!-- The panel measures its direct children (the generated item containers), so pane
                         visibility must gate the CONTAINER, not a Border inside the template — otherwise a
                         collapsed panel still claims a tile. -->
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter">
                            <Setter Property="IsVisible" Value="{ReflectionBinding IsPaneVisible}"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:SessionTilePanel
                                StackVertically="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).StackSessionsVertically}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionPanelViewModel">
                            <!-- The active panel carries the accent edge (Theme "panel.active") so the
                                 session you're driving jumps out of the grid; others keep the hairline. -->
                            <Border Margin="4" Classes="panel"
                                    Classes.attention="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                    Classes.active="{Binding IsSelected}"
                                    CornerRadius="{StaticResource CockpitPanelRadius}">
                                <DockPanel>
                                    <!-- Drag-reorder grip (#54 follow-up): a grab bar above each pane, shown only when
                                         the draggable multi-pane grid is on. Dragging it picks the pane up and drops it
                                         into any cell; the gutters between panes are separately draggable to resize
                                         (handled by SessionTilePanel). Collapsed in single/zoom = no dead control. -->
                                    <Border x:Name="PaneDragHandle" DockPanel.Dock="Top" Height="14" Margin="0,0,0,2"
                                            Background="{StaticResource CockpitSecondaryBgBrush}"
                                            CornerRadius="{StaticResource CockpitControlRadius}"
                                            Cursor="SizeAll" ToolTip.Tip="Drag to move this pane"
                                            IsVisible="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).StackSessionsInStack}"
                                            PointerPressed="OnPaneDragHandlePressed"
                                            PointerMoved="OnPaneDragHandleMoved"
                                            PointerReleased="OnPaneDragHandleReleased">
                                        <TextBlock Text="⣿⣿⣿" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                    </Border>
                                    <!-- ContentControl + ViewLocator picks SessionView (SDK) or
                                         TtyView (TTY) from the panel view model's type. -->
                                    <ContentControl Content="{Binding}"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Drop-target cell outline: sized/positioned from the panel's cell rect in code-behind
                     while a pane is dragged; hit-transparent so it never blocks the drag. -->
                <Border x:Name="DropIndicator" IsVisible="False" IsHitTestVisible="False" ZIndex="100"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="2"
                        BorderBrush="{StaticResource CockpitAccentBrush}"
                        CornerRadius="{StaticResource CockpitPanelRadius}"/>
                </Grid>
            </DockPanel>

            <!-- Startup banners: plugin failures (#14) and pending approvals (AC-208) stack top-down in a StackPanel
                 rather than each sitting at a fixed Margin — either can be one or two lines depending on how many
                 plugins are named, and a fixed offset would either overlap or leave a gap. Both can show at once:
                 the two states are unrelated (a plugin can fail to load while a different one awaits approval). -->
            <StackPanel VerticalAlignment="Top" Margin="12,12,12,0" Spacing="8">
                <!-- Plugin-failure banner (#14): the app kept running; details live in the Plugin store → Installed. -->
                <Border IsVisible="{Binding HasPluginFailures}"
                        Background="{StaticResource CockpitSecondaryBgBrush}" BorderBrush="{StaticResource CockpitStatusWaitingBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CockpitControlRadius}" Padding="12,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Classes="Subtle" Padding="6,0"
                                Foreground="{StaticResource CockpitTextFaintBrush}"
                                Command="{Binding DismissPluginFailuresCommand}">
                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                        </Button>
                        <TextBlock Text="{Binding PluginFailureBanner}" TextWrapping="Wrap" VerticalAlignment="Center"
                                   Foreground="{StaticResource CockpitStatusWaitingBrush}" FontSize="12"/>
                    </DockPanel>
                </Border>

                <!-- Pending-approval banner (AC-208): plugins sitting at awaiting-approval (new, or bytes changed
                     since approved) otherwise showed up nowhere except a row in Plugin Manager. -->
                <Border IsVisible="{Binding HasPendingApprovals}"
                        Background="{StaticResource CockpitSecondaryBgBrush}" BorderBrush="{StaticResource CockpitStatusWaitingBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CockpitControlRadius}" Padding="12,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Classes="Subtle" Padding="6,0"
                                Foreground="{StaticResource CockpitTextFaintBrush}"
                                Command="{Binding DismissPendingApprovalsCommand}">
                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                        </Button>
                        <TextBlock Text="{Binding PendingApprovalBanner}" TextWrapping="Wrap" VerticalAlignment="Center"
                                   Foreground="{StaticResource CockpitStatusWaitingBrush}" FontSize="12"/>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- The toasts (#61), now a control of their own so a plugin's modal dialog shows the same ones. -->
        <controls:ToastOverlay Grid.Column="0" Grid.ColumnSpan="3"/>

        <!-- The breakdown (#78), rising out of the status bar in the corner the figures are in. It sits in the content
             row, so it floats over the sessions rather than pushing the bar around, and it is anchored bottom-right so
             it lines up with the button that opens it. -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                Classes="resourcePanel"
                Classes.open="{Binding IsResourcePanelOpen}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,10,6"
                Width="320"
                Background="{StaticResource CockpitPanelBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                CornerRadius="8"
                BoxShadow="0 8 24 0 #40000000">
            <StackPanel Margin="14,12" Spacing="10">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Classes="Subtle" Padding="6,0"
                            Command="{Binding CloseResourcePanelCommand}"
                            ToolTip.Tip="Close">
                        <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"/>
                    </Button>
                    <TextBlock Text="Resources" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- The total, big enough to be the thing you came for. It is the whole process tree, so the sessions
                     below are already in it — which the line under them says, rather than leaving it to be inferred
                     from figures that do not add up. -->
                <TextBlock Text="{Binding ResourceSummary}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource CockpitTextPrimaryBrush}"/>

                <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>

                <!-- Above the list, not below it: it says what the list is. -->
                <TextBlock Text="{Binding ResourceDetail}"
                           FontSize="10.5" TextWrapping="Wrap"
                           Foreground="{StaticResource CockpitTextFaintBrush}"/>

                <ItemsControl ItemsSource="{Binding ResourceRows}" IsVisible="{Binding HasResourceRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ResourceRowViewModel">
                            <StackPanel Spacing="3" Margin="0,0,0,10">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Memory}"
                                               FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource CockpitTextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="11.5"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource CockpitTextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                </DockPanel>

                                <!-- How much of the app's memory this one session is: the figure says 700 MB, the bar
                                     says it is most of what is being used, and that is the part you would act on. -->
                                <ProgressBar Height="4" Minimum="0" Maximum="1"
                                             Value="{Binding MemoryShare}"
                                             Foreground="{StaticResource CockpitAccentBrush}"
                                             Background="{StaticResource CockpitSecondaryBgBrush}"/>

                                <TextBlock Text="{Binding Cpu}"
                                           FontSize="10.5"
                                           Foreground="{StaticResource CockpitTextFaintBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- The local model servers (#78). They run beside AI-Cockpit rather than under it — one Ollama serves
                     every session — so they are shown apart from the total above rather than folded into it: a model
                     can weigh more than the whole app, and putting it in a figure the operator reads as "what the
                     AI-Cockpit costs" would be a lie. -->
                <StackPanel Spacing="10" IsVisible="{Binding HasModelServers}">
                    <Border Height="1" Background="{StaticResource CockpitHairlineBrush}"/>

                    <TextBlock Text="Local model servers"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource CockpitTextSecondaryBrush}"/>

                    <ItemsControl ItemsSource="{Binding ModelServerRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResourceRowViewModel">
                                <StackPanel Spacing="3" Margin="0,0,0,10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Memory}"
                                                   FontSize="11.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource CockpitTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource CockpitTextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                    </DockPanel>

                                    <ProgressBar Height="4" Minimum="0" Maximum="1"
                                                 Value="{Binding MemoryShare}"
                                                 Foreground="{StaticResource CockpitAccentBrush}"
                                                 Background="{StaticResource CockpitSecondaryBgBrush}"/>

                                    <TextBlock Text="{Binding Cpu}"
                                               FontSize="10.5"
                                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Runs beside AI-Cockpit, not under it: one server answers every session, so this is not part of the total above."
                               FontSize="10.5" TextWrapping="Wrap"
                               Foreground="{StaticResource CockpitTextFaintBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status bar (#78): what AI-Cockpit is using right now. The total is AI-Cockpit's own process tree,
             so it already contains every session it spawned; the figures open the breakdown per session. -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0"
                Padding="10,4">
            <DockPanel>
                <!-- The memory figure is its own TextBlock so it alone can change colour: amber as it climbs, red at
                     the point where the system starts killing things. A number that turns while you work is something
                     you can act on without being interrupted. -->
                <!-- The figures are a button, and the breakdown is a panel it opens (#78). It used to be a tooltip,
                     which meant relying on the platform to hit-test a strip of text and to place a popup where it was
                     asked to — and on this one it did neither. A button is hit like any other button, and a panel the
                     operator opened is one that stays open while they read it. -->
                <Button DockPanel.Dock="Right"
                        Classes="statusMeter"
                        Padding="8,2"
                        Command="{Binding ToggleResourcePanelCommand}"
                        ToolTip.Tip="What AI-Cockpit and its sessions are using — click for the breakdown per session">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding ResourceCpu}"
                                   FontSize="11"
                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ResourceMemory}"
                                   FontSize="11"
                                   Foreground="{Binding ResourceMemoryBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                                   VerticalAlignment="Center"/>
                        <!-- Points at the panel: up while it is closed (that is where it will come from), down while it
                             is open (that is where it will go). -->
                        <materialIcons:MaterialIcon Kind="ChevronUp" Width="10" Height="10" Margin="0,2,0,0"
                                   IsVisible="{Binding !IsResourcePanelOpen}"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"
                                   VerticalAlignment="Center"/>
                        <materialIcons:MaterialIcon Kind="ChevronDown" Width="10" Height="10" Margin="0,-2,0,0"
                                   IsVisible="{Binding IsResourcePanelOpen}"
                                   Foreground="{StaticResource CockpitTextFaintBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- The delegated tasks (#67) run as sessions without a tab, so the status bar is where they are
                     visible at all: work is happening on your behalf that nothing else on screen would tell you
                     about. Always there, including at nought: a meter that shows up only when it has something to
                     report leaves you unable to tell "nothing is running" from "the meter is gone". The colour carries
                     that — blue while something works, grey while nothing does. -->
                <Button DockPanel.Dock="Right"
                        Classes="statusMeter"
                        Padding="8,2"
                        Margin="0,0,8,0"
                        Command="{Binding ShowDelegatedTasksCommand}"
                        ToolTip.Tip="Work your sessions handed to another profile — click to read what they produced, or stop them">
                    <TextBlock Text="{Binding DelegatedTasks.ActiveTaskCount, StringFormat='Delegated tasks: {0}'}"
                               FontSize="11"
                               Foreground="{Binding DelegatedTasks.ActiveTaskBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Managed worktrees (AC-85): the git worktrees the cockpit created for isolated sessions. Shown only
                     while there are any — click to see each one's state, reattach a gone one, or clean up finished. -->
                <Button DockPanel.Dock="Right"
                        Classes="statusMeter"
                        Padding="8,2"
                        Margin="0,0,8,0"
                        Command="{Binding ShowWorktreesCommand}"
                        IsVisible="{Binding Worktrees.HasWorktrees}"
                        ToolTip.Tip="Git worktrees the cockpit created for isolated sessions — click to view them, reattach a gone one, or clean up">
                    <TextBlock Text="{Binding Worktrees.Count, StringFormat='⑂ Managed worktrees: {0}'}"
                               FontSize="11"
                               Foreground="{Binding Worktrees.CountBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Plugin-registered supervised activities (AC-82): a counter per source (e.g. "Port-forwards: 2"),
                     shown only while it has activities, opening a panel with a Kill per item. -->
                <controls:PluginStatusBarHost DockPanel.Dock="Right"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>

                <TextBlock Text="{Binding ResourceSessions}"
                           FontSize="11"
                           Foreground="{StaticResource CockpitTextFaintBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
    </DockPanel>
</UserControl>
