<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cockpit.App.ViewModels"
             xmlns:conv="using:Cockpit.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
             x:Class="Cockpit.App.Views.CockpitView"
             x:DataType="vm:CockpitViewModel"
             Background="{StaticResource CockpitWindowBgBrush}">

    <Design.DataContext>
        <vm:CockpitViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- The per-session close ✕ stays invisible until its sidebar row is hovered, so the overview
             reads calm; hovering reveals the affordance. Opacity (not IsVisible) keeps the row layout
             stable, and the target is only practically clickable while hovered (thus visible). -->
        <Style Selector="Border.sessionItem Button.closeSession">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Border.sessionItem:pointerover Button.closeSession">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="180,*">

        <!-- Sidebar: always visible in both grid and zoom mode — the constant overview/status anchor. -->
        <Border Grid.Column="0" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="8">

                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                    <Button Content="+ New session" Command="{Binding NewSessionCommand}"
                            Classes="Accent" HorizontalAlignment="Stretch"/>
                    <Button Content="+ New session (TTY)" Command="{Binding NewTtySessionCommand}"
                            Classes="Subtle" HorizontalAlignment="Stretch"
                            IsVisible="{Binding IsTtySupported}"
                            Foreground="{StaticResource CockpitTextSecondaryBrush}"
                            ToolTip.Tip="Experiment: the real interactive claude TUI in a panel (Windows only)"/>
                </StackPanel>

                <!-- Footer: secondary "Tools" section — Audio (F0) lives here, out of the way of the
                     primary session overview per the cockpit's design goal (sidebar = sessions, not tools). -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="4">
                    <Border Height="1" Background="{StaticResource CockpitHairlineBrush}" Margin="0,4"/>
                    <Button Content="Profiles" HorizontalAlignment="Stretch" Classes="Subtle"
                            Command="{Binding ManageProfilesCommand}"
                            Foreground="{StaticResource CockpitTextFaintBrush}"
                            ToolTip.Tip="Add, edit or remove Claude profiles"/>
                    <Button Content="Options" HorizontalAlignment="Stretch" Classes="Subtle"
                            Foreground="{StaticResource CockpitTextFaintBrush}">
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedBottom">
                                <StackPanel Spacing="8" Width="260">
                                    <TextBlock Text="Notifications" FontWeight="SemiBold"/>
                                    <CheckBox Content="Enable presence-aware notifications"
                                              IsChecked="{Binding NotificationsEnabled}"/>
                                    <TextBlock Text="Discord webhook URL (used when away)"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>
                                    <TextBox Text="{Binding WebhookUrl}" PlaceholderText="https://discord.com/api/webhooks/..."/>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="Away after (idle minutes)"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <NumericUpDown Value="{Binding IdleThresholdMinutes}" Minimum="1" Maximum="240"
                                                       Increment="1" FormatString="0" Width="90"/>
                                    </StackPanel>
                                    <Button Content="Save" Command="{Binding SaveNotificationSettingsCommand}"
                                            Classes="Accent" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding NotificationSettingsStatus}"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>

                                    <Border Height="1" Background="{StaticResource CockpitHairlineBrush}" Margin="0,4"/>

                                    <TextBlock Text="Session switching" FontWeight="SemiBold"/>
                                    <CheckBox Content="Switch sessions with modifier + arrows"
                                              IsChecked="{Binding SessionSwitchEnabled}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="Modifier"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding SessionSwitchModifiers}"
                                                  SelectedItem="{Binding SelectedSessionSwitchModifier}"
                                                  DisplayMemberBinding="{Binding Label}" MinWidth="120"/>
                                    </StackPanel>
                                    <TextBlock Text="Left/Up = previous, Right/Down = next. Word navigation in text fields stays intact."
                                               Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                                    <Button Content="Save" Command="{Binding SaveSessionSwitchSettingsCommand}"
                                            Classes="Accent" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding SessionSwitchSettingsStatus}"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>

                                    <Border Height="1" Background="{StaticResource CockpitHairlineBrush}" Margin="0,4"/>

                                    <TextBlock Text="Transcript" FontWeight="SemiBold"/>
                                    <CheckBox Content="Show a timestamp on each message"
                                              IsChecked="{Binding ShowTimestamps}"/>
                                    <Button Content="Save" Command="{Binding SaveTranscriptDisplaySettingsCommand}"
                                            Classes="Accent" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding TranscriptDisplaySettingsStatus}"
                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Content="Tools" HorizontalAlignment="Stretch" Classes="Subtle"
                            Foreground="{StaticResource CockpitTextFaintBrush}">
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedBottom">
                                <StackPanel Spacing="8" Width="200">
                                    <TextBlock Text="Audio (F0)" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Record" Command="{Binding RecordAudioCommand}"/>
                                        <Button Content="Stop" Command="{Binding StopRecordingAudioCommand}"/>
                                        <Button Content="Play" Command="{Binding PlayAudioCommand}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AudioStatus}" Foreground="{StaticResource CockpitTextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SessionPanelViewModel">
                                <!-- Selection + attention are driven entirely by the style classes below
                                     (see Theme.axaml Border.sessionItem*): the active session lifts to a
                                     filled card with an accent left-edge, inactive ones stay flat against
                                     the sidebar. Background/border are NOT set inline here — a local value
                                     would beat the style setters and both rows would look identical. -->
                                <Border Classes="sessionItem" Margin="0,0,0,4" Padding="8,6" CornerRadius="{StaticResource CockpitControlRadius}"
                                        Classes.active="{Binding IsSelected}"
                                        Classes.attention="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                        Cursor="Hand"
                                        PointerPressed="OnSessionItemPointerPressed">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding SessionStatusBrushKey, Converter={x:Static conv:StatusBrushConverter.Instance}}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="⚠" Foreground="{StaticResource CockpitStatusWaitingBrush}"
                                                               IsVisible="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                                               ToolTip.Tip="Needs attention"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding ActiveProfileLabel}"
                                                               Foreground="{StaticResource CockpitTextFaintBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding SessionStatusLabel}"
                                                               Foreground="{StaticResource CockpitTextSecondaryBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Hover-revealed close ✕, hidden while the confirm prompt is up. -->
                                            <Button Grid.Column="1" Classes="Subtle closeSession" Content="✕"
                                                    VerticalAlignment="Top" Padding="4,0" FontSize="12"
                                                    Foreground="{StaticResource CockpitTextFaintBrush}"
                                                    IsVisible="{Binding !IsConfirmingClose}"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).RequestCloseSessionCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Close session"/>
                                        </Grid>

                                        <!-- Inline close confirm for a busy session (L11 pattern): Close / Keep. -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsConfirmingClose}">
                                            <TextBlock Text="Close?" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                            <Button Content="Close" Classes="Compact"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).ConfirmCloseSessionCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Keep" Classes="Compact"
                                                    Command="{Binding $parent[ItemsControl].((vm:CockpitViewModel)DataContext).CancelCloseSessionCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main area: empty-state welcome until a session exists (#31), then the grid/zoom. -->
        <Grid Grid.Column="1">

            <!-- Empty state: no session opens on startup; one only exists once the operator creates it. -->
            <StackPanel IsVisible="{Binding !HasSessions}" MaxWidth="320"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14"
                        BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="AI" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource CockpitAccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No sessions yet" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Start a Claude session to begin. You pick the profile and its defaults up front."
                           TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}" Margin="0,0,0,16"/>
                <Button Content="+ New session" Command="{Binding NewSessionCommand}"
                        Classes="Accent" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Session grid + zoom, shown once at least one session exists. -->
            <DockPanel Margin="12" IsVisible="{Binding HasSessions}">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <ToggleButton Content="Zoom" IsChecked="{Binding IsZoomed}"
                                  IsEnabled="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}"
                                  ToolTip.Tip="Zoom in on the selected session / back to the grid"/>
                </StackPanel>

                <Grid>
                <!-- Grid mode: every session gets an auto-sized panel. -->
                <ItemsControl ItemsSource="{Binding Sessions}" IsVisible="{Binding !IsZoomed}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding GridColumns}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionPanelViewModel">
                            <!-- The active panel carries the accent edge (Theme "panel.active") so the
                                 session you're driving jumps out of the grid; others keep the hairline. -->
                            <Border Margin="4" Classes="panel"
                                    Classes.attention="{Binding SessionStatus, Converter={x:Static conv:IsNeedsAttentionConverter.Instance}}"
                                    Classes.active="{Binding IsSelected}"
                                    CornerRadius="{StaticResource CockpitPanelRadius}">
                                <!-- ContentControl + ViewLocator picks ClaudeSessionView (SDK) or
                                     ClaudeTtyView (TTY) from the panel view model's type. -->
                                <ContentControl Content="{Binding}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Zoom mode: only the selected session, full width/height. -->
                <ContentControl Content="{Binding SelectedSession}"
                                IsVisible="{Binding $parent[DockPanel].((vm:CockpitViewModel)DataContext).IsZoomed}"/>
                </Grid>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
