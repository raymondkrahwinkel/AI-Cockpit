<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cockpit.App.ViewModels"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Cockpit.App.Views.ManageStoresDialog"
        x:DataType="vm:PluginManagerViewModel"
        Title="Manage plugin stores"
        Width="560" Height="560" MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CockpitPanelBgBrush}">

    <Design.DataContext>
        <vm:PluginManagerViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: the manager's status line on the left, Close on the right. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CockpitSecondaryBgBrush}"
                BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="11"
                           MaxWidth="360" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Button Grid.Column="1" Content="Close" Click="OnClose"/>
            </Grid>
        </Border>

        <!-- Header: what a store is, and the add row. -->
        <StackPanel DockPanel.Dock="Top" Margin="18,16,18,10" Spacing="10">
            <StackPanel Spacing="3">
                <TextBlock Text="Plugin stores" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="A store is an index.json listing plugins and workflow templates — a public or private repo, or a folder on this machine. Add one to browse and install what it offers; already-installed plugins stay installed if you remove it."
                           FontSize="11.5" TextWrapping="Wrap"
                           Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
            </StackPanel>

            <!-- Remote (public or private) vs. a local folder — the fields below follow the choice. -->
            <StackPanel Orientation="Horizontal" Spacing="18">
                <RadioButton GroupName="StoreKind" Content="Remote" IsChecked="{Binding !NewStoreIsLocal}"/>
                <RadioButton GroupName="StoreKind" Content="Local folder" IsChecked="{Binding NewStoreIsLocal}"/>
            </StackPanel>

            <!-- Remote store: a URL, plus an optional token for a private one. -->
            <StackPanel Spacing="6" IsVisible="{Binding !NewStoreIsLocal}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBox Grid.Column="0" Text="{Binding NewStoreUrl}"
                             PlaceholderText="github.com/owner/repo  ·  or an index.json URL"/>
                    <Button Grid.Column="1" Content="Add store" Classes="Accent" Command="{Binding AddStoreCommand}"/>
                </Grid>
                <TextBox Text="{Binding NewStoreToken}" PasswordChar="•"
                         PlaceholderText="Access token for a private store (optional)"/>
            </StackPanel>

            <!-- Local store: a folder holding an index.json. -->
            <StackPanel Spacing="6" IsVisible="{Binding NewStoreIsLocal}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                    <TextBox Grid.Column="0" Text="{Binding NewStoreFolder}" IsReadOnly="True"
                             PlaceholderText="Choose a folder holding an index.json"/>
                    <Button Grid.Column="1" Content="Browse…" Command="{Binding PickStoreFolderCommand}"/>
                    <Button Grid.Column="2" Content="Add store" Classes="Accent" Command="{Binding AddStoreCommand}"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Store list, or an empty state when none are configured. -->
        <Panel Margin="14,4,14,12">
            <TextBlock Text="No plugin stores yet. Add one above to start browsing plugins."
                       IsVisible="{Binding !StoreInfos.Count}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="300"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{StaticResource CockpitTextFaintBrush}"/>

            <ScrollViewer IsVisible="{Binding StoreInfos.Count}">
                <ItemsControl ItemsSource="{Binding StoreInfos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PluginStoreInfo">
                            <Border Background="{StaticResource CockpitSecondaryBgBrush}"
                                    BorderBrush="{StaticResource CockpitHairlineBrush}" BorderThickness="1"
                                    CornerRadius="{StaticResource CockpitPanelRadius}" Padding="12,10">
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9" ClipToBounds="True"
                                            Background="{StaticResource CockpitPanelBgBrush}" VerticalAlignment="Center">
                                        <Panel>
                                            <!-- The store's real logo when its index.json advertised one; otherwise
                                                 its own icon glyph, otherwise the default storefront icon. -->
                                            <Image Source="{Binding Logo}" IsVisible="{Binding HasLogo}"
                                                   Width="40" Height="40" Stretch="UniformToFill"/>
                                            <TextBlock Text="{Binding Icon}" FontSize="20"
                                                       IsVisible="{Binding ShowIconGlyph}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <materialIcons:MaterialIcon Kind="StoreOutline" Width="20" Height="20"
                                                       IsVisible="{Binding ShowDefaultIcon}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Panel>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- A private (token) or local store says so, so a glance tells them apart. -->
                                            <materialIcons:MaterialIcon Kind="Lock" Width="13" Height="13"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource CockpitTextFaintBrush}"
                                                       IsVisible="{Binding IsPrivate}"
                                                       ToolTip.Tip="Private store — reached with a token"/>
                                            <materialIcons:MaterialIcon Kind="FolderOutline" Width="13" Height="13"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource CockpitTextFaintBrush}"
                                                       IsVisible="{Binding IsLocal}"
                                                       ToolTip.Tip="Local folder store"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Url}" FontSize="11"
                                                   FontFamily="{StaticResource CockpitMonoFont}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource CockpitTextFaintBrush}"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="11"
                                                   Foreground="{StaticResource CockpitTextSecondaryBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Remove" Classes="Subtle Compact"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource CockpitTextFaintBrush}"
                                            Command="{Binding $parent[ItemsControl].((vm:PluginManagerViewModel)DataContext).RemoveStoreCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Remove this store from the catalogue"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</Window>
