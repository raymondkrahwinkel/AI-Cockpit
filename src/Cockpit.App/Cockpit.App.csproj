<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <!-- The icon Windows Explorer and the taskbar read off the executable itself; the window's own Icon
         (MainWindow.axaml) does not reach either. Both point at the same .ico. -->
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Models\" />
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.5" />
    <!-- The host provides the DataGrid (control + theme) so plugins can use it via Private=false and share
         its type identity + app-wide theme, instead of each shipping and theming their own copy (#14). -->
    <PackageReference Include="Avalonia.Controls.DataGrid" Version="12.0.1" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.5" />
    <PackageReference Include="Avalonia.Headless" Version="12.0.5" />
    <!-- The host provides the Material Design icon set (control + styles), app-wide, so the UI draws icons as
         paths that inherit Foreground instead of emoji glyphs the machine's font renders (AC-33). Plugins use it
         via Private=false/ExcludeAssets=runtime — same host-provided pattern as the DataGrid above, so its type
         identity is shared and the plugin folder ships no copy. 3.0.2 targets Avalonia 12. -->
    <PackageReference Include="Material.Icons.Avalonia" Version="3.0.2" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.3">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
    <!-- TTY-mode experiment (#9): Exclr8.Terminal (MIT), a pure Avalonia terminal-emulator control with
         no PTY plumbing baked in — Write(bytes) feeds pty output in, the Input/Output events carry bytes
         the terminal wants written back (user keystrokes and protocol replies alike), Resized reports
         cell-grid changes. Verified pty-agnostic (no seam that wants to own the process), so the cockpit
         still hosts the pty itself (ConPtyProcess on Windows, PortaPtyProcess on Linux/macOS, both with
         our profile-aware env injection of CLAUDE_CONFIG_DIR + TERM) and renders into this control.
         Vendored from source under third_party/ (see that project) instead of the NuGet package: 1.0.7 is
         the last published release, and the renderer's glyph-drift (AC-66) and reflow/cols (AC-129) bugs
         are fixed in-tree there — a ProjectReference below. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cockpit.Core\Cockpit.Core.csproj" />
    <ProjectReference Include="..\Cockpit.Infrastructure\Cockpit.Infrastructure.csproj" />
    <ProjectReference Include="..\Cockpit.Plugins.Abstractions\Cockpit.Plugins.Abstractions.csproj" />
    <!-- Vendored terminal renderer (MIT), patched in-tree — see third_party/Exclr8.Terminal. -->
    <ProjectReference Include="..\..\third_party\Exclr8.Terminal\Exclr8.Terminal.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Cockpit.Core.Tests" />
    <InternalsVisibleTo Include="Cockpit.App.ViewTests" />
  </ItemGroup>

  <!-- Plugins that ship with the app (#: bundled plugins): features that used to be core and moved out to a
       plugin, so an operator has them out of the box instead of having to know they exist. Referenced with
       ReferenceOutputAssembly=false so they are *built* but never referenced — a bundled plugin must load
       through the plugin loader like any other, in its own load context, or shared types lose their identity.
       BundledPluginInstaller copies them into the operator's plugins directory on startup. -->
  <!-- These plugins live outside Cockpit.slnx, so a solution build has no configuration mapping for them and
       MSBuild — which by default strips Configuration/Platform when descending into a project reference — built
       them as Debug even in a Release build, while CopyBundledPlugins below looks under $(Configuration). On a
       machine with stale Debug output the copy quietly succeeded with yesterday's bytes; on a clean checkout
       (CI) the Release build failed outright, which is how this was found. Keeping the parent configuration is
       exactly what we want here: a bundled plugin is part of this build, not a separate one. -->
  <PropertyGroup>
    <ShouldUnsetParentConfigurationAndPlatform>false</ShouldUnsetParentConfigurationAndPlatform>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\Cockpit.Plugin.TranscriptSearch.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.GitStatus\Cockpit.Plugin.GitStatus.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <!-- The clock: a Dashboard workspace with nothing to put on it is a worse first impression than one that
         already has a clock, and it proves the widget SDK end to end from outside the host. Its former other
         half, the system monitor, is its own plugin from the store — one plugin per widget, so wanting a clock
         is not also wanting a CPU meter. -->
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.Clock\Cockpit.Plugin.Clock.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <!-- The usage-trend widget (AC-54): bundled beside the clock so the ctx/5h/wk trend is there out of the box,
         and it exercises the AC-54 read surface (ICockpitSessionObserver.ActiveSessionUsage) from a real plugin. -->
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.UsageTrend\Cockpit.Plugin.UsageTrend.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <!-- The example workspace (AC-122): bundled so the plugin-owned full-surface workspace type is there out of
         the box, and it exercises the workspace-type SDK — a plugin drawing a whole workspace with a real host
         session embedded in it — from a real plugin, the way UsageTrend exercises the widget SDK. -->
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\Cockpit.Plugin.ExampleWorkspace.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <!-- Autopilot (AC-94, skeleton AC-149): bundled so its workspace and settings are there out of the box; it
         registers a plugin workspace type through the AC-122 SDK. The run flow lands in later sub-tickets. -->
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.Autopilot\Cockpit.Plugin.Autopilot.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
    <!-- Claude as a provider plugin (Fase 4): Claude used to be a core feature and is now a plugin like the
         others here, so an operator gets it out of the box. Both its routes register — the interactive TUI (TTY)
         and the headless SDK route, whose tool approvals ride the control protocol in-band. -->
    <ProjectReference Include="..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\Cockpit.Plugin.ClaudeProvider.csproj"
                      ReferenceOutputAssembly="false" Private="false"
                      SetConfiguration="Configuration=$(Configuration)" />
  </ItemGroup>

  <!-- A single-file build is one file, so the bundled plugins ride inside it: the same dll/deps/plugin.json are
       embedded as resources under their folder names, and BundledPluginResources unpacks them at startup. Only for
       single-file — a normal build keeps its folder, which is what a developer edits and rebuilds.

       The plugins are project references, so they are built before this project compiles; the item is added in a
       target rather than at the top level because at evaluation time those files do not exist yet on a clean
       checkout, and MSBuild refuses an EmbeddedResource pointing at nothing. -->
  <Target Name="EmbedBundledPlugins" BeforeTargets="PrepareForBuild" Condition="'$(PublishSingleFile)' == 'true'">
    <ItemGroup>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.TranscriptSearch.dll">
        <LogicalName>bundled-plugins/transcript-search/Cockpit.Plugin.TranscriptSearch.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.TranscriptSearch.deps.json">
        <LogicalName>bundled-plugins/transcript-search/Cockpit.Plugin.TranscriptSearch.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\plugin.json">
        <LogicalName>bundled-plugins/transcript-search/plugin.json</LogicalName>
      </EmbeddedResource>

      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.GitStatus.dll">
        <LogicalName>bundled-plugins/git-status/Cockpit.Plugin.GitStatus.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.GitStatus.deps.json">
        <LogicalName>bundled-plugins/git-status/Cockpit.Plugin.GitStatus.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\plugin.json">
        <LogicalName>bundled-plugins/git-status/plugin.json</LogicalName>
      </EmbeddedResource>

      <!-- The clock was missing here while its predecessor was bundled: it was copied beside the exe but never
           embedded, so a single file handed over on its own carried two of the three bundled plugins and no
           widget at all. -->
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Clock.dll">
        <LogicalName>bundled-plugins/clock/Cockpit.Plugin.Clock.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Clock.deps.json">
        <LogicalName>bundled-plugins/clock/Cockpit.Plugin.Clock.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\plugin.json">
        <LogicalName>bundled-plugins/clock/plugin.json</LogicalName>
      </EmbeddedResource>

      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.UsageTrend.dll">
        <LogicalName>bundled-plugins/usage-trend/Cockpit.Plugin.UsageTrend.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.UsageTrend.deps.json">
        <LogicalName>bundled-plugins/usage-trend/Cockpit.Plugin.UsageTrend.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\plugin.json">
        <LogicalName>bundled-plugins/usage-trend/plugin.json</LogicalName>
      </EmbeddedResource>

      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ExampleWorkspace.dll">
        <LogicalName>bundled-plugins/example-workspace/Cockpit.Plugin.ExampleWorkspace.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ExampleWorkspace.deps.json">
        <LogicalName>bundled-plugins/example-workspace/Cockpit.Plugin.ExampleWorkspace.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\plugin.json">
        <LogicalName>bundled-plugins/example-workspace/plugin.json</LogicalName>
      </EmbeddedResource>

      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Autopilot.dll">
        <LogicalName>bundled-plugins/autopilot/Cockpit.Plugin.Autopilot.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Autopilot.deps.json">
        <LogicalName>bundled-plugins/autopilot/Cockpit.Plugin.Autopilot.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\plugin.json">
        <LogicalName>bundled-plugins/autopilot/plugin.json</LogicalName>
      </EmbeddedResource>

      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ClaudeProvider.dll">
        <LogicalName>bundled-plugins/claude-provider/Cockpit.Plugin.ClaudeProvider.dll</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ClaudeProvider.deps.json">
        <LogicalName>bundled-plugins/claude-provider/Cockpit.Plugin.ClaudeProvider.deps.json</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\plugin.json">
        <LogicalName>bundled-plugins/claude-provider/plugin.json</LogicalName>
      </EmbeddedResource>
    </ItemGroup>
  </Target>

  <Target Name="CopyBundledPlugins" AfterTargets="Build;Publish">
    <ItemGroup>
      <TranscriptSearchFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.TranscriptSearch.dll;
                                      $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.TranscriptSearch.deps.json;
                                      $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.TranscriptSearch\plugin.json" />
      <GitStatusFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.GitStatus.dll;
                               $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.GitStatus.deps.json;
                               $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.GitStatus\plugin.json" />
      <ClockFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Clock.dll;
                           $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Clock.deps.json;
                           $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Clock\plugin.json" />
      <UsageTrendFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.UsageTrend.dll;
                               $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.UsageTrend.deps.json;
                               $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.UsageTrend\plugin.json" />
      <ExampleWorkspaceFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ExampleWorkspace.dll;
                                     $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ExampleWorkspace.deps.json;
                                     $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ExampleWorkspace\plugin.json" />
      <AutopilotFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Autopilot.dll;
                              $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.Autopilot.deps.json;
                              $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.Autopilot\plugin.json" />
      <ClaudeProviderFiles Include="$(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ClaudeProvider.dll;
                                    $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\bin\$(Configuration)\$(TargetFramework)\Cockpit.Plugin.ClaudeProvider.deps.json;
                                    $(MSBuildThisFileDirectory)..\..\plugins-dev\Cockpit.Plugin.ClaudeProvider\plugin.json" />
    </ItemGroup>
    <Copy SourceFiles="@(TranscriptSearchFiles)" DestinationFolder="$(OutDir)bundled-plugins\transcript-search" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(GitStatusFiles)" DestinationFolder="$(OutDir)bundled-plugins\git-status" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(ClockFiles)" DestinationFolder="$(OutDir)bundled-plugins\clock" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(UsageTrendFiles)" DestinationFolder="$(OutDir)bundled-plugins\usage-trend" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(ExampleWorkspaceFiles)" DestinationFolder="$(OutDir)bundled-plugins\example-workspace" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(AutopilotFiles)" DestinationFolder="$(OutDir)bundled-plugins\autopilot" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(ClaudeProviderFiles)" DestinationFolder="$(OutDir)bundled-plugins\claude-provider" SkipUnchangedFiles="true" />

    <!-- Publish takes a different output root, and a release bundle without its bundled plugins would ship a
         cockpit missing the features that used to be core. -->
    <Copy SourceFiles="@(TranscriptSearchFiles)" DestinationFolder="$(PublishDir)bundled-plugins\transcript-search"
          SkipUnchangedFiles="true" Condition="'$(PublishDir)' != ''" />
    <Copy SourceFiles="@(GitStatusFiles)" DestinationFolder="$(PublishDir)bundled-plugins\git-status"
          SkipUnchangedFiles="true" Condition="'$(PublishDir)' != ''" />
    <Copy SourceFiles="@(ClockFiles)" DestinationFolder="$(PublishDir)bundled-plugins\clock"
          SkipUnchangedFiles="true" Condition="'$(PublishDir)' != ''" />
    <Copy SourceFiles="@(UsageTrendFiles)" DestinationFolder="$(PublishDir)bundled-plugins\usage-trend"
          SkipUnchangedFiles="true" Condition="'$(PublishDir)' != ''" />
    <Copy SourceFiles="@(ClaudeProviderFiles)" DestinationFolder="$(PublishDir)bundled-plugins\claude-provider"
          SkipUnchangedFiles="true" Condition="'$(PublishDir)' != ''" />
  </Target>
</Project>
