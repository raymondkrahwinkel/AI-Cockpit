<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Models\" />
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.5" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.5" />
    <PackageReference Include="Avalonia.Headless" Version="12.0.5" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.3">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cockpit.Core\Cockpit.Core.csproj" />
    <ProjectReference Include="..\Cockpit.Infrastructure\Cockpit.Infrastructure.csproj" />
    <!-- TTY-mode experiment (#9): an in-tree fork of SvcSystems.UI.Terminal (MIT; a pure XTerm.NET
         renderer control — Feed for pty output, UserInput/Send for keystrokes, SizeChanged for
         resize). Chosen over Iciclecreek.Avalonia.Terminal because the latter's TerminalControl owns
         the pty and offers no seam to inject environment variables (Porta.Pty spawns with an empty
         env block), which our profile-aware spawn (CLAUDE_CONFIG_DIR + TERM) requires — so the
         cockpit hosts the pty itself (ConPtyProcess on Windows, PortaPtyProcess on Linux/macOS) and
         renders into this control. Forked in-tree (Fase 1) to fix a cell-width/glyph-advance coupling
         bug in the upstream renderer; see Cockpit.Terminal/NOTICE.md for provenance and the fix. -->
    <ProjectReference Include="..\Cockpit.Terminal\Cockpit.Terminal.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Cockpit.Core.Tests" />
  </ItemGroup>
</Project>
