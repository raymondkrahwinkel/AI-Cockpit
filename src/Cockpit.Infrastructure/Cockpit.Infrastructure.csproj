<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.9" />
    <!-- SessionSwitch (lock/unlock) presence events for the Windows presence detector. The package is
         Windows-only at runtime but restores/builds on any host, keeping Infrastructure a plain net10.0
         assembly (no Windows target framework needed). -->
    <PackageReference Include="Microsoft.Win32.SystemEvents" Version="10.0.9" />
    <!-- Multi-provider (#26): the local-LLM session driver (Ollama/LM Studio) talks to their
         OpenAI-compatible /v1 endpoints through Microsoft.Extensions.AI's IChatClient. The .OpenAI
         package brings the OpenAI SDK plus the AsIChatClient() adapter; a custom Endpoint points it at
         localhost. Later (#26 tool-loop) the same IChatClient hosts MCP tools via ModelContextProtocol. -->
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.7.0" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="10.7.0" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.4.1" />
    <!-- #26 tools/MCP: the MCP client (namespace ModelContextProtocol.Client) that connects the local-LLM
         tool-loop to the user's MCP servers. Kept on the same 1.4.x line as the AspNetCore server package. -->
    <PackageReference Include="ModelContextProtocol" Version="1.4.1" />
    <!-- Read-aloud TTS (#35): sherpa-onnx (Apache-2.0) running Piper VITS voices in-proc — no Python,
         no subprocess. OfflineTts.Generate returns normalized float32 mono PCM plus the voice's own
         sample rate; playback plays at that rate (SoundFlowAudioPlaybackService opens the device on
         whatever AudioFormat.SampleRate is handed in), so no resampling step is needed. -->
    <PackageReference Include="org.k2fsa.sherpa.onnx" Version="1.13.4" />
    <!-- Extracts the .tar.bz2 Piper-voice archives sherpa-onnx's model releases ship as (model.onnx +
         tokens.txt + espeak-ng-data/) — .NET's built-in System.Formats.Tar has no bzip2 decompressor. -->
    <PackageReference Include="SharpCompress" Version="0.49.1" />
    <!-- Linux/macOS pty host for TTY mode (#9): forkpty()+execvp() run entirely in a native shim
         (avoids the .NET 7+ W^X/fork pitfall of forking from managed code), env injection via
         PtyOptions.Environment. Windows keeps the existing hand-rolled ConPtyProcess. -->
    <PackageReference Include="Porta.Pty" Version="1.0.7" />
    <PackageReference Include="SharpHook" Version="7.1.1" />
    <PackageReference Include="SoundFlow" Version="1.4.1" />
    <PackageReference Include="Tmds.DBus" Version="0.92.0" />
    <!-- Voice input (STT+VAD): Whisper.net core plus a hardware-agnostic bundle of native runtimes.
         WhisperBackendPlanner (Cockpit.Core) decides the try-order per VoiceBackendPreference + OS;
         Whisper.net's own NativeLibraryLoader walks that order at model-load time and picks the first
         one that actually loads on the host — CUDA on NVIDIA (Windows+Linux), Vulkan on Windows only
         (no published Linux Vulkan runtime as of 2026-07-07, see WhisperBackendPlanner remarks), plain
         CPU (AVX, with a NoAvx tail) everywhere else, including AMD-on-Linux.
         Runtime.Cuda and Runtime.Cuda12 are separate packages (not one bundling both, despite
         RuntimeLibraryOrder listing both as fallback candidates) — confirmed empirically 2026-07-07 on
         this RTX-4070/Fedora machine: it has CUDA 12.8 installed, "Cuda" alone (CUDA 13 native libs)
         detected the runtime-version mismatch and silently fell back to Cpu; adding Cuda12 explicitly
         is required for CUDA acceleration on a CUDA-12.x host. Both are needed for real hardware-agnostic
         NVIDIA coverage. -->
    <PackageReference Include="Whisper.net" Version="1.9.1" />
    <PackageReference Include="Whisper.net.Runtime" Version="1.9.1" />
    <PackageReference Include="Whisper.net.Runtime.NoAvx" Version="1.9.1" />
  </ItemGroup>

  <!-- The GPU runtimes are 1.4 GB of native libraries, and a self-contained publish ships every one of them to
       every platform — including a Mac, which cannot use a single byte of CUDA or Vulkan. So they are left out
       of a macOS publish and kept everywhere else, which is where they earn their weight (CUDA gives 33x
       realtime on Raymond's RTX 4070; the CPU fallback does not).
       An ordinary build has no RuntimeIdentifier, so the condition holds and a developer keeps GPU Whisper. -->
  <ItemGroup Condition="!$(RuntimeIdentifier.StartsWith('osx'))">
    <PackageReference Include="Whisper.net.Runtime.Cuda" Version="1.9.1" />
    <PackageReference Include="Whisper.net.Runtime.Cuda12" Version="1.9.1" />
    <PackageReference Include="Whisper.net.Runtime.Vulkan" Version="1.9.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cockpit.Core\Cockpit.Core.csproj" />
    <!-- #45: the plugin-provider driver adapter (PluginSessionDriverAdapter) and registry live here, so
         Infrastructure needs the shared plugin-contract types (IPluginSessionDriver, SessionProviderRegistration)
         to translate a plugin's narrow driver into the app's own ISessionDriver. -->
    <ProjectReference Include="..\Cockpit.Plugins.Abstractions\Cockpit.Plugins.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Cockpit.Core.Tests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>

</Project>
