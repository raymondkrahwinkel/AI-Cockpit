<Project Sdk="Microsoft.NET.Sdk">

  <!-- The single assembly shared by the host and every plugin (#14). Plugins reference this with
       <Private>false</Private> so the host's copy is the one loaded — see the plugin build plan's
       type-identity pitfall. Kept dependency-light on purpose: only the DI abstractions (for the
       ConfigureServices hook) and Avalonia (for the Control-factory contribution points). -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
    <PackageReference Include="Avalonia" Version="12.0.5" />
  </ItemGroup>

</Project>
