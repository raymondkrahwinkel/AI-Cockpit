<Project Sdk="Microsoft.NET.Sdk">

  <!-- The single assembly shared by the host and every plugin (#14). Plugins reference this with
       <Private>false</Private> so the host's copy is the one loaded — see the plugin build plan's
       type-identity pitfall. Kept dependency-light on purpose: only the DI abstractions (for the
       ConfigureServices hook) and Avalonia (for the Control-factory contribution points). -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- This assembly is the plugin SDK (#14): authors reference it to build a plugin. It is packable
         so it can be published as a NuGet for out-of-repo authoring; its Version's major must equal
         AbstractionsContract.Version (the manifest's abstractionsVersion the host gates on). XML docs
         ship for author IntelliSense; CS1591 is not enforced (the SDK guide is the reference). -->
    <!-- 1.1.0: members were added since 1.0.0 (AddWorkflowTemplate, ShowSettingsAsync, SuggestAsync, SetSecret/
         GetSecret) and nothing was taken away or changed. Additions are a minor — including the ones carrying a
         default implementation, which is precisely what keeps an existing plugin compiling. The major stays 1
         because AbstractionsContract.Version (the manifest's abstractionsVersion, which the host gates on) counts
         breaking changes, and there have been none. -->
    <!-- 1.2.0: added ProviderConfigStatus (the shared per-field ✓/✗ status line for provider config views). A new
         type is an addition, so still a minor; the major and abstractionsVersion stay 1 (nothing broke). -->
    <!-- 1.3.0 (#AC-13): added ICockpitHost.SetSessionStatusline/SetSessionName and ICockpitActions.
         SetActiveSessionStatusAsync (all default-implemented, so existing plugins keep compiling) and
         WellKnownPluginSessionOptions.PaneId. Additions only — still a minor; the major and abstractionsVersion
         stay 1. -->
    <!-- 1.4.0 (#AC-47): added ICockpitHost.RequestConsentAsync and the Consent types (ConsentRequest/Decision/
         Source/Risk/Outcome) — the shared host-side consent gate. Default-implemented (fails closed → Denied), so
         existing plugins keep compiling. Additions only — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.5.0 (#AC-38): added IWorkflowStep.RequiredConsent — a contributed workflow step declares whether running it
         needs consent (a WorkflowStepConsent: None/LowRisk/Dangerous), so the workflows engine gates it and an MCP
         caller cannot create/arm a flow with a Dangerous one. Existing plugins keep compiling (the member is
         default-implemented), but a non-trigger step that leaves it null is treated as undeclared and left out of the
         editor until it declares None or Dangerous — a step that acts with the operator's rights cannot slip through
         ungated. Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.6.0 (#AC-40): added PluginMcpServer.CockpitHosted so a provider knows which servers are the cockpit's own
         loopback endpoints and must carry this run's bearer key; added WellKnownSessionEnvironment.CockpitMcpKey, the
         env-var name the host sets on every spawned session so the key reaches a server generically without landing in
         a config file — both pure additions. ICockpitHost.AddMcpEndpoint's third parameter changed from a
         bool enabledByDefault to a Func<bool>? isEnabled callback (a plugin can now gate its own cockpit-hosted MCP on
         its setting, read live when a session's servers are gathered): source- and binary-compatible for a plugin that
         called the two-argument form, but a rebuild for one that passed the old bool — in-repo only Workflows called
         it, and it is updated here. On balance additive; the major and abstractionsVersion stay 1. -->
    <!-- 1.7.0 (#AC-1): added PickedConversation (a picked conversation's id plus the directory it ran in) and
         ConversationPickerRegistration.PickWithLocationAsync, the init-only richer picker a folder-scoped provider
         sets so a resumed session starts where it ran. The positional PickAsync (id-only) is unchanged, so an
         existing plugin's constructor call still binds — additions only; the major and abstractionsVersion stay 1. -->
    <!-- 1.8.0 (#AC-33): added an optional MaterialIconKind? IconKind alongside the existing string Icon on
         PluginSessionAction and WidgetRegistration (init-only properties) and IWorkflowStep (a default-implemented
         member returning null), so a contributed action/step/widget can name a bundled vector icon instead of an
         emoji glyph the host renders font-dependently. The string Icon stays and is the fallback when IconKind is
         null, so existing plugins keep compiling and running unchanged. Additive API — still a minor; the major and
         abstractionsVersion stay 1. A plugin that sets IconKind needs a host that ships the icon set (Material.Icons),
         which its minHostVersion must state. -->
    <!-- 1.9.0 (#AC-20): added the managed-CLI contract — the ManagedCli types (ManagedCliDescriptor/DownloadPlan/
         ArchiveFormat/Platform/InstallResult, init-only records) and the reusable ManagedCliConfigSection, plus
         ICockpitHost.AddManagedCli/ResolveManagedCliPath/InstallManagedCliAsync/RemoveManagedCli (default-implemented).
         A plugin describes where its CLI comes from while the host installer stays provider-agnostic. Additive API —
         still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.10.0 (#AC-20): added ManagedCliStatus and ICockpitHost.GetManagedCliStatusAsync (default-implemented), so a
         config view can offer "Update to X" only when a newer version actually exists and a background check can toast
         when an installed managed CLI is outdated. Additive API — still a minor; the major and abstractionsVersion
         stay 1. -->
    <!-- 1.11.0 (#AC-14): added the session-image sink contract — SessionImageAttachment/SessionImageDispatch/
         SessionImageSinkRegistration (records) and ICockpitHost.AddSessionImageSink (default-implemented), so the host
         can route the images an operator sends with a message to any plugin, provider-agnostic (a tracker attaches
         them to the issue its session tracks). Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.12.0 (#AC-91): added the ToolbarAction record and ICockpitHost.AddToolbarAction (default-implemented), so a
         plugin contributes a global quick-action button to the Sessions toolbar next to the workspace gear — it opens
         the plugin's own settings (ShowSettingsAsync) or runs any action it assigns. The icon names a bundled
         MaterialIconKind (like PluginSessionAction's IconKind, AC-33). Existing plugins keep compiling (the member is
         default no-op). Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.13.0 (#AC-116): added the tool-activity read/observe surface — SessionToolActivity (record) plus
         ICockpitSessionObserver.ToolActivityObserved (default no-op) and GetCurrentTurnImages (default empty), so a
         plugin can react to a specific tool call completing (a tracker attaching the message's images to an issue the
         agent just created) rather than scanning prose. REMOVED the AC-14 session-image sink that this supersedes:
         SessionImageDispatch/SessionImageSinkRegistration (records) and ICockpitHost.AddSessionImageSink. Those were
         a default-implemented push hook added one version earlier (1.11.0) with a single in-repo consumer (the
         YouTrack plugin), updated in the same change — no installed third-party plugin used them, so
         AbstractionsContract.Version (the gate PluginLoadPolicy enforces) stays 1 and no plugin is refused. On
         balance additive; the SDK's package version follows suit as a minor. SessionImageAttachment stays (reused by
         GetCurrentTurnImages). -->
    <!-- 1.16.0 (#AC-95): added the inter-plugin intent contract — the PluginIntent record and ICockpitHost.
         RegisterIntentHandler/SendIntent/CanSendIntent (default-implemented), so one plugin can invoke a named action
         on another addressed by its manifest id, with a presence check (CanSendIntent), and no shared contract type
         between them — the tracker's "Start in Autopilot" reaches Autopilot without either referencing the other.
         Existing plugins keep compiling (the members are default no-op / null). Additive API — still a minor; the
         major and abstractionsVersion stay 1. (1.14.0/1.15.0 were skipped — AC-96/AC-54 renumbered past AC-116's
         1.13.0 to avoid a version collision.) -->
    <!-- 1.17.0 (#AC-96): added the NewSessionPrefill record and ICockpitHost.ShowNewSessionDialogAsync (default-
         implemented), so a plugin can open the cockpit's New-session dialog pre-filled and get the started session's
         pane id back through an onStarted callback (or an onCancelled signal) — the operator still confirms every
         field. Existing plugins keep compiling (the member is default no-op). Additive API — still a minor; the major
         and abstractionsVersion stay 1. (Renumbered past AC-116's 1.13.0 to avoid a version collision; 1.14.0/1.15.0
         skipped.) -->
    <!-- 1.18.0 (#AC-54): added SessionUsageSnapshot (the selected session's ctx/5h/wk figures plus its profile label)
         and ICockpitSessionObserver.ActiveSessionUsage/ActiveSessionUsageChanged — the plugin-facing read surface over
         a session's live usage, so a widget can chart it over time. Both are default-implemented (the property returns
         null, the event is a no-op add/remove), so existing observers and test fakes keep compiling. Renumbered past
         AC-116's 1.13.0 and AC-95 (1.16.0)/AC-96 (1.17.0) to the next free minor; 1.14.0/1.15.0 skipped.
         Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.20.0 (#AC-122): added ICockpitHost.AddWorkspaceType/WorkspaceTypes and the Workspaces namespace
         (WorkspaceTypeRegistration, IWorkspaceContext, IEmbeddedSession, EmbeddedSessionRequest) — a plugin can
         register its own full-surface workspace type, owning the whole body and optionally embedding a live host
         session. Both host members are default-implemented (no-op / empty), so existing hosts and test fakes keep
         compiling. Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.21.0 (#AC-180): added EmbeddedSessionRequest.AppendSystemPrompt and WellKnownPluginSessionOptions.AppendSystemPrompt
         — the host folds a hidden per-session system prompt into the launch options map so an embedded run (Autopilot's
         CEO) is briefed at start rather than through a visible turn, and each provider driver applies it its own way
         (a CLI's append-system-prompt flag / Codex's developerInstructions / a leading system message for a local model).
         Both are additions a driver reads only if it wants to; nothing breaks. Additive API — still a minor; the major
         and abstractionsVersion stay 1. -->
    <!-- 1.22.0 (#AC-174): added IWorkspaceContext.Closed (raised once when a workspace is really closed, not on a mere
         tab-switch, so a body can cancel a long-running job like Autopilot's autonomous run) and
         PluginProfileInfo.ModelSuggestions (host-supplied per-profile model list for a picker, since a plugin cannot
         tell a Claude profile from a local one on the provider name alone). Both additive — a default no-op event and
         an init-property with a default — so nothing breaks. Still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.23.0 (#AC-174): added IEmbeddedSession.Completion (a task that completes when an embedded session ends, so an
         embedder awaiting the session — Autopilot's step wait — unblocks instead of hanging when the host ends it) and
         PluginSessionCapabilities.ConfinesFileAccessToWorkingDirectory (whether a provider's file tools stay in the
         session working directory, so the host can refuse an isolate-in-worktree run on a provider that cannot confine
         them rather than let it edit the operator's real checkout) and PluginProfileInfo.RunsLocally (host-supplied
         cost signal — a local free model vs a paid hosted API — so Autopilot's CEO can pick the cheapest-adequate model
         per step), plus IEmbeddedSession.SetInputEnabled and EmbeddedSessionRequest.StartWithInputDisabled (an
         autonomous embedded run starts with its composer off so the operator does not type into a self-driving session,
         and re-enables it to intervene). Completion and SetInputEnabled are new interface members, but no plugin
         implements IEmbeddedSession — the host hands it out — so nothing breaks; the info/request additions are
         init-properties with defaults. Additive in practice — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.24.0 (#AC-174): added ICockpitHost.DetectGitDirectoryStatusAsync (with the GitDirectoryStatus enum) so a
         plugin can tell up front whether a working directory is a git repository — Autopilot isolates each step in a
         repo but runs an admin task in a plain folder without isolation, rather than failing at the first step — and
         GetRememberedWorkingPathsAsync/RememberWorkingPathAsync (with PluginRememberedWorkingPaths) so a plugin that
         asks the operator to name a working directory offers the same pinned/recent folders as the New-session quick-pick.
         The status enum defaults to Unknown (fail-closed: treat as needing isolation) and both host members are
         default-implemented (Unknown / Empty / no-op), so existing hosts and test fakes keep compiling. Additive API —
         still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.25.0 is the single Autopilot-release minor that folds in four additive groups (AC-189, AC-190, AC-195 landed
         on ICockpitHost.cs / PluginSessionCapabilities.cs / IEmbeddedSession.cs without touching this Version; AC-202
         carried the one bump). Nothing was removed or changed, so the major and abstractionsVersion stay 1.
         - AC-189: ICockpitHost.RegisterAutopilotTemplate (default no-op) plus the PluginAutopilotTemplate /
           RegisteredAutopilotTemplate records — a plugin contributes a reusable Autopilot run template.
         - AC-190: PluginSessionCapabilities.ConfinesViaPermissionsOnly (init, default false) — a provider marks that its
           worktree confinement rests on its permission system (Claude) rather than an OS sandbox, so the isolation gate
           can vouch a permission-engaged mode and refuse a bypass mode.
         - AC-195: IEmbeddedSession.IsBusy (default false) and BusyChanged (default no-op event) — an embedder lights or
           clears a "working" indicator; no plugin implements IEmbeddedSession (the host hands it out) so nothing breaks.
         - AC-202: the TrackerWorkStage enum (a tracker-neutral point in a consumer's work lifecycle) and
           ITrackerProvider.SuggestStageName (default null → no auto-mapping), which maps it to the tracker's own stage
           name so Autopilot moves a source issue automatically at run-start and merge-ready without hardcoding any
           tracker's vocabulary. An existing provider keeps compiling and loading; it simply is not auto-moved until it
           opts in.
         All four are additions (new types, init-properties with defaults, or default-implemented members) — a minor. -->
    <Version>1.25.0</Version>
    <AssemblyVersion>1.8.0.0</AssemblyVersion>
    <PackageId>Cockpit.Plugins.Abstractions</PackageId>
    <Title>Cockpit Plugin SDK</Title>
    <Description>The contract assembly for building Cockpit plugins: ICockpitPlugin (two-phase lifecycle), ICockpitHost (Options-tab and side-menu contribution points), ICockpitActions (clipboard / inject into the active session) and IPluginStorage.</Description>
    <Authors>Raymond Krahwinkel</Authors>
    <Company>Krahwinkel-IT</Company>
    <Copyright>Copyright (c) 2026 Raymond Krahwinkel / Krahwinkel-IT</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <!-- The MaterialIconKind enum only (no Avalonia control), so a contribution point can name a bundled vector
         icon (AC-33). The host ships the runtime copy via Material.Icons.Avalonia; plugins get the enum through
         this reference compile-only, like Avalonia above. -->
    <PackageReference Include="Material.Icons" Version="3.0.2" />
  </ItemGroup>

</Project>
