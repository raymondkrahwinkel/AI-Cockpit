<Project Sdk="Microsoft.NET.Sdk">

  <!-- The single assembly shared by the host and every plugin (#14). Plugins reference this with
       <Private>false</Private> so the host's copy is the one loaded — see the plugin build plan's
       type-identity pitfall. Kept dependency-light on purpose: only the DI abstractions (for the
       ConfigureServices hook) and Avalonia (for the Control-factory contribution points). -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- This assembly is the plugin SDK (#14): authors reference it to build a plugin. It is packable
         so it can be published as a NuGet for out-of-repo authoring; its Version's major must equal
         AbstractionsContract.Version (the manifest's abstractionsVersion the host gates on). XML docs
         ship for author IntelliSense; CS1591 is not enforced (the SDK guide is the reference). -->
    <!-- 1.1.0: members were added since 1.0.0 (AddWorkflowTemplate, ShowSettingsAsync, SuggestAsync, SetSecret/
         GetSecret) and nothing was taken away or changed. Additions are a minor — including the ones carrying a
         default implementation, which is precisely what keeps an existing plugin compiling. The major stays 1
         because AbstractionsContract.Version (the manifest's abstractionsVersion, which the host gates on) counts
         breaking changes, and there have been none. -->
    <!-- 1.2.0: added ProviderConfigStatus (the shared per-field ✓/✗ status line for provider config views). A new
         type is an addition, so still a minor; the major and abstractionsVersion stay 1 (nothing broke). -->
    <!-- 1.3.0 (#AC-13): added ICockpitHost.SetSessionStatusline/SetSessionName and ICockpitActions.
         SetActiveSessionStatusAsync (all default-implemented, so existing plugins keep compiling) and
         WellKnownPluginSessionOptions.PaneId. Additions only — still a minor; the major and abstractionsVersion
         stay 1. -->
    <!-- 1.4.0 (#AC-47): added ICockpitHost.RequestConsentAsync and the Consent types (ConsentRequest/Decision/
         Source/Risk/Outcome) — the shared host-side consent gate. Default-implemented (fails closed → Denied), so
         existing plugins keep compiling. Additions only — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.5.0 (#AC-38): added IWorkflowStep.RequiredConsent — a contributed workflow step declares whether running it
         needs consent (a WorkflowStepConsent: None/LowRisk/Dangerous), so the workflows engine gates it and an MCP
         caller cannot create/arm a flow with a Dangerous one. Existing plugins keep compiling (the member is
         default-implemented), but a non-trigger step that leaves it null is treated as undeclared and left out of the
         editor until it declares None or Dangerous — a step that acts with the operator's rights cannot slip through
         ungated. Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.6.0 (#AC-40): added PluginMcpServer.CockpitHosted so a provider knows which servers are the cockpit's own
         loopback endpoints and must carry this run's bearer key; added WellKnownSessionEnvironment.CockpitMcpKey, the
         env-var name the host sets on every spawned session so the key reaches a server generically without landing in
         a config file — both pure additions. ICockpitHost.AddMcpEndpoint's third parameter changed from a
         bool enabledByDefault to a Func<bool>? isEnabled callback (a plugin can now gate its own cockpit-hosted MCP on
         its setting, read live when a session's servers are gathered): source- and binary-compatible for a plugin that
         called the two-argument form, but a rebuild for one that passed the old bool — in-repo only Workflows called
         it, and it is updated here. On balance additive; the major and abstractionsVersion stay 1. -->
    <!-- 1.7.0 (#AC-1): added PickedConversation (a picked conversation's id plus the directory it ran in) and
         ConversationPickerRegistration.PickWithLocationAsync, the init-only richer picker a folder-scoped provider
         sets so a resumed session starts where it ran. The positional PickAsync (id-only) is unchanged, so an
         existing plugin's constructor call still binds — additions only; the major and abstractionsVersion stay 1. -->
    <!-- 1.8.0 (#AC-33): added an optional MaterialIconKind? IconKind alongside the existing string Icon on
         PluginSessionAction and WidgetRegistration (init-only properties) and IWorkflowStep (a default-implemented
         member returning null), so a contributed action/step/widget can name a bundled vector icon instead of an
         emoji glyph the host renders font-dependently. The string Icon stays and is the fallback when IconKind is
         null, so existing plugins keep compiling and running unchanged. Additive API — still a minor; the major and
         abstractionsVersion stay 1. A plugin that sets IconKind needs a host that ships the icon set (Material.Icons),
         which its minHostVersion must state. -->
    <!-- 1.9.0 (#AC-20): added the managed-CLI contract — the ManagedCli types (ManagedCliDescriptor/DownloadPlan/
         ArchiveFormat/Platform/InstallResult, init-only records) and the reusable ManagedCliConfigSection, plus
         ICockpitHost.AddManagedCli/ResolveManagedCliPath/InstallManagedCliAsync/RemoveManagedCli (default-implemented).
         A plugin describes where its CLI comes from while the host installer stays provider-agnostic. Additive API —
         still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.10.0 (#AC-20): added ManagedCliStatus and ICockpitHost.GetManagedCliStatusAsync (default-implemented), so a
         config view can offer "Update to X" only when a newer version actually exists and a background check can toast
         when an installed managed CLI is outdated. Additive API — still a minor; the major and abstractionsVersion
         stay 1. -->
    <!-- 1.11.0 (#AC-14): added the session-image sink contract — SessionImageAttachment/SessionImageDispatch/
         SessionImageSinkRegistration (records) and ICockpitHost.AddSessionImageSink (default-implemented), so the host
         can route the images an operator sends with a message to any plugin, provider-agnostic (a tracker attaches
         them to the issue its session tracks). Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.12.0 (#AC-91): added the ToolbarAction record and ICockpitHost.AddToolbarAction (default-implemented), so a
         plugin contributes a global quick-action button to the Sessions toolbar next to the workspace gear — it opens
         the plugin's own settings (ShowSettingsAsync) or runs any action it assigns. The icon names a bundled
         MaterialIconKind (like PluginSessionAction's IconKind, AC-33). Existing plugins keep compiling (the member is
         default no-op). Additive API — still a minor; the major and abstractionsVersion stay 1. -->
    <!-- 1.17.0 (#AC-96): added the NewSessionPrefill record and ICockpitHost.ShowNewSessionDialogAsync (default-
         implemented), so a plugin can open the cockpit's New-session dialog pre-filled and get the started session's
         pane id back through an onStarted callback (or an onCancelled signal) — the operator still confirms every
         field. Existing plugins keep compiling (the member is default no-op). Additive API — still a minor; the major
         and abstractionsVersion stay 1. Sits above AC-95's in-flight 1.13.0; a version clash at merge is Raymond's to
         resolve. -->
    <Version>1.17.0</Version>
    <AssemblyVersion>1.8.0.0</AssemblyVersion>
    <PackageId>Cockpit.Plugins.Abstractions</PackageId>
    <Title>Cockpit Plugin SDK</Title>
    <Description>The contract assembly for building Cockpit plugins: ICockpitPlugin (two-phase lifecycle), ICockpitHost (Options-tab and side-menu contribution points), ICockpitActions (clipboard / inject into the active session) and IPluginStorage.</Description>
    <Authors>Raymond Krahwinkel</Authors>
    <Company>Krahwinkel-IT</Company>
    <Copyright>Copyright (c) 2026 Raymond Krahwinkel / Krahwinkel-IT</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <!-- The MaterialIconKind enum only (no Avalonia control), so a contribution point can name a bundled vector
         icon (AC-33). The host ships the runtime copy via Material.Icons.Avalonia; plugins get the enum through
         this reference compile-only, like Avalonia above. -->
    <PackageReference Include="Material.Icons" Version="3.0.2" />
  </ItemGroup>

</Project>
