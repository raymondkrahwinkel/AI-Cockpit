<Project Sdk="Microsoft.NET.Sdk">

  <!-- Workflow editor (#69): the visual canvas where cockpit workflows are drawn. Built OUTSIDE the main
       solution (plugins-dev/) like the other plugins; package bin/<config>/net10.0 into a .zip and install it
       via the plugin store. EnableDynamicLoading emits the .deps.json the host's AssemblyDependencyResolver
       needs. Shared assemblies (Cockpit.Plugins.Abstractions, Avalonia, the DI abstractions) are compile-only
       (Private=false / ExcludeAssets=runtime) so the host's copies load and shared types keep one identity —
       the plugin folder ships only its own DLL + plugin.json.

       No node-editor package: every one of them depends on Avalonia.Xaml.Behaviors, which has no Avalonia 12
       release, while the host is on Avalonia 12 (spikes/spike-node-editor demonstrates the resulting crash). The
       canvas is therefore plain Avalonia — which also means this plugin ships no third-party runtime at all. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Cockpit.Plugins.Abstractions\Cockpit.Plugins.Abstractions.csproj">
      <Private>false</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Jint" Version="4.12.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <!-- The [McpServerTool] attributes for the workflow MCP (#AC-12). Host-provided (the cockpit already loads
         ModelContextProtocol), so compile-only — the plugin ships no copy and the attribute types keep one identity. -->
    <PackageReference Include="ModelContextProtocol" Version="1.4.1">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- Lets Cockpit.Plugin.Workflows.Tests reach the internal store and canvas, same pattern as the other plugins. -->
    <InternalsVisibleTo Include="Cockpit.Plugin.Workflows.Tests" />
  </ItemGroup>

</Project>
